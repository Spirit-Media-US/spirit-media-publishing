---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
	title: string;
	description?: string;
	/** Absolute or root-relative path to the OG share image. Defaults to /og-image.png */
	ogImage?: string;
}

const { title, description = 'Spirit Media Publishing', ogImage = 'https://cdn.sanity.io/images/pmowd8uo/production/83b595b916eeb64126e303f3fc71027c55aa6dbb-4000x2588.png?w=1200&h=630&fm=jpg&q=85' } = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Spirit Media Publishing" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Spirit Media Publishing" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@spiritmediaus" />
    <meta name="twitter:creator" content="@spiritmediaus" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Per-page head slot (keywords, schema, etc.) -->
    <slot name="head" />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W3R21TNHTX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W3R21TNHTX');
    </script>

    <!-- Google Fonts: Cormorant Garamond (display) + Source Sans 3 (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon-final.svg" />

    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col bg-stone-50 text-ink antialiased">
    <Navbar />
    <slot />
    <Footer />

    <script>
      function initAnimations() {
        // Scroll-triggered animations — triggers [data-animate] elements via IntersectionObserver
        const revealEl = (el: Element) => el.classList.add('is-visible');

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                revealEl(entry.target);
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.04, rootMargin: '0px 0px 0px 0px' }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

        // Fallback: force-reveal any remaining hidden elements after 2.5s
        setTimeout(() => {
          document.querySelectorAll('[data-animate]:not(.is-visible)').forEach(revealEl);
        }, 2500);

        // Hero stagger — add .loaded shortly after page load
        const heroStagger = document.querySelector('.hero-stagger');
        if (heroStagger) {
          setTimeout(() => heroStagger.classList.add('loaded'), 60);
        }
      }

      document.addEventListener('astro:page-load', initAnimations);
    </script>
  </body>
</html>
