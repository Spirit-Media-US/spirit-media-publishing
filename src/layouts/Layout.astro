---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

interface Props {
	title: string;
	description?: string;
	/** Absolute or root-relative path to the OG share image. Defaults to siteSettings.ogImage */
	ogImage?: string;
}

const { title, description = 'Spirit Media Publishing' } = Astro.props;
let ogImage = Astro.props.ogImage;
let twitterHandle = '@spiritmediaus';
let gaId = 'G-W3R21TNHTX';

// Fetch siteSettings for default OG image, Twitter handle, and GA ID
try {
	const siteSettings = await sanityClient.fetch(
		'*[_type == "siteSettings"][0]{ ogImage, twitterHandle, googleAnalyticsId }',
	);
	if (siteSettings) {
		// If no explicit ogImage prop, use siteSettings
		if (!ogImage && siteSettings.ogImage) {
			ogImage =
				urlFor(siteSettings.ogImage).width(1200).height(630).format('jpg').url() || undefined;
		}
		if (siteSettings.twitterHandle) twitterHandle = siteSettings.twitterHandle;
		if (siteSettings.googleAnalyticsId) gaId = siteSettings.googleAnalyticsId;
	}
} catch (e) {
	console.error('Error fetching siteSettings:', e);
}

// Fallback OG image if still not set — served from R2, same origin as fonts.
if (!ogImage) {
	ogImage =
		'https://assets.spiritmediapublishing.com/spirit-media-publishing/homepage/og-homepage.jpg';
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- TLS warmup for LCP-critical origin. Homepage and most marketing pages
         now serve all imagery from R2 (same origin as fonts + logo) — Sanity
         preconnect removed because on mobile it wasted a TLS connection slot
         without a matching resource fetch. Pages that still use cdn.sanity.io
         (blog post bodies, bookstore) can add their own preconnect via
         <slot name="head"> if needed. -->
    <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />

    <!-- Critical fonts on the mobile above-fold:
         - Playfair 800 → H1
         - Source Sans 400 → hero paragraphs
         - Source Sans 700 → <strong> inside p2 + both CTA button labels
         Not preloading these three caused ~100KB of late-arriving font payload
         that triggered post-FCP LCP re-paints on mobile. -->
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/playfair-display/playfair-display-800.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/source-sans-3/source-sans-3-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/source-sans-3/source-sans-3-700.woff2" crossorigin />

    <!-- Per-page head slot — hoisted so page-specific LCP preloads (e.g., hero image) come early -->
    <slot name="head-early" />

    <!-- Gate hero-stagger animation on window.load (post-LCP). CSS selectors
         use `html.loaded` so no animation runs during the LCP paint window,
         eliminating style+layout main-thread cost that held back image paint. -->
    <script is:inline>
      addEventListener('load', () => document.documentElement.classList.add('loaded'));
    </script>

    <!-- ========================================================================
         CRITICAL CSS — hand-rolled coverage of above-fold utilities site-wide.
         Enables above-fold paint before the async Tailwind bundle arrives.
         Covers homepage hero, shared nav, and first-screen utilities for every
         indexed page. Keep under 6KB. Any utility used above the fold on any
         indexed page must appear here (union, not intersection).
         ======================================================================== -->
    <style is:inline>
      /* --- critical @font-face (unlayered per CSS spec — @font-face is not valid inside @layer) --- */
      @font-face{font-family:'Playfair Display';font-style:normal;font-weight:800;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/playfair-display/playfair-display-800.woff2') format('woff2')}
      @font-face{font-family:'Playfair Display';font-style:normal;font-weight:700;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/playfair-display/playfair-display-700.woff2') format('woff2')}
      @font-face{font-family:'Source Sans 3';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/source-sans-3/source-sans-3-400.woff2') format('woff2')}
      @font-face{font-family:'Source Sans 3';font-style:normal;font-weight:700;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/source-sans-3/source-sans-3-700.woff2') format('woff2')}
      /* Metric-adjusted fallbacks — eliminate FCP→LCP gap from font-swap re-paint.
         Georgia / Times as local serif, Arial / Helvetica as local sans. The
         size-adjust + ascent/descent-override values approximate the real font
         metrics so the paint box is stable before and after swap. */
      @font-face{font-family:'Playfair fallback';font-style:normal;font-weight:700 800;src:local('Liberation Serif'),local('DejaVu Serif'),local('Georgia'),local('Times New Roman'),local('Times');size-adjust:107%;ascent-override:95%;descent-override:24%;line-gap-override:0%}
      @font-face{font-family:'SourceSans fallback';font-style:normal;font-weight:400 700;src:local('Liberation Sans'),local('DejaVu Sans'),local('Arial'),local('Helvetica');size-adjust:100.8%;ascent-override:95%;descent-override:22%;line-gap-override:0%}

      /* --- All critical CSS wrapped in @layer base so Tailwind v4's async-
             loaded @layer utilities always wins the cascade when the full
             bundle arrives. CSS rule: unlayered > any @layer, regardless
             of specificity. Prior bug (2026-04-19): unlayered .grid-cols-1
             beat external .lg\:grid-cols-4 → every card grid rendered
             single-column on desktop. --- */
      @layer base {
        /* resets */
        *,*::before,*::after{box-sizing:border-box;border:0 solid}
        html{-webkit-text-size-adjust:100%;font-size:18px;line-height:1.7;scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
        body{margin:0;background:#faf8f5;color:#574e45;font-family:'Source Sans 3','SourceSans fallback',system-ui,sans-serif;line-height:1.7}
        img,picture,svg,video,canvas{display:block;max-width:100%;height:auto}
        h1,h2,h3,h4,h5,h6{margin:0;font-family:'Playfair Display','Playfair fallback',Georgia,serif;color:#2e2a26;line-height:1.2;font-weight:600;overflow-wrap:break-word}
        p{margin:0;overflow-wrap:break-word}
        a{color:inherit;text-decoration:none}
        button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}

        /* SMP custom component classes used above the fold */
        .type-hero{font-family:'Playfair Display','Playfair fallback',Georgia,serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:800;line-height:1.08;letter-spacing:-.02em}
        .type-body-lg{font-family:'Source Sans 3','SourceSans fallback',system-ui,sans-serif;font-size:1rem;line-height:1.75}
        .eyebrow{display:block;font-family:'Source Sans 3','SourceSans fallback',system-ui,sans-serif;font-size:1rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#574e45;margin-bottom:.75rem}
        .eyebrow-red{color:#c0392b}
        .btn{display:inline-flex;align-items:center;gap:.5rem;font-family:'Source Sans 3','SourceSans fallback',system-ui,sans-serif;font-size:.875rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:.75rem 1.75rem;border-radius:.375rem;cursor:pointer;border:2px solid transparent;text-decoration:none;transition:all .15s}
        .btn-primary{background-color:#c0392b;color:#fff;border-color:#c0392b}
        .btn-primary:hover{background-color:#9b2d20;border-color:#9b2d20;color:#fff}
        .btn-ghost{background-color:transparent;color:#c0392b;border-color:#c0392b}
        .btn-ghost:hover{background-color:#c0392b;color:#fff}
        /* hero-stagger: fires only after window.load (see inline script above) —
           keeps main-thread style+layout quiet during LCP paint window. */
        html.loaded .hero-stagger>*:nth-child(1){animation:fadeUp .7s .1s cubic-bezier(.16,1,.3,1) both}
        html.loaded .hero-stagger>*:nth-child(2){animation:fadeUp .7s .22s cubic-bezier(.16,1,.3,1) both}
        html.loaded .hero-stagger>*:nth-child(3){animation:fadeUp .7s .34s cubic-bezier(.16,1,.3,1) both}
        html.loaded .hero-stagger>*:nth-child(4){animation:fadeUp .7s .46s cubic-bezier(.16,1,.3,1) both}
        html.loaded .hero-stagger>*:nth-child(5){animation:fadeUp .7s .58s cubic-bezier(.16,1,.3,1) both}

        /* Tailwind utility copies so above-fold renders before the async bundle.
           External @layer utilities overrides these once the bundle loads. */
        .flex{display:flex}.inline-flex{display:inline-flex}.grid{display:grid}.block{display:block}.hidden{display:none}.inline-block{display:inline-block}
        .items-center{align-items:center}.items-start{align-items:flex-start}
        .justify-between{justify-content:space-between}.justify-center{justify-content:center}.justify-start{justify-content:flex-start}
        .flex-col{flex-direction:column}.flex-wrap{flex-wrap:wrap}.shrink-0{flex-shrink:0}.flex-1{flex:1 1 0%}
        .grid-cols-1{grid-template-columns:repeat(1,minmax(0,1fr))}
        .gap-1{gap:.25rem}.gap-2{gap:.5rem}.gap-3{gap:.75rem}.gap-4{gap:1rem}.gap-16{gap:4rem}
        .order-first{order:-9999}
        .sticky{position:sticky}.relative{position:relative}.absolute{position:absolute}.fixed{position:fixed}
        .top-0{top:0}.left-0{left:0}.right-0{right:0}.inset-0{inset:0}
        .z-10{z-index:10}.z-40{z-index:40}.z-50{z-index:50}
        .h-6{height:1.5rem}.h-8{height:2rem}.h-14{height:3.5rem}.h-20{height:5rem}.h-auto{height:auto}.h-full{height:100%}
        .w-6{width:1.5rem}.w-8{width:2rem}.w-full{width:100%}.w-auto{width:auto}
        .min-h-screen{min-height:100vh}
        .max-w-7xl{max-width:80rem}.max-w-3xl{max-width:48rem}.max-w-xl{max-width:36rem}
        .max-w-\[275px\]{max-width:275px}
        .max-h-\[360px\]{max-height:360px}
        .mx-auto{margin-inline:auto}.my-0{margin-block:0}
        .mt-2{margin-top:.5rem}.mt-4{margin-top:1rem}.mt-6{margin-top:1.5rem}.mt-7{margin-top:1.75rem}.mt-9{margin-top:2.25rem}
        .mb-2{margin-bottom:.5rem}.mb-4{margin-bottom:1rem}.mb-6{margin-bottom:1.5rem}
        .p-2{padding:.5rem}
        .px-3{padding-inline:.75rem}.px-4{padding-inline:1rem}.px-6{padding-inline:1.5rem}.px-8{padding-inline:2rem}
        .py-1{padding-block:.25rem}.py-2{padding-block:.5rem}.py-3{padding-block:.75rem}
        .pt-8{padding-top:2rem}.pt-14{padding-top:3.5rem}.pb-10{padding-bottom:2.5rem}.pb-12{padding-bottom:3rem}
        .border-b{border-bottom-width:1px}.border-stone-100{border-color:#f5f1ec}.border-stone-200{border-color:#ede7df}
        .rounded{border-radius:.375rem}.rounded-md{border-radius:.5rem}.rounded-lg{border-radius:.75rem}.rounded-full{border-radius:9999px}
        .bg-stone-50{background-color:#faf8f5}.bg-stone-100{background-color:#f5f1ec}.bg-surface{background-color:#fff}.bg-white{background-color:#fff}
        .bg-red{background-color:#c0392b}.hover\:bg-red-deep:hover{background-color:#9b2d20}.hover\:bg-stone-50:hover{background-color:#faf8f5}.hover\:bg-stone-100:hover{background-color:#f5f1ec}
        .text-xs{font-size:1rem}.text-sm{font-size:1rem}.text-base{font-size:1rem}.text-lg{font-size:1rem}
        .text-white{color:#fff}.text-stone-300{color:#d9d0c4}.text-stone-400{color:#bfb4a4}.text-stone-500{color:#9e9285}.text-stone-600{color:#7a6e63}.text-stone-700{color:#574e45}
        .text-ink-soft{color:#2e2a26}.text-ink{color:#1a1714}.text-red{color:#c0392b}.text-red-soft{color:#d4544a}
        .hover\:text-ink:hover{color:#1a1714}.hover\:text-red-deep:hover{color:#9b2d20}
        .font-medium{font-weight:500}.font-semibold{font-weight:600}.font-bold{font-weight:700}
        .uppercase{text-transform:uppercase}.text-center{text-align:center}
        .tracking-\[0\.08em\]{letter-spacing:.08em}.tracking-widest{letter-spacing:.1em}
        .leading-tight{line-height:1.25}
        .object-contain{object-fit:contain}.object-cover{object-fit:cover}
        .overflow-hidden{overflow:hidden}
        .shadow-sm{box-shadow:0 1px 2px 0 rgba(26,23,20,.08)}
        .transition-colors{transition:color .15s,background-color .15s,border-color .15s}.transition-all{transition:all .15s}
        .antialiased{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
        .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

        /* Responsive variants above fold */
        @media(min-width:640px){
          .sm\:px-6{padding-inline:1.5rem}
          .sm\:inline-flex{display:inline-flex}
          .sm\:max-w-\[325px\]{max-width:325px}
        }
        @media(min-width:1024px){
          .lg\:block{display:block}
          .lg\:hidden{display:none}
          .lg\:h-24{height:6rem}
          .lg\:px-8{padding-inline:2rem}
          .lg\:pt-12{padding-top:3rem}
          .lg\:pb-16{padding-bottom:4rem}
          .lg\:grid-cols-2{grid-template-columns:repeat(2,minmax(0,1fr))}
          .lg\:order-last{order:9999}
          .lg\:max-h-\[600px\]{max-height:600px}
        }
      }

      /* @keyframes must live outside @layer */
      @keyframes fadeUp{from{opacity:0}to{opacity:1}}
    </style>

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Spirit Media Publishing" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Spirit Media Publishing" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Per-page head slot (keywords, schema, etc.) -->
    <slot name="head" />

    <!-- Google Analytics GA4 — loaded on first user interaction to protect LCP/TBT.
         Kohler/TMCG pattern: scroll/mousemove/touchstart/keydown/click triggers load
         with an 8s fallback timeout. Keeps ~130ms of gtag JS off the LCP main thread. -->
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      function loadGA() {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', gaId);
      }
      var gaEvents = ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'];
      function gaTrigger(){ gaEvents.forEach(function(e){ window.removeEventListener(e, gaTrigger); }); loadGA(); }
      gaEvents.forEach(function(e){ window.addEventListener(e, gaTrigger, { passive: true, once: true }); });
      setTimeout(function(){ if(!window.__gaLoaded) loadGA(); }, 8000);
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon-final.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
  </head>
  <body class="flex min-h-screen flex-col bg-stone-50 text-ink antialiased">
    <Navbar />
    <slot />
    <Footer />

    <script>
      function initAnimations() {
        // Scroll-triggered animations — triggers [data-animate] elements via IntersectionObserver
        const revealEl = (el: Element) => el.classList.add('is-visible');

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                revealEl(entry.target);
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.04, rootMargin: '0px 0px 0px 0px' }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

        // Fallback: force-reveal any remaining hidden elements after 2.5s
        setTimeout(() => {
          document.querySelectorAll('[data-animate]:not(.is-visible)').forEach(revealEl);
        }, 2500);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimations);
      } else {
        initAnimations();
      }
    </script>
  </body>
</html>
