---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Work On Yourself — Spirit Media"
	description="WOY is a soul care intensive by Spirit Media — designed for leaders, pastors, and Kingdom voices who are burning out or running on empty."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">A Spirit Media Initiative</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Work On Yourself
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed mb-8">
					A soul care intensive for leaders, pastors, and Kingdom voices who are ready to stop
					performing and start healing — because you can't pour from an empty vessel.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="https://workonyourself.com"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors"
					>
						Visit WorkOnYourself.com
					</a>
					<a href="#about" class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors">
						Learn More
					</a>
				</div>
			</div>
		</section>

		<!-- THE PROBLEM -->
		<section id="about" class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">Leaders Are Burning Out</h2>
				<p class="text-lg text-gray-700 leading-relaxed mb-6">
					Ministry leadership is one of the most emotionally and spiritually demanding callings in
					the world. The invisible weight of caring for others — while hiding your own wounds —
					eventually takes a toll.
				</p>
				<p class="text-lg text-gray-700 leading-relaxed">
					Work On Yourself (WOY) was created for the leader who is still showing up, still
					preaching, still serving — but running on fumes inside. It's time to do the inner work.
				</p>
			</div>
		</section>

		<!-- WHAT IS WOY -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="max-w-3xl mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">What Is the WOY Intensive?</h2>
					<p class="text-lg text-gray-700 leading-relaxed">
						WOY is a multi-day soul care intensive experience that brings leaders into a safe,
						structured environment for deep inner work. Combining prophetic ministry, inner healing
						prayer, identity restoration, and practical leadership tools — WOY is where leaders
						come to be cared for, not to perform.
					</p>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">💛</div>
						<h3 class="font-semibold text-gray-900 mb-2">Inner Healing</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Address the root wounds that drive unhealthy patterns in leadership and life</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">🌿</div>
						<h3 class="font-semibold text-gray-900 mb-2">Identity Restoration</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Reconnect with who God created you to be, apart from your role or ministry</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">🛠️</div>
						<h3 class="font-semibold text-gray-900 mb-2">Soul Care Tools</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Practical rhythms and practices for sustainable leadership health</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">🤝</div>
						<h3 class="font-semibold text-gray-900 mb-2">Community</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Experience the power of being known and loved in a safe community of peers</p>
					</div>
				</div>
			</div>
		</section>

		<!-- WHO IT'S FOR -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">Who Should Attend WOY?</h2>
				<ul class="space-y-4">
					<li class="flex items-start gap-3 text-gray-700">
						<span class="text-red-600 mt-1">•</span> Pastors and church leaders
					</li>
					<li class="flex items-start gap-3 text-gray-700">
						<span class="text-red-600 mt-1">•</span> Ministry founders and executives
					</li>
					<li class="flex items-start gap-3 text-gray-700">
						<span class="text-red-600 mt-1">•</span> Authors and speakers who carry heavy messages
					</li>
					<li class="flex items-start gap-3 text-gray-700">
						<span class="text-red-600 mt-1">•</span> Kingdom entrepreneurs feeling isolated
					</li>
					<li class="flex items-start gap-3 text-gray-700">
						<span class="text-red-600 mt-1">•</span> Anyone in full-time ministry approaching burnout
					</li>
				</ul>
			</div>
		</section>

		<!-- GET STARTED -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">It's Time to Work On Yourself</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Visit the official WOY website to learn about upcoming intensives, dates, and how to register.
				</p>
				<a
					href="https://workonyourself.com"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Visit WorkOnYourself.com →
				</a>
			</div>
		</section>

	</main>
</Layout>
