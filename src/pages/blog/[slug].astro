---
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity.ts';

// Static site — pre-render all blog posts from Sanity at build time
export async function getStaticPaths() {
	const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
	return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

// Fetch the full post
const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, {
	slug,
});

if (!post) {
	return Astro.redirect('/blog');
}

// Helper function to render portable text blocks as HTML
function renderPortableText(blocks: any[]): string {
	if (!Array.isArray(blocks)) return '';

	return blocks
		.map((block: any) => {
			if (!block || block._type !== 'block') return '';

			const children = Array.isArray(block.children) ? block.children : [];
			const textContent = children
				.map((child: any) => {
					if (!child) return '';
					let text = child.text || '';
					const marks = Array.isArray(child.marks) ? child.marks : [];
					if (marks.length > 0) {
						if (marks.includes('strong')) text = `<strong>${text}</strong>`;
						if (marks.includes('em')) text = `<em>${text}</em>`;
						const linkMark = marks.find(
							(m: any) => m && typeof m === 'object' && m._type === 'link',
						);
						if (linkMark?.href) {
							text = `<a href="${linkMark.href}" class="text-red hover:underline" target="_blank" rel="noopener noreferrer">${text}</a>`;
						}
					}
					return text;
				})
				.join('');

			const style = block.style || 'normal';
			if (style === 'h2')
				return `<h2 class="text-2xl font-serif font-bold text-ink-soft mt-8 mb-4">${textContent}</h2>`;
			if (style === 'h3')
				return `<h3 class="text-xl font-serif font-bold text-ink-soft mt-6 mb-3">${textContent}</h3>`;
			return `<p class="text-stone-600 mb-4 leading-relaxed">${textContent}</p>`;
		})
		.join('');
}

// Format publish date
const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishDate = formatDate(post.publishDate);
const heroImage = post.heroImage
	? urlFor(post.heroImage).width(1200).format('webp').url()
	: '/blog-default.jpg';
const author = post.author || 'Kevin White';
const tags = post.tags || [];

const bodyHtml = renderPortableText(post.body);
---

<Layout
  title={post.seoTitle || `${post.title} | Spirit Media Publishing Blog`}
  description={post.seoDescription || post.excerpt || 'Read this article on the Spirit Media Publishing blog'}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "image": heroImage,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" },
      "url": `https://spiritmediapublishing.com/blog/${post.slug.current}`,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <main id="main-content">
    <!-- HERO IMAGE -->
    <div class="w-full">
      <img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-72 lg:h-96 object-cover" />
    </div>

    <!-- POST HEADER -->
    <section class="bg-stone-50 px-6 pt-10 pb-2 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red hover:text-red-deep transition-colors mb-5">← Back to Blog</a>
        <h1 class="type-hero text-ink-soft">{post.title}</h1>
        {post.excerpt && <p class="mt-3 type-body-lg text-stone-600 max-w-2xl">{post.excerpt}</p>}
        <div class="flex items-center gap-3 mt-4 pb-8 text-sm text-stone-500 border-b border-stone-200">
          <span>By <span class="font-semibold text-ink-soft">{author}</span></span>
          <span>·</span>
          <span>{publishDate}</span>
        </div>
      </div>
    </section>

    <!-- TAGS -->
    {tags.length > 0 && (
      <section class="bg-stone-50 px-6 pb-6 lg:px-8 border-b border-stone-200">
        <div class="mx-auto max-w-3xl">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold text-stone-600 bg-stone-200 hover:bg-red hover:text-white rounded-full px-3 py-1 transition-colors">
                {tag}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- POST CONTENT -->
    <section class="bg-white px-6 py-10 lg:px-8 lg:py-16">
      <div class="mx-auto max-w-3xl prose prose-stone max-w-none">
        <div set:html={bodyHtml} class="space-y-4" />
      </div>
    </section>

    <!-- SHARE BAR -->
    <ShareBar />

    <!-- RELATED POSTS -->
    <RelatedPosts />
  </main>
</Layout>
