---
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity.ts';

// Static site — pre-render all blog posts from Sanity at build time
export async function getStaticPaths() {
	const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
	return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

// Fetch the full post
const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, {
	slug,
});

if (!post) {
	return Astro.redirect('/blog');
}

// Slugify heading text for jump-link anchors. Lowercases, strips punctuation,
// collapses whitespace to single hyphens. Must match the Jump-to TOC's #anchors.
function slugifyHeading(s: string): string {
	return s
		.toLowerCase()
		.replace(/[‘’“”]/g, '')
		.replace(/[^\w\s-]/g, '')
		.trim()
		.replace(/\s+/g, '-');
}

// Render Sanity portable text to HTML.
//
// Sanity stores link annotations as a separate `markDefs` array on each block;
// the child span carries only the markDef _key as a string. Looking up that
// _key in markDefs gives us the href. Strong/em are inline string decorators.
function renderPortableText(blocks: any[]): string {
	if (!Array.isArray(blocks)) return '';

	return blocks
		.map((block: any) => {
			if (!block || block._type !== 'block') return '';

			const children = Array.isArray(block.children) ? block.children : [];
			const rawText = children.map((c: any) => c?.text || '').join('');
			// Skip placeholder blocks left over from content drafts
			if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText.trim())) return '';

			const markDefs = Array.isArray(block.markDefs) ? block.markDefs : [];
			const linkByKey: Record<string, string> = {};
			for (const md of markDefs) {
				if (md && md._type === 'link' && md._key && md.href) {
					linkByKey[md._key] = md.href;
				}
			}

			const textContent = children
				.map((child: any) => {
					if (!child) return '';
					let text = child.text || '';
					const marks = Array.isArray(child.marks) ? child.marks : [];
					if (marks.length > 0) {
						if (marks.includes('strong')) text = `<strong>${text}</strong>`;
						if (marks.includes('em')) text = `<em>${text}</em>`;
						const linkKey = marks.find((m: any) => typeof m === 'string' && linkByKey[m]);
						if (linkKey) {
							const href = linkByKey[linkKey];
							const isExternal = /^https?:\/\//i.test(href);
							const targetAttrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';
							text = `<a href="${href}" class="text-red hover:underline"${targetAttrs}>${text}</a>`;
						}
					}
					return text;
				})
				.join('');

			const style = block.style || 'normal';
			if (style === 'h2') {
				const id = slugifyHeading(rawText);
				return `<h2 id="${id}" class="font-serif text-2xl font-bold text-ink-soft mt-12 mb-4 scroll-mt-24">${textContent}</h2>`;
			}
			if (style === 'h3')
				return `<h3 class="font-serif text-xl font-bold text-ink-soft mt-8 mb-3">${textContent}</h3>`;
			if (style === 'blockquote')
				return `<blockquote class="my-6 px-6 py-5 lg:px-8 rounded-2xl text-lg leading-relaxed bg-stone-50 border border-stone-200 text-ink-soft">${textContent}</blockquote>`;
			return `<p class="type-body-lg text-stone-700 leading-relaxed mb-4">${textContent}</p>`;
		})
		.join('');
}

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishDate = formatDate(post.publishDate);
// Surface a visible "Updated" stamp only when dateModified differs from publishDate.
// publishDate is a date (YYYY-MM-DD); dateModified is a datetime. Compare on the
// date portion so a same-day "modified" timestamp doesn't render a noisy stamp.
const modifiedDate =
	post.dateModified && post.dateModified.slice(0, 10) !== post.publishDate
		? formatDate(post.dateModified)
		: null;
const heroImage = post.heroImage
	? urlFor(post.heroImage).width(1200).format('webp').url()
	: '/blog-default.jpg';
const author = post.author || 'Kevin White';
const tags = post.tags || [];

const bodyHtml = renderPortableText(post.body);

const postUrl = `https://spiritmediapublishing.com/blog/${post.slug.current}`;
const dateModified = post.dateModified || post.publishDate;

// BlogPosting schema: now carries dateModified (Gold-Level milestone #14).
const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.title,
	description: post.excerpt || post.seoDescription || post.title,
	image: heroImage,
	author: { '@type': 'Person', name: author },
	publisher: {
		'@type': 'Organization',
		name: 'Spirit Media Publishing',
		url: 'https://spiritmediapublishing.com',
	},
	url: postUrl,
	mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
	datePublished: post.publishDate,
	dateModified,
	inLanguage: 'en-US',
	keywords: tags.join(', '),
	articleSection: tags[0] || undefined,
};

// FAQPage schema — only emitted when the post defines FAQ pairs in Sanity
// (Gold-Level milestone #13). AI Overviews and Perplexity extract these verbatim.
const faqs = Array.isArray(post.faqs) ? post.faqs : [];
const faqSchema =
	faqs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqs
					.filter((f: any) => f?.question && f?.answer)
					.map((f: any) => ({
						'@type': 'Question',
						name: f.question,
						acceptedAnswer: { '@type': 'Answer', text: f.answer },
					})),
			}
		: null;

const jsonLd = [blogPostingSchema, faqSchema].filter(Boolean);
---

<Layout
  title={post.seoTitle || `${post.title} | Spirit Media Publishing Blog`}
  description={post.seoDescription || post.excerpt || 'Read this article on the Spirit Media Publishing blog'}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    <meta property="article:modified_time" content={dateModified} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
  </Fragment>

  <main id="main-content">
    <!-- HERO IMAGE -->
    <div class="w-full">
      <img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-72 lg:h-[600px] object-cover" />
    </div>

    <!-- POST HEADER -->
    <section class="bg-stone-50 px-6 pt-10 pb-2 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red hover:text-red-deep transition-colors mb-5">← Back to Blog</a>
        <h1 class="type-hero text-ink-soft">{post.title}</h1>
        {post.excerpt && <p class="mt-3 type-body-lg text-stone-600 max-w-2xl">{post.excerpt}</p>}
        <div class="flex items-center gap-3 mt-4 pb-8 text-sm text-stone-500 border-b border-stone-200 flex-wrap">
          <span>By <span class="font-semibold text-ink-soft">{author}</span></span>
          <span>·</span>
          <span>{publishDate}</span>
          {modifiedDate && (
            <>
              <span>·</span>
              <span>Updated {modifiedDate}</span>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- TAGS -->
    {tags.length > 0 && (
      <section class="bg-stone-50 px-6 pb-6 lg:px-8 border-b border-stone-200">
        <div class="mx-auto max-w-3xl">
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold text-stone-600 bg-stone-200 hover:bg-red hover:text-white rounded-full px-3 py-1 transition-colors">
                {tag}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- POST CONTENT -->
    <section class="bg-white px-6 py-10 lg:px-8 lg:py-16">
      <div class="mx-auto max-w-3xl prose prose-stone max-w-none">
        <div set:html={bodyHtml} class="space-y-4" />
      </div>
    </section>

    <!-- SHARE BAR -->
    <ShareBar title={post.title} url={`https://spiritmediapublishing.com/blog/${post.slug.current}`} />

    <!-- RELATED POSTS -->
    <RelatedPosts currentSlug={`/blog/${post.slug.current}`} currentTags={tags} />
  </main>
</Layout>
