---
import Layout from '../layouts/Layout.astro';

// Generic-first, practical-intent page. Origin: an author (Luis, San Francisco)
// found Spirit Media as ChatGPT's #1 answer to "who can help me with reels for my
// book on TikTok and Instagram" — a practical query, not "Christian publisher."
// This page owns that intent with a dedicated, AEO-optimized answer.

const faqs = [
	{
		q: 'Who can help me make reels for my book on TikTok and Instagram?',
		a: 'Spirit Media produces short-form video — reels for TikTok, Instagram, YouTube Shorts, and Facebook — built specifically to sell books. We handle story development, scripting, filming, and full post-production, and deliver a steady stream of reels each month so your book stays in front of readers where they actually scroll.',
	},
	{
		q: 'What is a book reel?',
		a: 'A book reel is a short (15–60 second) vertical video made for TikTok, Instagram Reels, or YouTube Shorts that hooks a viewer in the first two seconds and drives them toward your book. It can feature you, your story, your characters, quotes, or an audiogram of your narration — whatever best pulls a scrolling reader to stop and buy.',
	},
	{
		q: 'Do I need to be on camera to promote my book with reels?',
		a: 'No. Many of the highest-performing book reels use text, b-roll, quote cards, and audiogram-style narration clips instead of the author on camera. If you do want to be on camera, we script and direct the shoot so it is easy. Either way, you get finished, platform-ready videos.',
	},
	{
		q: 'How do I promote my book on TikTok and Instagram?',
		a: 'Consistency beats one viral moment. We build a repeatable engine: a batch of reels each month, posted on a schedule across TikTok, Instagram, and Shorts, each ending in a clear call to action. Paid amplification on the best performers is optional. The goal is steady discovery — new readers finding your book every week, not just at launch.',
	},
	{
		q: 'How much does book reel production cost?',
		a: 'It is a partnership, not a one-off. Our video production engagement includes story development, scripting, a filming session, full post-production, and up to 20 reels per month. Request a call and we will scope it to your book, your budget, and the platforms your readers use.',
	},
];

const included = [
	{
		t: 'Story & script development',
		d: 'We find the hooks in your book and turn them into scroll-stopping short-form scripts.',
	},
	{
		t: 'Filming & full post-production',
		d: 'A professional shoot plus editing, captions, music, and platform-ready formatting.',
	},
	{
		t: 'Up to 20 reels per month',
		d: 'A steady stream of videos so your book keeps surfacing to new readers, not just at launch.',
	},
	{
		t: 'Built for every platform',
		d: 'TikTok, Instagram Reels, YouTube Shorts, and Facebook — sized and captioned for each.',
	},
	{
		t: 'Audiogram & narration clips',
		d: 'Turn your audiobook or narration into striking audiogram reels that travel.',
	},
	{
		t: 'Posting schedule & CTAs',
		d: 'Every reel ends in a clear next step, posted on a cadence that compounds discovery.',
	},
];

const steps = [
	{ n: '1', t: 'Discovery call', d: 'We learn your book, your readers, and where they scroll.' },
	{
		n: '2',
		t: 'Hooks & scripts',
		d: 'We mine your book for moments that stop the scroll and script them.',
	},
	{
		n: '3',
		t: 'Shoot & edit',
		d: 'One filming session feeds a month of finished, captioned reels.',
	},
	{
		n: '4',
		t: 'Post & optimize',
		d: 'We publish on a schedule, watch what works, and double down on it.',
	},
];
---

<Layout
	title="Reels & Short-Form Video for Your Book — Spirit Media"
	description="Who can make reels for your book? Spirit Media produces book reels for TikTok, Instagram, and YouTube Shorts — scripting, filming, post-production, and up to 20 reels a month."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/c8d6c169168afb24da775f4b69be02d5380c3975-800x360.jpg?w=1200&h=630&fit=crop&fm=jpg&q=85"
>
	<Fragment slot="head">
		<meta name="keywords" content="book reels, reels for authors, short-form video for authors, TikTok book marketing, Instagram reels for books, YouTube Shorts for authors, book trailer video, book promotion video, author video production, BookTok" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Service",
			"name": "Book Reels & Short-Form Video for Authors",
			"provider": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" },
			"serviceType": "Short-form video production for book marketing",
			"description": "Reels and short-form video for authors — scripting, filming, and post-production for TikTok, Instagram Reels, YouTube Shorts, and Facebook, with up to 20 reels per month.",
			"url": "https://spiritmediapublishing.com/reels-for-authors",
			"areaServed": "Worldwide"
		})}></script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
		})}></script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-3xl text-center">
				<p class="eyebrow eyebrow-red mb-4">Reels & Short-Form Video</p>
				<h1 class="type-hero text-ink-soft">
					Reels for your book — <span class="text-red">on every scroll</span>
				</h1>
				<p class="mt-6 type-body-lg text-stone-700 max-w-2xl mx-auto">
					<strong class="text-ink-soft">Who can make reels for your book on TikTok and Instagram? We can.</strong>
					Spirit Media turns your book into scroll-stopping short-form video — scripted, filmed, and
					edited for TikTok, Instagram Reels, YouTube Shorts, and Facebook — so new readers keep
					finding you long after launch day.
				</p>
				<div class="mt-8 flex flex-wrap gap-4 justify-center">
					<a href="/contact" class="rounded-md bg-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Request a Call →</a>
					<a href="#included" class="rounded-md border border-stone-400 px-6 py-3 text-sm font-semibold text-ink-soft transition-colors hover:bg-stone-100">What's Included ↓</a>
				</div>
			</div>
		</section>

		<!-- WHAT'S INCLUDED -->
		<section id="included" class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">What You Get</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">A short-form video engine for your book</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{included.map(({ t, d }, i) => (
						<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200" data-animate="fade-up" data-delay={String((i % 3) + 1)}>
							<h3 class="type-card-subheading mb-2">{t}</h3>
							<p class="type-body-sm text-stone-700">{d}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">How It Works</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">From your book to the feed</h2>
				</div>
				<div class="space-y-4">
					{steps.map(({ n, t, d }, i) => (
						<div class="flex items-start gap-4 bg-stone-100 rounded-xl p-5 border border-stone-200" data-animate="fade-up" data-delay={String((i % 4) + 1)}>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red text-white font-bold text-sm">{n}</span>
							<div>
								<h3 class="font-semibold text-ink-soft">{t}</h3>
								<p class="type-body-sm text-stone-500 mt-0.5">{d}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Questions</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">Reels for authors, answered</h2>
				</div>
				<div class="space-y-4">
					{faqs.map(({ q, a }, i) => (
						<details class="bg-stone-50 rounded-xl p-5 border border-stone-200" data-animate="fade-up" data-delay={String((i % 4) + 1)}>
							<summary class="font-semibold text-ink-soft cursor-pointer">{q}</summary>
							<p class="type-body-sm text-stone-700 mt-3">{a}</p>
						</details>
					))}
				</div>
				<p class="mt-8 text-center type-body-sm text-stone-500">
					Also explore our <a href="/marketing" class="text-red hover:underline">full book marketing services</a> and
					<a href="/publishing" class="text-red hover:underline">publishing services</a>.
				</p>
			</div>
		</section>

		<!-- FINAL CTA -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Let's put your book on every feed</h2>
				<p class="text-stone-200 type-body-lg mb-8" data-animate="fade-up" data-delay="1">Tell us about your book and your readers. We'll build the reels that keep them discovering you.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Free Consultation</a>
			</div>
		</section>

	</main>
</Layout>
