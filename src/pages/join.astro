---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Join the Spirit Media Network — Spirit Media"
	description="Join the Spirit Media Network — a community of Kingdom Messengers, authors, and leaders on a mission to carry God's message to the nations."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-white px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-4">Community</p>
						<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight text-gray-900">Join the Spirit Media<br /><span class="text-red-600">Network</span></h1>
						<p class="mt-6 text-lg leading-8 text-gray-600 max-w-xl">Spirit Media Network is a global community for Kingdom Messengers — a single ecosystem where formation, publishing, and mission come together.</p>
						<p class="mt-3 text-base text-gray-500 max-w-xl">Whether you're writing your first book, interceding for the nations, or discerning your next step, you'll find your lane.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-red-800 aspect-square"></div>
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-gray-900 aspect-square"></div>
						<div class="rounded-2xl bg-red-700 aspect-square"></div>
						<div class="rounded-2xl bg-gray-800 aspect-square"></div>
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-gray-900 aspect-square"></div>
						<div class="rounded-2xl bg-red-800 aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- LANES -->
		<section class="bg-gray-50 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3" data-animate="fade-up">Choose Your Lane</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900 sm:text-4xl" data-animate="fade-up" data-delay="1">Find Your Place in the Network</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
					{[
						{ title: "Writers' Room", body: 'Writing support, structure, editing feedback, and beta readers from fellow authors.' },
						{ title: 'Publishing & Marketing Lab', body: 'Launch strategy, Amazon optimization, podcast tours, and audience growth.' },
						{ title: "Father's Heart Movement", body: "Join a global movement publishing and distributing the Father's Heart Bible to the nations." },
						{ title: 'Resource Library', body: 'Free eBooks, starter kits, and downloadable guides to sharpen your message.' },
					].map(({ title, body }, i) => (
						<div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm" data-animate="fade-up" data-delay={String(i + 1)}>
							<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">{title}</h3>
							<p class="text-sm text-gray-600 leading-relaxed">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red-600 px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Membership is free.</h2>
				<p class="text-red-100 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">Join the network, introduce yourself, and choose your lane.</p>
				<a href="https://spiritmedianetwork.mn.co" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-red-600 font-semibold px-8 py-3.5 rounded-md hover:bg-red-50 transition-colors" data-animate="fade-up" data-delay="2">Join the Network (Free) →</a>
			</div>
		</section>

	</main>
</Layout>
