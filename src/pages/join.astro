---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Join the Spirit Media Network — Community for Christian Authors & Leaders"
	description="Join the Spirit Media Network — a free community for Christian authors, speakers, and Kingdom leaders. Get resources, support, and connection to help you carry your message to the nations."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/232962df9e9743a5790ae86776ab683dbd76042b-1200x630?w=1200&h=630&fit=crop&auto=format.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Spirit Media Network, Christian author community, free community for authors, Kingdom Messenger community, Christian leaders network, Mighty Networks Christian, Christian publishing community, Christian author resources" />
		<meta name="robots" content="index, follow" />
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Community</p>
						<h1 class="type-hero text-ink-soft">Join the Spirit Media<br /><span class="text-red">Network</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">Spirit Media Network is a global community for Kingdom Messengers — a single ecosystem where formation, publishing, and mission come together.</p>
						<p class="mt-3 type-body text-stone-500 max-w-xl">Whether you're writing your first book, interceding for the nations, or discerning your next step, you'll find your lane.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-ink-muted aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- LANES -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Choose Your Lane</p>
					<h2 class="font-serif text-3xl font-bold text-ink-soft sm:text-4xl" data-animate="fade-up" data-delay="1">Find Your Place in the Network</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
					{[
						{ title: "Writers' Room", body: 'Writing support, structure, editing feedback, and beta readers from fellow authors.' },
						{ title: 'Publishing & Marketing Lab', body: 'Launch strategy, Amazon optimization, podcast tours, and audience growth.' },
						{ title: "Father's Heart Movement", body: "Join a global movement publishing and distributing the Father's Heart Bible to the nations." },
						{ title: 'Resource Library', body: 'Free eBooks, starter kits, and downloadable guides to sharpen your message.' },
					].map(({ title, body }, i) => (
						<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm" data-animate="fade-up" data-delay={String(i + 1)}>
							<h3 class="font-serif text-lg font-bold text-ink-soft mb-2">{title}</h3>
							<p class="type-body-sm text-stone-600 leading-relaxed">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Membership is free.</h2>
				<p class="text-stone-200 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">Join the network, introduce yourself, and choose your lane.</p>
				<a href="https://spiritmedianetwork.mn.co" target="_blank" rel="noopener noreferrer" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Join the Network (Free) →</a>
			</div>
		</section>

	</main>
</Layout>
