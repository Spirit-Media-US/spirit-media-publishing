---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join the Spirit Media Network — Spirit Media" description="Join the Spirit Media Network — a community of Kingdom Messengers, authors, and leaders on a mission to carry God's message to the nations.">
  <main id="main-content">

    <!-- HERO -->
    <section class="bg-red-600 text-white py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Community</p>
        <h1 class="text-4xl md:text-5xl font-bold font-serif mb-6">Join the Spirit Media Network</h1>
        <p class="text-lg md:text-xl text-red-100 leading-relaxed mb-8 max-w-2xl mx-auto">
          A global community of Kingdom Messengers, authors, leaders, and world-changers. This is where your journey finds its tribe.
        </p>
        <a
          href="https://spiritmedianetwork.mn.co"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-white text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors"
        >
          Join the Community
        </a>
      </div>
    </section>

    <!-- WHAT IS THE NETWORK -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-6">What Is the Spirit Media Network?</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          The Spirit Media Network is our online community built on Mighty Networks — a private, ad-free space where Kingdom authors, leaders, and voices gather to connect, grow, and encourage one another on the journey.
        </p>
        <p class="text-gray-700 leading-relaxed">
          This is not another Facebook group. This is a purposeful community with shared values, curated conversations, and regular content from the Spirit Media team.
        </p>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="bg-gray-50 py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-12 text-center">What's Inside the Community</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">🎙️</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Live Sessions</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Monthly live calls with Kevin White and special guests</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">📚</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Resource Library</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Exclusive access to courses, workshops, and publishing guides</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">✍️</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Author Community</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Connect with other Kingdom authors at every stage of their journey</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">🙏</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Prayer & Support</h3>
            <p class="text-gray-700 leading-relaxed text-sm">A community that prays together and carries one another's burdens</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">⚡</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Early Access</h3>
            <p class="text-gray-700 leading-relaxed text-sm">First access to new Spirit Media programs, events, and resources</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="text-red-600 text-2xl mb-3">🎯</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Accountability</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Find your accountability partner and stay on mission together</p>
          </div>

        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-12 text-center">How to Join</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">

          <div class="text-center">
            <div class="w-12 h-12 bg-red-600 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">1</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Click the Join Button</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Click the button below to visit our Mighty Networks community</p>
          </div>

          <div class="text-center">
            <div class="w-12 h-12 bg-red-600 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">2</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Create Your Profile</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Set up your account and introduce yourself to the community</p>
          </div>

          <div class="text-center">
            <div class="w-12 h-12 bg-red-600 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">3</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Dive In</h3>
            <p class="text-gray-700 leading-relaxed text-sm">Start connecting, contributing, and growing with your new tribe</p>
          </div>

        </div>
        <div class="text-center">
          <a
            href="https://spiritmedianetwork.mn.co"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors"
          >
            Join the Spirit Media Network &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="bg-navy-950 text-white py-20 px-4 text-center">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold font-serif mb-6">You Were Never Meant to Run Alone</h2>
        <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-2xl mx-auto">
          The Spirit Media Network exists to give Kingdom voices the community, encouragement, and resources they need to finish strong.
        </p>
        <a
          href="https://spiritmedianetwork.mn.co"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors"
        >
          Join Us Today
        </a>
      </div>
    </section>

  </main>
</Layout>
