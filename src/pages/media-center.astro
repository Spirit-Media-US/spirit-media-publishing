---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Media Center — Spirit Media"
	description="The latest news, updates, and happenings from Spirit Media."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-white px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-4">Media Center</p>
						<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight text-gray-900">The Latest<br /><span class="text-red-600">News &amp; Updates</span></h1>
						<p class="mt-6 text-lg leading-8 text-gray-600 max-w-xl">The latest news, updates, and happenings from Spirit Media.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-red-800 aspect-square"></div>
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-gray-900 aspect-square"></div>
						<div class="rounded-2xl bg-red-700 aspect-square"></div>
						<div class="rounded-2xl bg-gray-800 aspect-square"></div>
						<div class="rounded-2xl bg-red-600 aspect-square"></div>
						<div class="rounded-2xl bg-gray-900 aspect-square"></div>
						<div class="rounded-2xl bg-red-800 aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- MEDIA -->
		<section class="bg-gray-50 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3" data-animate="fade-up">Watch</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900 sm:text-4xl" data-animate="fade-up" data-delay="1">Spirit Media on YouTube</h2>
				</div>
				<div class="max-w-3xl mx-auto" data-animate="fade-up" data-delay="2">
					<div class="aspect-video rounded-2xl overflow-hidden bg-gray-900">
						<iframe
							class="w-full h-full"
							src="https://www.youtube.com/embed/?listType=user_uploads&list=UCQh2m97udW1osliFysbWsOA"
							title="Spirit Media YouTube Channel"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="text-center mt-6" data-animate="fade-up" data-delay="3">
						<a href="https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA" target="_blank" rel="noopener noreferrer" class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors text-sm">Visit Our YouTube Channel →</a>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red-600 px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Have a media inquiry?</h2>
				<p class="text-red-100 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">We'd love to hear from you. Reach out to discuss press releases, interviews, or media partnerships.</p>
				<a href="/contact" class="inline-block bg-white text-red-600 font-semibold px-8 py-3.5 rounded-md hover:bg-red-50 transition-colors" data-animate="fade-up" data-delay="2">Contact Us</a>
			</div>
		</section>

	</main>
</Layout>
