---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

const MONTHS = ['Jan.','Feb.','Mar.','Apr.','May','June','July','Aug.','Sept.','Oct.','Nov.','Dec.'];

const rawPressReleases = await sanityClient.fetch(`
  *[_type == "pressRelease"] | order(displayOrder asc, publishDate desc) {
    title, excerpt, publishDate, source, externalUrl,
    "coverImage": coverImage.asset->url
  }
`);

const rawVideos = await sanityClient.fetch(`
  *[_type == "mediaVideo"] | order(displayOrder asc) {
    youtubeId, thumbnailQuality, title
  }
`);

const FALLBACK_PRESS = [
  { title: "Generosity Campaign Launched To Share a Gift of Courage with 400,000 Families Fighting Cancer", excerpt: "SpiritMedia.US joins with John Vallely, Paul Weissenstein, Pediatric Cancer Research Foundation, and strategic partners to launch a nationwide generosity campaign for 400,000 families fighting cancer.", publishDate: "Dec. 2, 2024", source: "PRNewswire", externalUrl: "https://www.prnewswire.com/news-releases/generosity-campaign-launched-to-share-a-gift-of-courage-with-400-000-families-fighting-cancer-302319839.html", coverImage: "https://cdn.sanity.io/images/pmowd8uo/production/7a58d8d617622320266ae3d60c7c8e7398a32f39-480x360?w=640&h=480&fit=crop&auto=format.jpg" },
  { title: "UCLA's Coach Cori Close Applauds The Pyramid Principle by John Vallely", excerpt: "SpiritMedia.US celebrates the release of The Pyramid Principle — a heart-gripping story of hope for anyone fighting cancer and facing hard places in life.", publishDate: "Nov. 13, 2024", source: "PRNewswire", externalUrl: "https://www.prnewswire.com/news-releases/coach-cori-close-applauds-the-pyramid-principle-by-john-vallely-302304309.html", coverImage: "https://cdn.sanity.io/images/pmowd8uo/production/6d623b9cbbaa21b7f83766ddde9ffff3851a6c8b-480x360?w=640&h=480&fit=crop&auto=format.jpg" },
  { title: "SpiritMedia.US to Publish The Pyramid Principle by UCLA Superstar and NBA Pro John Vallely", excerpt: "SpiritMedia.US secures exclusive rights to publish The Pyramid Principle by Hall of Famer John Vallely — anticipated to be a New York Times Bestseller.", publishDate: "Aug. 15, 2024", source: "PRNewswire", externalUrl: "https://www.prnewswire.com/news-releases/spiritmediaus-to-publish-the-pyramid-principle-by-ucla-superstar-and-nba-pro-john-vallely-302223398.html", coverImage: "https://cdn.sanity.io/images/pmowd8uo/production/14b30df3d61822117b1df4e38e6f89d9c4e7018b-480x360?w=640&h=480&fit=crop&auto=format.jpg" },
  { title: "Spirit Media Shakes up the Publishing Industry with Unique, Expedited Process", excerpt: "Spirit Media completes publishing in every format within five months, with paperback editions finalizing in as little as 14 days.", publishDate: "June 18, 2024", source: "PRNewswire", externalUrl: "https://www.prnewswire.com/news-releases/spirit-media-shakes-up-the-publishing-industry-with-unique-expedited-process-302175618.html", coverImage: "https://cdn.sanity.io/images/pmowd8uo/production/a5d7fb6949a3bbdf07414bf48506975ca0d843e2-480x360?w=640&h=480&fit=crop&auto=format.jpg" },
  { title: "Spirit Media Poised for Rapid Growth, Robust Profitability in 2024", excerpt: "Spirit Media is poised for rapid growth thanks to international business dealings and new funding secured through the U.S. Small Business Administration.", publishDate: "Feb. 1, 2024", source: "PRNewswire", externalUrl: "https://www.prnewswire.com/news-releases/spirit-media-poised-for-rapid-growth-robust-profitability-in-2024-302050871.html", coverImage: "https://cdn.sanity.io/images/pmowd8uo/production/bfa828bf54b48bcd7549ad49b9fdad6be4b1b27f-480x360?w=640&h=480&fit=crop&auto=format.jpg" },
];

const FALLBACK_VIDEOS = [
  { youtubeId: "e7od2t3u2wI", thumbnailQuality: "maxresdefault", title: "Turn Your God-Given Vision into Global Impact" },
  { youtubeId: "tCrq_CJu1oQ", thumbnailQuality: "maxresdefault", title: "How Spirit Media Fast-Tracks Publishing with Purpose" },
  { youtubeId: "RRpWqlfQ7zQ", thumbnailQuality: "maxresdefault", title: "Spirit Media Thanks YOU: Building Success Through Stories" },
  { youtubeId: "DOSzIf-Ih90", thumbnailQuality: "maxresdefault", title: "Struggling to Launch Your Book? Spirit Media Does It All" },
  { youtubeId: "h2ph9i4Dv2M", thumbnailQuality: "maxresdefault", title: "How Spirit Media Helps Authors Dominate 195 Nations" },
  { youtubeId: "rabRf0qWZxE", thumbnailQuality: "maxresdefault", title: "Is Your Story God-Sized? Let us Share It with the World" },
  { youtubeId: "dvu1MKeFUc4", thumbnailQuality: "sddefault", title: "The Pyramid Principle — Coming Soon" },
  { youtubeId: "W92hLbOnl8k", thumbnailQuality: "maxresdefault", title: "Spirit Media's Purpose for Global Impact" },
  { youtubeId: "3v77UY5Xnzk", thumbnailQuality: "maxresdefault", title: "Why Spirit Media — Kevin White, CEO" },
];

function formatPressDate(d) {
  if (!d) return '';
  if (typeof d === 'string' && d.includes('.')) return d; // already formatted fallback
  const dt = new Date(d + 'T00:00:00');
  return `${MONTHS[dt.getMonth()]} ${dt.getDate()}, ${dt.getFullYear()}`;
}

const pressReleases = rawPressReleases.length > 0
  ? rawPressReleases.map(p => ({ ...p, publishDate: formatPressDate(p.publishDate) }))
  : FALLBACK_PRESS;
const mediaVideos = rawVideos.length > 0 ? rawVideos : FALLBACK_VIDEOS;
---

<Layout
	title="Media Center — Spirit Media Publishing in the News"
	description="Spirit Media Publishing press releases, YouTube videos, and media coverage. See how we're helping Christian authors publish, market, and reach the nations."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/f67376ca3cbad336ac9ed54977f72d3f9917397b-1200x630?w=1200&h=630&fit=crop&auto=format.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Spirit Media Publishing news, Christian publishing press releases, Spirit Media YouTube, Christian publishing media coverage, Spirit Media in the news, PRNewswire Christian publishing, Kingdom Messenger news" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			"name": "Media Center — Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com/media-center",
			"description": "Spirit Media Publishing press releases, YouTube videos, and media coverage.",
			"publisher": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" }
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-10 lg:py-14 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Media Center</p>
						<h1 class="type-hero text-ink-soft">Spirit Media<br /><span class="text-red">In the News</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">Press releases, media coverage, and video resources from Spirit Media Publishing — a leading voice in Christian publishing and Kingdom impact.</p>
					</div>
					<div class="hidden lg:flex flex-col gap-3 items-end" data-animate="zoom-in" aria-hidden="true">
						<p class="text-xs font-bold text-stone-400 uppercase tracking-widest text-right mb-1">As seen on</p>
						<div class="grid grid-cols-3 gap-3 w-full">
						<!-- Fox News -->
						<a href="https://foxnews.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#003366;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/94e15e6e73e18a7a3f7fc4b49481465cf2b7d596-152x152?w=152&h=152&fit=max&auto=format" alt="Fox News" class="w-24 h-24 object-contain" />
						</a>
						<!-- CNN -->
						<a href="https://cnn.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#cc0000;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/d09d53e60e03aaff3edf87935bcf49f45adaa979-76x76?w=76&h=76&fit=max&auto=format" alt="CNN" class="w-24 h-24 object-contain" />
						</a>
						<!-- NBC News -->
						<a href="https://nbcnews.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#1a1a1a;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/0f5296eb7ef370e0a2939f7a23ca27bc8f1964c9-192x192?w=192&h=192&fit=max&auto=format" alt="NBC News" class="w-24 h-24 object-contain" />
						</a>
						<!-- ABC News -->
						<a href="https://abcnews.go.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#00477b;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/f315c3ae575987d2e87926f681086095151683c4-48x48?w=48&h=48&fit=max&auto=format" alt="ABC News" class="w-24 h-24 object-contain" />
						</a>
						<!-- AP News -->
						<a href="https://apnews.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#cc0000;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/d3ddb9bbce4ce942d680fb81dfccf299b00572fa-180x180?w=180&h=180&fit=max&auto=format" alt="AP News" class="w-24 h-24 object-contain bg-white rounded-full p-2" />
						</a>
						<!-- CBS News -->
						<a href="https://cbsnews.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#183e7e;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/021bd89908c364f545b31fa303ad53f903945f38-192x192?w=192&h=192&fit=max&auto=format" alt="CBS News" class="w-24 h-24 object-contain" />
						</a>
						<!-- WSJ -->
						<a href="https://wsj.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#1a1a1a;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/bfae28404fe337f53b4c70e59c6c10cbf4664649-180x180?w=180&h=180&fit=max&auto=format" alt="Wall Street Journal" class="w-24 h-24 object-contain" />
						</a>
						<!-- USA Today -->
						<a href="https://usatoday.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#009bff;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/4f624e64dfe46360d19e0a44897a8bafa8186f64-114x114?w=114&h=114&fit=max&auto=format" alt="USA Today" class="w-24 h-24 object-contain" />
						</a>
						<!-- NY Post -->
						<a href="https://nypost.com" target="_blank" rel="noopener noreferrer" class="rounded-2xl aspect-square flex flex-col items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background:#cc0000;">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/828764e60a24587f5fa61aa361d7cf8aed8968a8-192x192?w=192&h=192&fit=max&auto=format" alt="NY Post" class="w-24 h-24 object-contain" />
						</a>
					</div>
				</div>
				</div>
			</div>
		</section>

		<!-- PRESS RELEASES -->
		<section class="bg-white py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Press Releases</p>
					<h2 class="font-serif text-3xl font-bold text-ink-soft sm:text-4xl" data-animate="fade-up" data-delay="1">In the News</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

				{pressReleases.map((pr, i) => (
					<article class="bg-stone-50 rounded-2xl border border-stone-200 overflow-hidden flex flex-col" data-animate="fade-up" data-delay={String(i % 3)}>
						<div class="h-48 overflow-hidden">
							<img src={pr.coverImage} alt={pr.title} loading="lazy" class="w-full h-full object-cover" />
						</div>
						<div class="p-7 flex flex-col flex-1">
							<p class="text-xs font-semibold text-stone-400 uppercase tracking-wide mb-3">{pr.publishDate} · {pr.source}</p>
							<h3 class="font-serif text-lg font-bold text-ink-soft mb-3 leading-snug">{pr.title}</h3>
							<p class="type-body-sm text-stone-600 leading-relaxed mb-5 flex-1">{pr.excerpt}</p>
							<a href={pr.externalUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red hover:text-red-deep transition-colors mt-auto">Read Press Release →</a>
						</div>
					</article>
				))}

				</div>
			</div>
		</section>

		<!-- MEDIA INQUIRY STRIP -->
		<section class="bg-stone-100 px-6 py-12 lg:px-8 border-t border-stone-200">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
				<div>
					<p class="font-serif text-xl font-bold text-ink-soft mb-1">Have a press or media inquiry?</p>
					<p class="type-body-sm text-stone-600">For interviews, partnerships, or press releases — we'd love to connect.</p>
				</div>
				<a href="/contact" class="inline-block bg-red text-white font-semibold px-8 py-3.5 rounded-md hover:bg-red-deep transition-colors text-sm whitespace-nowrap">Request a Free Consult →</a>
			</div>
		</section>

		<!-- MEDIA -->
		<section class="bg-stone-600 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Watch</p>
					<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl" data-animate="fade-up" data-delay="1">Spirit Media on YouTube</h2>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10" data-animate="fade-up" data-delay="2">
					{mediaVideos.map(({ youtubeId, thumbnailQuality, title }) => (

						<a href={`https://www.youtube.com/watch?v=${youtubeId}`} target="_blank" rel="noopener noreferrer" class="group block rounded-2xl overflow-hidden bg-white border border-stone-200 shadow-sm hover:shadow-md transition-shadow">
							<div class="relative aspect-video">
								<img
									src={`https://i.ytimg.com/vi/${youtubeId}/${thumbnailQuality}.jpg`}
									alt={title}
									loading="lazy"
									class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity"
								/>
								<div class="absolute inset-0 flex items-center justify-center">
									<div class="w-14 h-14 rounded-full bg-red flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
										<svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
									</div>
								</div>
							</div>
							<div class="p-4">
								<p class="text-sm font-semibold text-white leading-snug line-clamp-2">{title}</p>
							</div>
						</a>
					))}
				</div>
				<div class="text-center" data-animate="fade-up" data-delay="3">
					<a href="https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA" target="_blank" rel="noopener noreferrer" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Visit Our YouTube Channel →</a>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Ready to Get Your Message to the Nations?</h2>
				<p class="text-stone-200 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">Spirit Media Publishing helps Kingdom Messengers publish, market, and reach readers across 195 nations. Let's talk about your book.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Call →</a>
			</div>
		</section>

	</main>
</Layout>
