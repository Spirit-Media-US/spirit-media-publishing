---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Media Center — Spirit Media"
	description="The latest news, updates, and happenings from Spirit Media Publishing."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Media Center</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					The Latest News, Updates, and Happenings
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed">
					Stay current with what Spirit Media and our authors are doing in the world.
				</p>
			</div>
		</section>

		<!-- WATCH ON YOUTUBE -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3">Watch</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900">
						Spirit Media on YouTube
					</h2>
				</div>
				<div class="bg-gray-900 rounded-2xl overflow-hidden shadow-xl">
					<div class="aspect-video flex items-center justify-center">
						<a
							href="https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA"
							target="_blank"
							rel="noopener noreferrer"
							class="group flex flex-col items-center gap-4"
							aria-label="Watch Spirit Media on YouTube"
						>
							<span class="flex h-20 w-20 items-center justify-center rounded-full bg-red-600 shadow-lg transition-transform group-hover:scale-110">
								<svg class="h-8 w-8 translate-x-0.5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M8 5v14l11-7z"/>
								</svg>
							</span>
							<span class="text-sm font-medium text-gray-400">Watch on YouTube</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- PRESS & MEDIA -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">
					Media Resources
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<div class="bg-white rounded-xl p-6 text-center">
						<div class="text-4xl mb-4">📰</div>
						<h3 class="font-semibold text-gray-900 mb-2">Press Releases</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Distributed domestically and internationally through PR Newswire.
						</p>
					</div>
					<div class="bg-white rounded-xl p-6 text-center">
						<div class="text-4xl mb-4">🎙️</div>
						<h3 class="font-semibold text-gray-900 mb-2">Podcast</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Weekly episodes celebrating Kingdom authors and their books.
						</p>
					</div>
					<div class="bg-white rounded-xl p-6 text-center">
						<div class="text-4xl mb-4">📸</div>
						<h3 class="font-semibold text-gray-900 mb-2">Media Kit</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							For press inquiries, contact us at
							<a href="mailto:hello@spiritmedia.us" class="text-red-600 hover:underline">hello@spiritmedia.us</a>
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Want to Be Featured?</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Publish your book with Spirit Media and get featured in our media catalog, podcast,
					and email marketing.
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Request a Call
				</a>
			</div>
		</section>

	</main>
</Layout>
