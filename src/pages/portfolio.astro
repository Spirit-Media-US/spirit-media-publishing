---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Portfolio — Spirit Media Publishing"
	description="Discover how Spirit Media Publishing has helped authors grow. Client testimonials and success stories."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Portfolio</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Discover How We've Helped Others Grow
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed">
					Step into a gallery of growth and achievement, where we showcase how our expertise
					has nurtured success for our clients. Each project is a testament to our dedication
					and the transformative power of collaboration.
				</p>
			</div>
		</section>

		<!-- CATEGORIES -->
		<section class="bg-white py-12 px-4">
			<div class="max-w-3xl mx-auto">
				<div class="flex flex-wrap gap-3 justify-center">
					{
						['Publishing', 'Marketing', 'Branding'].map((cat) => (
							<span class="inline-block bg-red-50 text-red-600 font-semibold text-sm px-5 py-2 rounded-full border border-red-100">
								{cat}
							</span>
						))
					}
				</div>
			</div>
		</section>

		<!-- WHAT OUR CLIENTS SAY -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3">Testimonials</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900">What Our Clients Say</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">

					<!-- Video 1 -->
					<div class="bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-gray-100">
						<div class="aspect-video bg-gray-900 relative flex items-center justify-center">
							<a
								href="https://youtu.be/mKj2akahoQs"
								target="_blank"
								rel="noopener noreferrer"
								class="group flex flex-col items-center gap-3"
								aria-label="Watch client testimonial"
							>
								<span class="flex h-16 w-16 items-center justify-center rounded-full bg-red-600 shadow-lg transition-transform group-hover:scale-110">
									<svg class="h-6 w-6 translate-x-0.5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
								<span class="text-sm text-gray-400">Watch Testimonial</span>
							</a>
						</div>
					</div>

					<!-- Video 2 -->
					<div class="bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-gray-100">
						<div class="aspect-video bg-gray-900 relative flex items-center justify-center">
							<a
								href="https://youtu.be/I-smnc5eVpg"
								target="_blank"
								rel="noopener noreferrer"
								class="group flex flex-col items-center gap-3"
								aria-label="Watch client testimonial"
							>
								<span class="flex h-16 w-16 items-center justify-center rounded-full bg-red-600 shadow-lg transition-transform group-hover:scale-110">
									<svg class="h-6 w-6 translate-x-0.5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
								<span class="text-sm text-gray-400">Watch Testimonial</span>
							</a>
						</div>
					</div>

					<!-- Video 3 -->
					<div class="bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-gray-100">
						<div class="aspect-video bg-gray-900 relative flex items-center justify-center">
							<a
								href="https://youtu.be/fDQ47Jk0TWs"
								target="_blank"
								rel="noopener noreferrer"
								class="group flex flex-col items-center gap-3"
								aria-label="Watch client testimonial"
							>
								<span class="flex h-16 w-16 items-center justify-center rounded-full bg-red-600 shadow-lg transition-transform group-hover:scale-110">
									<svg class="h-6 w-6 translate-x-0.5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
								<span class="text-sm text-gray-400">Watch Testimonial</span>
							</a>
						</div>
					</div>

					<!-- Video 4 -->
					<div class="bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-gray-100">
						<div class="aspect-video bg-gray-900 relative flex items-center justify-center">
							<a
								href="https://youtu.be/PrvL2EGGRGU"
								target="_blank"
								rel="noopener noreferrer"
								class="group flex flex-col items-center gap-3"
								aria-label="Watch client testimonial"
							>
								<span class="flex h-16 w-16 items-center justify-center rounded-full bg-red-600 shadow-lg transition-transform group-hover:scale-110">
									<svg class="h-6 w-6 translate-x-0.5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
								<span class="text-sm text-gray-400">Watch Testimonial</span>
							</a>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- GOT QUESTIONS -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Got Questions?</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					We're looking forward to hearing from you!
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Request a Call
				</a>
			</div>
		</section>

	</main>
</Layout>
