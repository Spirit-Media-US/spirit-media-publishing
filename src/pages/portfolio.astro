---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Portfolio — 300+ Christian Books Published by Spirit Media"
	description="Spirit Media Publishing has helped 300+ Christian authors publish, brand, and market their books across 195 nations. Explore our publishing, branding, and marketing portfolio."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-10 lg:py-16 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Portfolio</p>
						<h1 class="type-hero text-ink-soft">Discover How We've<br /><span class="text-red">Helped Others Grow</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">Over 300 Kingdom authors published, branded, and launched — reaching readers across 195 nations. This is what it looks like when calling meets craft.</p>
					</div>
					<div class="hidden lg:flex items-center justify-center" data-animate="zoom-in">
						<img src="/book-collage5.png" alt="Spirit Media Publishing book portfolio" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- SERVICES SHOWCASE -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Our Work</p>
					<h2 class="font-serif text-3xl font-bold text-ink-soft sm:text-4xl" data-animate="fade-up" data-delay="1">What We Do</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-stone-50 rounded-2xl border border-stone-200 overflow-hidden text-center" data-animate="fade-up" data-delay="1">
						<img src="/publish-my-book.jpg" alt="Christian book publishing — Spirit Media Publishing" class="w-full h-48 object-cover" />
						<div class="p-8">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
						</div>
						<h3 class="font-serif text-xl font-bold text-ink-soft mb-2">Publishing</h3>
						<p class="type-body-sm text-stone-600">300+ titles published across paperback, hardback, digital, and audiobook formats.</p>
						</div>
					</div>
					<div class="bg-stone-50 rounded-2xl border border-stone-200 overflow-hidden text-center" data-animate="fade-up" data-delay="2">
						<img src="/market-my-book.jpg" alt="Christian book marketing and social media strategy" class="w-full h-48 object-cover" />
						<div class="p-8">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
						</div>
						<h3 class="font-serif text-xl font-bold text-ink-soft mb-2">Marketing</h3>
						<p class="type-body-sm text-stone-600">Websites, social media, video production, podcasts, and comprehensive marketing strategies.</p>
						</div>
					</div>
					<div class="bg-stone-50 rounded-2xl border border-stone-200 overflow-hidden text-center" data-animate="fade-up" data-delay="3">
						<img src="/write-my-book.jpg" alt="Christian book cover design and author branding" class="w-full h-48 object-cover object-top" />
						<div class="p-8">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" /></svg>
						</div>
						<h3 class="font-serif text-xl font-bold text-ink-soft mb-2">Branding</h3>
						<p class="type-body-sm text-stone-600">Logo design, brand identity, and visual systems that communicate your Kingdom message.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CLIENT TESTIMONIALS -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Testimonials</p>
					<h2 class="font-serif text-3xl font-bold text-ink-soft sm:text-4xl" data-animate="fade-up" data-delay="1">What Our Clients Say</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
					{[
						{ url: 'https://www.youtube.com/embed/mKj2akahoQs', title: 'Client Testimonial 1' },
						{ url: 'https://www.youtube.com/embed/I-smnc5eVpg', title: 'Client Testimonial 2' },
						{ url: 'https://www.youtube.com/embed/fDQ47Jk0TWs', title: 'Client Testimonial 3' },
						{ url: 'https://www.youtube.com/embed/PrvL2EGGRGU', title: 'Client Testimonial 4' },
					].map(({ url, title }, i) => (
						<div class="aspect-video rounded-2xl overflow-hidden bg-ink-soft" data-animate="fade-up" data-delay={String((i % 4) + 1)}>
							<iframe class="w-full h-full" src={url} title={title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- BRANDING PORTFOLIO -->
		<section class="bg-white py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Branding</p>
					<h2 class="font-serif text-3xl font-bold text-ink-soft sm:text-4xl" data-animate="fade-up" data-delay="1">Brand Design Portfolio</h2>
					<p class="mt-4 type-body-lg text-stone-600 max-w-2xl" data-animate="fade-up" data-delay="2">Websites, social media graphics, and digital branding — crafted to build authority and reach readers where they are.</p>
				</div>

				<!-- Websites -->
				<div class="mb-14">
					<h3 class="font-serif text-xl font-bold text-ink-soft mb-6" data-animate="fade-up">Websites</h3>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
						{Array.from({length: 9}, (_, i) => (
							<div class="rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" data-animate="fade-up" data-delay={String(i % 3)}>
								<img src={`/branding-websites-${i+1}.webp`} alt={`Website design ${i+1}`} loading="lazy" class="w-full h-full object-cover" />
							</div>
						))}
					</div>
				</div>

				<!-- Facebook -->
				<div class="mb-14">
					<h3 class="font-serif text-xl font-bold text-ink-soft mb-6" data-animate="fade-up">Facebook Graphics</h3>
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
						{Array.from({length: 10}, (_, i) => (
							<div class="rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" data-animate="fade-up" data-delay={String(i % 5)}>
								<img src={`/branding-facebook-${i+1}.webp`} alt={`Facebook graphic ${i+1}`} loading="lazy" class="w-full h-full object-cover aspect-square" />
							</div>
						))}
					</div>
				</div>

				<!-- Twitter / X -->
				<div class="pb-4">
					<h3 class="font-serif text-xl font-bold text-ink-soft mb-6" data-animate="fade-up">X / Twitter Graphics</h3>
					<div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-4">
						{Array.from({length: 9}, (_, i) => (
							<div class="rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" data-animate="fade-up" data-delay={String(i % 5)}>
								<img src={`/branding-twitter-${i+1}.webp`} alt={`X / Twitter graphic ${i+1}`} loading="lazy" class="w-full h-full object-cover aspect-[248/500]" />
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Ready to Write Your Next Chapter?</h2>
				<p class="text-stone-200 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">Join 300+ Kingdom authors who've trusted Spirit Media to publish, brand, and market their message to the nations. Let's talk about your book.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Free Consultation →</a>
			</div>
		</section>

	</main>
</Layout>
