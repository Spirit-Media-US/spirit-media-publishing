---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Express Books — Spirit Media Publishing"
	description="Publish your book in 30 days with Express Books — Spirit Media's fast-track publishing format for speakers, ministry leaders, and first-time authors."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Fast-Track Publishing</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Express Books — Your Message in 30 Days
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed mb-8">
					For the conference speaker who needs a book on the table. For the pastor with a message
					the congregation needs in hand. For the first-time author who can't wait.
				</p>
				<a href="/contact" class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
					Get Started
				</a>
			</div>
		</section>

		<!-- WHAT IS IT -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">What Is Express Books?</h2>
				<p class="text-lg text-gray-700 leading-relaxed mb-6">
					Express Books is Spirit Media Publishing's fast-track publishing format. It's designed
					for authors with a clear, focused message who need a professionally published book
					ready in 30 days or less.
				</p>
				<p class="text-lg text-gray-700 leading-relaxed">
					Unlike a full publishing engagement, Express Books focuses on speed — streamlined editing,
					efficient design, and rapid distribution — without sacrificing quality.
				</p>
			</div>
		</section>

		<!-- WHO IT'S FOR -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">Perfect For...</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">🎤</div>
						<h3 class="font-semibold text-gray-900 mb-2">Conference Speakers</h3>
						<p class="text-sm text-gray-600 leading-relaxed">You have an event in 30 days and need a book to sell at the back of the room</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">⛪</div>
						<h3 class="font-semibold text-gray-900 mb-2">Pastors &amp; Ministry Leaders</h3>
						<p class="text-sm text-gray-600 leading-relaxed">You want your sermon series in the hands of your congregation as a takeaway resource</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">✍️</div>
						<h3 class="font-semibold text-gray-900 mb-2">First-Time Authors</h3>
						<p class="text-sm text-gray-600 leading-relaxed">You want to test your message before investing in a full publishing package</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">💡</div>
						<h3 class="font-semibold text-gray-900 mb-2">Thought Leaders</h3>
						<p class="text-sm text-gray-600 leading-relaxed">You're speaking at an event and want a credibility-building resource to offer attendees</p>
					</div>
				</div>
			</div>
		</section>

		<!-- THE PROCESS -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">The Express Books Process</h2>
				<ol class="space-y-8">
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Days</span><span>1–3</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Submit Your Manuscript</h3>
							<p class="text-gray-600 leading-relaxed">Share your completed draft. Minimum 10,000 words recommended.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Days</span><span>4–10</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Express Edit</h3>
							<p class="text-gray-600 leading-relaxed">Our editors do a focused pass for clarity, flow, and errors.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Days</span><span>5–12</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Cover Design</h3>
							<p class="text-gray-600 leading-relaxed">A clean, professional cover designed to represent your message.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Days</span><span>11–18</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Interior Layout</h3>
							<p class="text-gray-600 leading-relaxed">Formatted for both digital and print-on-demand.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Days</span><span>19–25</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Distribution Setup</h3>
							<p class="text-gray-600 leading-relaxed">Published on Amazon KDP and major eBook platforms.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-12 h-12 rounded-full bg-green-600 text-white flex flex-col items-center justify-center text-xs font-bold leading-tight text-center">
							<span>Day</span><span>30</span>
						</div>
						<div class="pt-2">
							<h3 class="font-semibold text-gray-900 mb-1">Your Book Is Live</h3>
							<p class="text-gray-600 leading-relaxed">You're a published author — ready for your event.</p>
						</div>
					</li>
				</ol>
			</div>
		</section>

		<!-- WHAT'S INCLUDED -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-8 text-center">What's Included</h2>
				<ul class="space-y-3">
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> Manuscript review and express editing
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> Professional cover design
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> Interior formatting (print + digital)
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> Amazon KDP setup
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> eBook distribution to 40+ retailers
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> ISBN assignment
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> Author page setup
					</li>
					<li class="flex items-center gap-3 text-gray-700">
						<span class="text-red-600 font-bold">✓</span> 5 complimentary author copies (print)
					</li>
				</ul>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Ready to Publish in 30 Days?</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Contact us today and let's get your Express Book project started.
				</p>
				<a href="/contact" class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors">
					Request Express Books
				</a>
			</div>
		</section>

	</main>
</Layout>
