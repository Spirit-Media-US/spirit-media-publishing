---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Spirit Media Publishing"
  description="Spirit Media Publishing — sharing faith, culture, and compelling stories."
>
  <main id="main-content">
    <!-- Hero -->
    <section class="bg-white px-6 py-24 sm:py-32 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-base font-semibold leading-7 text-indigo-600">Spirit Media Publishing</p>
        <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          Stories that inspire.
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          We publish faith-driven books, media, and resources that encourage, equip, and empower
          readers to live with purpose.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a
            href="#"
            class="rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
          >
            Browse titles
          </a>
          <a href="/about" class="text-sm font-semibold leading-6 text-gray-900">
            Our mission <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Placeholder feature strip -->
    <section class="border-t border-gray-100 bg-gray-50 px-6 py-16 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-medium uppercase tracking-widest text-gray-400">Coming soon</p>
        <h2 class="mt-4 text-2xl font-bold text-gray-800">More content on the way.</h2>
        <p class="mt-3 text-gray-500">
          Check back soon for our full catalogue of titles and resources.
        </p>
      </div>
    </section>
  </main>
</Layout>
