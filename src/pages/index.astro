---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Spirit Media Publishing — Bringing Life to People who Feel Dead"
  description="Empowering Believers to Publish Testimonies of God's Power to the Nations. eBook Publishing starting at $99."
>
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden bg-navy-950">
      <!-- Gold glow accent -->
      <div
        class="pointer-events-none absolute -top-32 right-0 h-[500px] w-[500px] rounded-full bg-gold-500 opacity-5 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="relative mx-auto max-w-7xl px-6 py-20 sm:py-28 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

          <!-- Left: copy -->
          <div>
            <p class="font-serif text-sm font-semibold uppercase tracking-[0.2em] text-gold-400">
              Spirit Media Publishing
            </p>
            <h1 class="mt-4 font-serif text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
              Bringing Life to<br />
              <span class="text-gold-400">People who Feel Dead</span>
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-8 text-navy-200">
              Empowering Believers to Publish Testimonies of God's Power to the Nations.
            </p>
            <div class="mt-10 flex flex-wrap gap-4">
              <a
                href="/about"
                class="rounded-md bg-white px-6 py-3 text-sm font-semibold text-navy-900 shadow-sm transition-colors hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
              >
                We Are Spirit Media
              </a>
              <a
                href="/contact"
                class="rounded-md bg-gold-500 px-6 py-3 text-sm font-semibold text-navy-950 shadow-sm transition-colors hover:bg-gold-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500"
              >
                Request a Call
              </a>
            </div>
          </div>

          <!-- Right: book stack visual -->
          <div class="flex justify-center lg:justify-end">
            <div class="relative">
              <!-- Placeholder book stack — replace with actual image -->
              <div class="grid grid-cols-3 gap-3 sm:gap-4">
                {
                  Array.from({ length: 9 }).map((_, i) => (
                    <div
                      class:list={[
                        'aspect-[2/3] w-20 sm:w-24 rounded-sm shadow-2xl ring-1 ring-white/10',
                        [
                          'bg-gold-600', 'bg-navy-700', 'bg-gold-500',
                          'bg-navy-600', 'bg-gold-700', 'bg-navy-800',
                          'bg-gold-400', 'bg-navy-500', 'bg-gold-600',
                        ][i],
                      ]}
                    />
                  ))
                }
              </div>
              <div
                class="pointer-events-none absolute inset-0 rounded-xl bg-gradient-to-t from-navy-950/60 via-transparent to-transparent"
                aria-hidden="true"
              ></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         EBOOK PUBLISHING STARTING AT $99
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="border-b border-gray-100 bg-white px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-gold-500">Publishing</p>
            <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">
              eBook Publishing<br />
              <span class="text-gold-500">Starting at $99</span>
            </h2>
            <p class="mt-4 text-base leading-7 text-gray-600">
              With over 1 Billion users worldwide, eBooks are the fastest growing format in the
              publishing industry. Print books are a viable option for serious authors. Spirit Media
              offers publishing accessible for ALL authors.
            </p>
            <a
              href="/publishing"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-navy-800"
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Distribution platform logos -->
          <div class="rounded-2xl bg-gray-50 p-8">
            <p class="mb-6 text-center text-xs font-semibold uppercase tracking-widest text-gray-400">
              Distributed on all major platforms
            </p>
            <div class="grid grid-cols-3 gap-6 sm:grid-cols-6 lg:grid-cols-3 xl:grid-cols-6">
              {
                ['Amazon', 'Kindle', 'Apple Books', 'Kobo', 'Barnes & Noble', 'Google Play'].map(
                  (platform) => (
                    <div class="flex items-center justify-center rounded-lg bg-white px-3 py-4 shadow-sm ring-1 ring-gray-100">
                      <span class="text-center text-[10px] font-semibold leading-tight text-gray-500">
                        {platform}
                      </span>
                    </div>
                  ),
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         BUILDING FAITH
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-gray-50 px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 text-center">
          <h2 class="font-serif text-3xl font-bold text-navy-900 sm:text-4xl">
            Building <span class="text-gold-500">Faith</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">

          <!-- Card 1: 1 Million Christian Writers -->
          <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
            <div class="aspect-video bg-navy-900 flex items-center justify-center">
              <div class="text-center px-8">
                <p class="font-serif text-xs font-semibold uppercase tracking-widest text-gold-400">Training</p>
                <p class="mt-2 font-serif text-xl font-bold text-white leading-snug">
                  Certified Christian<br />Writers Training
                </p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-serif text-xl font-bold text-navy-900">1 Million Christian Writers!</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">
                We're on a mission to equip 1 Million Christian writers worldwide. Writers are needed
                in all 7 of the cultural mountains. Sign up now to be notified of our CERTIFIED
                CHRISTIAN WRITERS TRAINING event.
              </p>
              <span
                class="mt-4 inline-block rounded-md bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-500"
              >
                Coming Soon
              </span>
            </div>
          </div>

          <!-- Card 2: Celebrating Authors & Books -->
          <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
            <div class="aspect-video bg-gold-600 flex items-center justify-center">
              <div class="text-center px-8">
                <p class="font-serif text-xs font-semibold uppercase tracking-widest text-navy-900/70">Live Event</p>
                <p class="mt-2 font-serif text-xl font-bold text-navy-950 leading-snug">
                  Amplify Your Impact
                </p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-serif text-xl font-bold text-navy-900">Celebrating Authors &amp; Books!</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">
                Check out to view our LIVE podcast streamed every Tuesday at Spirit.US! Each week we
                celebrate today's Christian authors and books. We make you and the community with never-
                before-told stories!
              </p>
              <a
                href="/media-center"
                class="mt-4 inline-flex items-center gap-2 rounded-md bg-navy-900 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-navy-800"
              >
                Learn More <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         VIDEO — PUBLISHING GOD-SIZED STORIES
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-navy-950 px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-gold-400">Watch</p>
        <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Publishing God-sized Stories To The Nations
        </h2>
        <p class="mt-4 text-base text-navy-300">
          See how Spirit Media Publishing is helping authors carry their God-given message further
          than they ever imagined.
        </p>

        <!-- Video embed placeholder -->
        <div class="mt-10 overflow-hidden rounded-2xl shadow-2xl">
          <div class="relative aspect-video bg-navy-900 flex items-center justify-center">
            <!-- Replace src with actual YouTube embed URL -->
            <a
              href="https://www.youtube.com/@spiritmediaus"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col items-center gap-4"
              aria-label="Watch on YouTube"
            >
              <span class="flex h-20 w-20 items-center justify-center rounded-full bg-gold-500 shadow-lg transition-transform group-hover:scale-110">
                <svg class="h-8 w-8 translate-x-0.5 text-navy-950" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </span>
              <span class="text-sm font-medium text-navy-300">Watch on YouTube</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         IN THE NEWS
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-white px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

          <!-- Video / media thumbnail -->
          <div class="overflow-hidden rounded-2xl bg-navy-900 shadow-lg">
            <div class="relative aspect-video flex items-center justify-center">
              <div class="text-center p-8">
                <p class="font-serif text-sm text-gold-400 uppercase tracking-widest">Featured</p>
                <p class="mt-3 font-serif text-2xl font-bold text-white leading-snug">
                  The Pyramid Principle
                </p>
                <span class="mt-4 inline-flex h-14 w-14 items-center justify-center rounded-full bg-gold-500">
                  <svg class="h-6 w-6 translate-x-0.5 text-navy-950" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>

          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-gold-500">Media</p>
            <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">
              In the News
            </h2>
            <p class="mt-4 text-base leading-7 text-gray-600">
              ASCTA's Corin Clar's Corin Approach: The Pyramid Principle, by John
              Mallia. Stay current with what Spirit Media and our authors are doing in the world.
            </p>
            <a
              href="/media-center"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-navy-800"
            >
              Visit Our Media Center <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         ENLARGE YOUR IMPACT
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-navy-50 px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-gold-500">Our Mission</p>
            <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">
              Let Spirit Media Help<br />
              <span class="text-gold-600">Enlarge Your Impact</span>
            </h2>
            <p class="mt-4 text-base leading-7 text-gray-600">
              God created you for Impact. We've engineered everything to give you Publishing and
              Marketing success — so your story, your testimony, your message reaches the people who
              need it most.
            </p>
            <a
              href="/about"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-navy-800"
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </div>

          <!-- Brand icon -->
          <div class="flex justify-center">
            <div class="flex h-56 w-56 items-center justify-center rounded-full bg-navy-900 shadow-2xl ring-4 ring-gold-500/30">
              <div class="text-center">
                <svg class="mx-auto h-20 w-20 text-gold-400" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
                  <!-- Dove silhouette -->
                  <path d="M50 15c-8 0-20 8-24 18-3 7-2 15 2 20 1 2 3 4 5 5l-8 20h5l6-14c3 2 7 3 11 3 4 0 8-1 11-3l6 14h5l-8-20c2-1 4-3 5-5 4-5 5-13 2-20C64 23 58 15 50 15zm0 6c6 0 14 6 17 14 2 5 1 10-1 14l-4-3c-1-4-5-7-12-7s-11 3-12 7l-4 3c-2-4-3-9-1-14C36 27 44 21 50 21z"/>
                </svg>
                <p class="mt-2 font-serif text-sm font-bold text-white">SpiritMedia</p>
                <p class="text-xs text-gold-400">Publishing</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         SOLUTIONS / SERVICES
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-white px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:items-start">

          <!-- Book covers grid (portfolio preview) -->
          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-gold-500">Our Portfolio</p>
            <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">
              Providing Solutions<br />
              <span class="text-gold-500">You Need Right Now</span>
            </h2>
            <p class="mt-4 mb-8 text-base leading-7 text-gray-600">
              At Spirit Media, our passion is to amplify your message and increase your impact. Our
              comprehensive Publishing and Marketing services are here to serve you.
            </p>
            <a
              href="/publishing"
              class="inline-flex items-center gap-2 rounded-md bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-navy-800"
            >
              Learn More <span aria-hidden="true">→</span>
            </a>

            <!-- Book grid placeholder -->
            <div class="mt-10 grid grid-cols-3 gap-3">
              {
                Array.from({ length: 9 }).map((_, i) => (
                  <div
                    class:list={[
                      'aspect-[2/3] rounded shadow-md ring-1 ring-gray-200',
                      [
                        'bg-gradient-to-br from-navy-700 to-navy-900',
                        'bg-gradient-to-br from-gold-400 to-gold-600',
                        'bg-gradient-to-br from-navy-500 to-navy-700',
                        'bg-gradient-to-br from-gold-500 to-gold-700',
                        'bg-gradient-to-br from-navy-800 to-navy-950',
                        'bg-gradient-to-br from-gold-300 to-gold-500',
                        'bg-gradient-to-br from-navy-600 to-navy-800',
                        'bg-gradient-to-br from-gold-600 to-gold-800',
                        'bg-gradient-to-br from-navy-400 to-navy-600',
                      ][i],
                    ]}
                  />
                ))
              }
            </div>
          </div>

          <!-- 6 service icons -->
          <div>
            <p class="mb-8 text-sm font-semibold uppercase tracking-widest text-gold-500">Services</p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              {
                [
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />',
                    title: 'Write My Book',
                    body: 'Not sure where to start? We help you craft your message from idea to final manuscript.',
                    href: '/publishing',
                  },
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />',
                    title: 'Publish My Book',
                    body: 'Full eBook and print publishing with distribution across all major platforms worldwide.',
                    href: '/publishing',
                  },
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />',
                    title: "Publish My Children's Book",
                    body: "Bring your children's story to life with professional illustration and full-color printing.",
                    href: '/publishing',
                  },
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />',
                    title: 'Grow My Business',
                    body: 'Marketing strategy, brand development, and audience growth to scale your platform and revenue.',
                    href: '/marketing',
                  },
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />',
                    title: 'Grow My Church or NPO',
                    body: 'Specialized publishing and marketing solutions for churches, ministries, and non-profit organizations.',
                    href: '/marketing',
                  },
                  {
                    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />',
                    title: 'Publish My Broadcast',
                    body: 'Launch your podcast, YouTube channel, or video series with full production and distribution support.',
                    href: '/media-center',
                  },
                ].map(({ icon, title, body, href }) => (
                  <a
                    href={href}
                    class="group flex gap-4 rounded-xl border border-gray-100 bg-gray-50 p-5 transition-shadow hover:shadow-md"
                  >
                    <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-navy-100">
                      <svg
                        class="h-5 w-5 text-navy-700"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        aria-hidden="true"
                        set:html={icon}
                      />
                    </div>
                    <div>
                      <h3 class="font-semibold text-navy-900 group-hover:text-gold-600 transition-colors">
                        {title}
                      </h3>
                      <p class="mt-1 text-sm leading-5 text-gray-500">{body}</p>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════
         SPIRIT MEDIA CELEBRATES (TESTIMONIALS)
         ═══════════════════════════════════════════════════════════════════ -->
    <section class="bg-navy-950 px-6 py-20 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 text-center">
          <h2 class="font-serif text-3xl font-bold text-white sm:text-4xl">
            Spirit Media <span class="text-gold-400">Celebrates</span>
          </h2>
          <p class="mt-3 text-navy-300">Real authors. Real results. Real testimonies.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {
            [
              {
                quote:
                  'Jesse Earl at Little Lamby Group focused a CELEBRATED Amazons bestseller to charity at 4 years. WHAT?! So Jesse creates this amazing children\'s book. The story doesn\'t just captivate — it demonstrates young minds all the truth about who we\'re talking about during choosing.',
                name: 'Jesse Earl',
                role: 'Children\'s Book Author',
              },
              {
                quote:
                  'Years ago, while attending a REMARKABLE AGENT, John Fallen was in the darkest season of his life — asking God to restore this faith. His family believed him into returning back to loving life. "Work on Yourself" was born. It\'s now selling internationally. If you believe it possible, you believe God.',
                name: 'John Fallen',
                role: 'Author, Work on Yourself',
              },
              {
                quote:
                  '2 YEARS OF EXPLORING AND REACHING IMPACT. Desleyne published a book in about 2 hours! She wrote it while in HAITI. We\'ve NEVER SEEN AN EVER MORE TREMENDOUS APPLAUSE, and so we SHARED IT. IT\'S CHANGING LIVES in three places.',
                name: 'Desleyne',
                role: 'International Author',
              },
            ].map(({ quote, name, role }) => (
              <figure class="rounded-2xl bg-navy-900 p-8 ring-1 ring-navy-800">
                <blockquote class="text-sm leading-7 text-navy-200">
                  <p>"{quote}"</p>
                </blockquote>
                <figcaption class="mt-6 flex items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500/20 font-serif text-base font-bold text-gold-400">
                    {name[0]}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white">{name}</p>
                    <p class="text-xs text-navy-400">{role}</p>
                  </div>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

