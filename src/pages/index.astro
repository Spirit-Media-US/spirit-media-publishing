---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Spirit Media Publishing — Heart. Message. Movement."
	description="We develop Kingdom Messengers through soul care, publishing, and marketing — spreading Father's heart to all 195 nations."
>
	<main id="main-content">

		<!-- ═══ HERO ═══ -->
		<section class="bg-white px-6 py-24 sm:py-32 lg:px-8">
			<div class="mx-auto max-w-4xl text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-4">
					Welcome to Spirit Media!
				</p>
				<h1 class="font-serif text-4xl font-bold leading-tight tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
					Born from holy conviction.<br />
					<span class="text-red-600">Built for global impact.</span>
				</h1>
				<p class="mt-6 max-w-2xl mx-auto text-lg leading-8 text-gray-600">
					We refuse small vision. We reveal the Father's heart for His beloved children, for
					generations, and until the Good News bears fruit in every nation.
				</p>
				<p class="mt-4 max-w-2xl mx-auto text-base leading-7 text-gray-500">
					We develop Kingdom Messengers by empowering them from
					<strong class="text-gray-700">heart → message → movement.</strong>
				</p>
				<div class="mt-10 flex flex-wrap gap-4 justify-center">
					<a
						href="/about"
						class="rounded-md border-2 border-red-600 bg-white px-6 py-3 text-sm font-semibold text-red-600 shadow-sm transition-colors hover:bg-red-50"
					>
						We Are Spirit Media
					</a>
					<a
						href="https://spiritmedia.us/request-a-call/"
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
					>
						Request a Call
					</a>
				</div>
			</div>
		</section>

		<!-- ═══ SCRIPTURE SECTION ═══ -->
		<section class="bg-navy-950 px-6 py-16 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<blockquote>
					<p class="font-serif text-xl sm:text-2xl font-medium italic leading-relaxed text-white">
						"Publish Our Father's glorious deeds among the nations. Tell everyone about the amazing
						things He does."
					</p>
					<cite class="mt-4 block text-sm font-semibold tracking-widest text-red-400 not-italic">
						— Psalm 96:3 (FHB)
					</cite>
				</blockquote>
			</div>
		</section>

		<!-- ═══ MISSION STATEMENT ═══ -->
		<section class="bg-gray-50 px-6 py-16 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-4">Our Mission</p>
				<p class="font-serif text-2xl sm:text-3xl font-bold text-gray-900 leading-snug">
					Spirit Media is a Christian publishing and marketing family with a mission to reveal our
					Father's heart to all
					<span class="text-red-600">195 nations</span>
					worldwide.
				</p>
			</div>
		</section>

		<!-- ═══ EXCLUSIVE HOME OF (BRAND CARDS) ═══ -->
		<section class="bg-white px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3">
						Exclusive Home of
					</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900 sm:text-4xl">
						Our Brands &amp; Programs
					</h2>
				</div>

				<div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">

					<!-- FHB -->
					<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
						<div class="text-3xl mb-3">📖</div>
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-2">
							Father's Heart Bible™ (FHB)
						</p>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							An intimate translation revealing our Father's heart to a fatherless generation.
						</h3>
						<p class="text-sm text-gray-600 leading-relaxed mb-5">
							One message for every reader: "Come home. You belong to Me. You are My beloved
							child." Each gift of $100 places three Father's Heart Bibles into the hands of
							readers worldwide.
						</p>
						<a
							href="https://fathersheartbible.com"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-block bg-red-600 text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-red-700 transition-colors"
						>
							Visit FathersHeartBible.com →
						</a>
					</div>

					<!-- KMC -->
					<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
						<div class="text-3xl mb-3">🌍</div>
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-2">
							The Kingdom Messenger Collective
						</p>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							From God-given message to sustainable movement.
						</h3>
						<p class="text-sm text-gray-600 leading-relaxed mb-5">
							Our flagship development program that walks with Kingdom Messengers through a 3+
							year partnership — turning restoration into proclamation and message into movement.
						</p>
						<a
							href="/kingdom-messenger-collective"
							class="inline-block bg-red-600 text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-red-700 transition-colors"
						>
							Learn More →
						</a>
					</div>

					<!-- WOY -->
					<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
						<div class="text-3xl mb-3">🌿</div>
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-2">
							Work On Yourself
						</p>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							A soul care intensive for leaders whose outer success has outpaced their inner life.
						</h3>
						<p class="text-sm text-gray-600 leading-relaxed mb-5">
							A twelve-month protected season where leaders are accompanied rather than optimized,
							stewarded rather than evaluated. Because the inner life deserves the same
							intentionality as the outer one.
						</p>
						<a
							href="https://workonyourself.com"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-block bg-red-600 text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-red-700 transition-colors"
						>
							Visit WorkOnYourself.com →
						</a>
					</div>

					<!-- Express Books -->
					<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
						<div class="text-3xl mb-3">⚡</div>
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-2">
							EXPRESS BOOKS™
						</p>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							Fast reads. Lasting impact.
						</h3>
						<p class="text-sm text-gray-600 leading-relaxed mb-5">
							Our signature publishing format — intentionally compact books designed to be read in
							under an hour. No filler. No fluff. Affordably priced for easy sharing.
							Transformation that lasts a lifetime.
						</p>
						<a
							href="/express-books"
							class="inline-block bg-red-600 text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-red-700 transition-colors"
						>
							Learn More →
						</a>
					</div>

					<!-- Believer's Library -->
					<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm hover:shadow-md transition-shadow md:col-span-2 lg:col-span-1">
						<div class="text-3xl mb-3">📱</div>
						<p class="text-xs font-semibold uppercase tracking-widest text-red-600 mb-2">
							The Believer's Library
						</p>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							The world's largest cloud-based Christian library.
						</h3>
						<p class="text-sm text-gray-600 leading-relaxed mb-5">
							Our exclusive mobile app delivering PDF downloads of Christian books to 3.3 billion
							souls worldwide with limited access to Jesus. Coming soon.
						</p>
						<span class="inline-block bg-gray-100 text-gray-500 text-sm font-semibold px-5 py-2.5 rounded-md">
							Coming Soon
						</span>
					</div>

				</div>
			</div>
		</section>

		<!-- ═══ FREE MANUSCRIPT REVIEW ═══ -->
		<section class="bg-red-600 px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<div class="text-center mb-10">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-3">Free Offer</p>
					<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4">
						Free Manuscript Review
					</h2>
					<p class="text-red-100 text-lg leading-relaxed max-w-2xl mx-auto">
						Share your manuscript with us and our team of seasoned editors will provide a
						<strong class="text-white">FREE customized 20-point review ($250 value).</strong>
					</p>
				</div>

				<div class="bg-red-700/50 rounded-2xl p-6 mb-8">
					<p class="text-red-100 text-sm leading-relaxed text-center">
						Manuscript Overview · Biblical Accuracy · Target Audience Analysis · Genre &amp; Market
						Fit · Content Organization · Thematic Depth · Emotional Impact · Writing Style &amp;
						Voice · Grammar &amp; Mechanics · Clarity &amp; Readability · Research &amp; Credibility
						· Reader Engagement &amp; Pacing · Unique Selling Points · Final Editing Assessment ·
						Market Potential · Strengths · Areas for Improvement · Top Amazon Categories · Optimized
						KDP Keywords · Summary &amp; Recommendations
					</p>
				</div>

				<p class="text-center text-red-100 italic mb-8">
					This will affirm God's good work in and through you.
				</p>

				<div class="text-center">
					<a
						href="mailto:publisher@spiritmedia.us"
						class="inline-block bg-white text-red-600 font-semibold px-8 py-3.5 rounded-md hover:bg-red-50 transition-colors text-sm"
					>
						Email your Manuscript →
					</a>
				</div>
			</div>
		</section>

		<!-- ═══ SERVICES OVERVIEW ═══ -->
		<section class="bg-white px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3">
						What We Do
					</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900 sm:text-4xl">
						Publishing &amp; Marketing<br />
						<span class="text-red-600">for Kingdom Messengers</span>
					</h2>
				</div>

				<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{
						[
							{
								icon: '✍️',
								title: 'Write My Book',
								body: 'Meet with your writer one hour per week via Zoom. Your book is complete in as few as 90 days. Your story. Your words. Our hands.',
								href: '/publishing',
							},
							{
								icon: '📚',
								title: 'Publish My Book',
								body: 'Paperback, hardback, digital, and audiobook — with global distribution through Amazon, IngramSpark, libraries, and eBook stores worldwide.',
								href: '/publishing',
							},
							{
								icon: '🌐',
								title: 'Market My Book',
								body: 'Every book we publish receives our full base marketing. Because publishing without marketing is just printing.',
								href: '/marketing',
							},
							{
								icon: '🌍',
								title: 'Translate My Book',
								body: 'We translate into the top 20 spoken languages — reaching over 75% of the human race.',
								href: '/publishing',
							},
							{
								icon: '⚡',
								title: 'Express Book',
								body: 'Need a book in 30 days? Our signature compact format — intentionally designed for impact. No filler. No fluff.',
								href: '/express-books',
							},
							{
								icon: '🎨',
								title: "Publish My Children's Book",
								body: 'Fully illustrated children\'s books connecting your story with young readers everywhere.',
								href: '/publishing',
							},
						].map(({ icon, title, body, href }) => (
							<a
								href={href}
								class="group flex gap-4 rounded-xl border border-gray-100 bg-gray-50 p-6 transition-shadow hover:shadow-md"
							>
								<div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-50 text-xl">
									{icon}
								</div>
								<div>
									<h3 class="font-semibold text-gray-900 transition-colors group-hover:text-red-600">
										{title}
									</h3>
									<p class="mt-1 text-sm leading-6 text-gray-500">{body}</p>
								</div>
							</a>
						))
					}
				</div>

				<div class="mt-10 flex gap-4 justify-center">
					<a
						href="/publishing"
						class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors text-sm"
					>
						View Publishing Services →
					</a>
					<a
						href="/marketing"
						class="inline-block border-2 border-red-600 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors text-sm"
					>
						View Marketing Services →
					</a>
				</div>
			</div>
		</section>

		<!-- ═══ TESTIMONIALS ═══ -->
		<section class="bg-gray-50 px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red-600 mb-3">
						Testimonials
					</p>
					<h2 class="font-serif text-3xl font-bold text-gray-900 sm:text-4xl">
						What Kingdom Messengers Are Saying
					</h2>
				</div>

				<div class="grid grid-cols-1 gap-8 md:grid-cols-3">

					<figure class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-100">
						<blockquote class="text-base leading-7 text-gray-700 italic">
							<p>"Through Kevin's weekly soul care, I've grown as a leader and become more
							intentional in being a messenger of the Gospel."</p>
						</blockquote>
						<figcaption class="mt-6 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-red-100 font-serif text-base font-bold text-red-600">
								J
							</div>
							<div>
								<p class="font-semibold text-gray-900">Jim Matuga</p>
								<p class="text-sm text-gray-500">Humble Influence — Morgantown, West Virginia</p>
							</div>
						</figcaption>
					</figure>

					<figure class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-100">
						<blockquote class="text-base leading-7 text-gray-700 italic">
							<p>"Kevin and Shelly's pastoral care is what I needed to grow as a leader. They
							have been my guide on this journey of transformation."</p>
						</blockquote>
						<figcaption class="mt-6 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-red-100 font-serif text-base font-bold text-red-600">
								S
							</div>
							<div>
								<p class="font-semibold text-gray-900">Sheila Hoffman</p>
								<p class="text-sm text-gray-500">Succeed and Lead — Birmingham, Alabama</p>
							</div>
						</figcaption>
					</figure>

					<figure class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-100">
						<blockquote class="text-base leading-7 text-gray-700 italic">
							<p>"Kevin has accelerated my spiritual transformation journey more than anyone else
							on earth. Because of him I'm comfortable telling my story."</p>
						</blockquote>
						<figcaption class="mt-6 flex items-center gap-3">
							<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-red-100 font-serif text-base font-bold text-red-600">
								A
							</div>
							<div>
								<p class="font-semibold text-gray-900">Adam Gross</p>
								<p class="text-sm text-gray-500">Come Alive — Raleigh, North Carolina</p>
							</div>
						</figcaption>
					</figure>

				</div>
			</div>
		</section>

		<!-- ═══ FINAL CTA ═══ -->
		<section class="bg-navy-950 px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4">
					Ready to publish your message to the nations?
				</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Let's talk about your vision. Our team will walk you through every option and help you
					find the right path forward.
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3.5 rounded-md hover:bg-red-700 transition-colors"
				>
					Request a Free Consultation
				</a>
			</div>
		</section>

	</main>
</Layout>
