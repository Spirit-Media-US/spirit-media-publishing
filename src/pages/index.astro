---
import MailtoLink from '../components/MailtoLink.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

// All homepage brand/program/testimonial imagery is served from R2 (same origin
// as fonts + logo + hero). No cdn.sanity.io TLS handshake anywhere in the
// homepage request chain on any page lifecycle stage.
//
// To swap a brand image: upload a new <name>.webp to
//   assets.spiritmediapublishing.com/spirit-media-publishing/homepage/
// (source of truth is R2, not Sanity — matches the logo + hero pattern).
const R2_BASE = 'https://assets.spiritmediapublishing.com/spirit-media-publishing/homepage';

// Hero alt text + audio URL still fetched from Sanity (text only, tiny GROQ).
// Testimonials are now hardcoded (see FALLBACK_TESTIMONIALS below) so the
// author photos can stay on R2 — Sanity testimonials would re-inject
// cdn.sanity.io photo URLs and reintroduce the TLS handshake.
let homepageHeroImageAlt = 'Published books by Spirit Media authors';
let homepageAudioUrl: string | undefined;
try {
	const s = await sanityClient.fetch(
		`*[_type == "siteSettings"][0]{ homepageHeroImageAlt, homepageAudioUrl }`,
	);
	if (s?.homepageHeroImageAlt) homepageHeroImageAlt = s.homepageHeroImageAlt;
	if (s?.homepageAudioUrl) homepageAudioUrl = s.homepageAudioUrl;
} catch (e) {}

const fhbImage = `${R2_BASE}/fhb.webp`;
const kmcBrandImage = `${R2_BASE}/kmc.webp`;
const woyImage = `${R2_BASE}/woy.webp`;
const expressBooksImage = `${R2_BASE}/express-books.webp`;
const believerLibraryImage = `${R2_BASE}/believers-library.webp`;
const manuscriptReviewImage = `${R2_BASE}/manuscript-review.webp`;
const childrensBooksImage = `${R2_BASE}/childrens-books.webp`;
const writeBookImage = `${R2_BASE}/write-book.webp`;
const publishBookImage = `${R2_BASE}/publish-book.webp`;
const marketMessageImage = `${R2_BASE}/market-message.webp`;

// Hero LCP image — self-hosted on R2, same origin as fonts (one TLS handshake).
// Desktop-only block (hidden lg:block) so mobile never fetches the hero.
// AVIF primary + WebP fallback, both at tablet (800w) and desktop (1200w).
const homepageHeroAvif800 =
	'https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-tablet.avif';
const homepageHeroAvif1200 =
	'https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-desktop.avif';
const homepageHeroImage800 =
	'https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-tablet.webp';
const homepageHeroImage =
	'https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-desktop.webp';
if (!homepageAudioUrl) {
	homepageAudioUrl =
		'https://assets.spiritmediapublishing.com/spirit-media-publishing/SM-2-23-26.mp3';
}

const FALLBACK_TESTIMONIALS = [
	{
		quote:
			"Kevin has accelerated my spiritual transformation journey more than anyone else on earth. Because of him I'm comfortable telling my story.",
		authorName: 'Jim Matuga',
		authorUrl: 'https://inneractionmedia.com/',
		authorLocation: 'Humble Influence — Morgantown, WV',
		authorPhoto: `${R2_BASE}/testimonial-jim.webp`,
	},
	{
		quote:
			'Kevin and Spirit Media are so amazing to work with. They guided me through every facet of writing and publishing my book. They empowered me to encourage others.',
		authorName: 'Cindy Love',
		authorUrl: 'https://clowningfromtheheart.com/',
		authorLocation: 'Clowning From the Heart — Walla Walla, WA',
		authorPhoto: `${R2_BASE}/testimonial-cindy.webp`,
	},
	{
		quote:
			'Kevin White and his team have not only worked hard but have been so much fun to work with. I highly recommend Spirit Media to everyone with a message to be published.',
		authorName: 'Van Eure',
		authorUrl: 'https://angusbarn.com/',
		authorLocation: 'Hospitality Rules — Raleigh, NC',
		authorPhoto: `${R2_BASE}/testimonial-van.webp`,
	},
];
const testimonials = FALLBACK_TESTIMONIALS;
---
<Layout
	title="Spirit Media Publishing | Christian Book Publishing"
	description="Spirit Media helps Christian authors publish and market their books to 195 nations. Ghostwriting, editing, cover design, audiobooks, and global distribution."
	ogImage="https://assets.spiritmediapublishing.com/spirit-media-publishing/og/homepage-og.jpg"
>
	<Fragment slot="head-early">
		<!-- Desktop-only hero preload. Mobile layout is text-only (H1 is LCP) and
		     never fetches the hero — `media="(min-width: 1024px)"` gates this <link>
		     so PSI mobile sees zero bytes for the collage. Matches the `<picture>`
		     below which lives inside `hidden lg:block`. Scripture Alive pattern. -->
		<link
			rel="preload"
			as="image"
			type="image/avif"
			href={homepageHeroAvif1200}
			imagesrcset={`${homepageHeroAvif800} 800w, ${homepageHeroAvif1200} 1200w`}
			imagesizes="600px"
			fetchpriority="high"
			media="(min-width: 1024px)"
		/>
	</Fragment>
	<Fragment slot="head">
		<meta name="keywords" content="Christian book publishing, Christian author publishing, publish a Christian book, Christian book marketing, Kingdom Messenger, Spirit Media Publishing, self publish Christian book, Christian ghostwriting, audiobook publishing, faith-based publishing, Christian publishing company" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com",
			"logo": "https://spiritmediapublishing.com/spirit-media-logo.png",
			"sameAs": [
				"https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA",
				"https://www.facebook.com/spiritmediaus",
				"https://www.instagram.com/spiritmediaus"
			],
			"description": "Spirit Media Publishing helps Christian authors publish, market, and distribute their books across 195 nations.",
			"founder": { "@type": "Person", "name": "Kevin White" },
			"foundingDate": "2020",
			"areaServed": "Worldwide",
			"serviceType": ["Book Publishing", "Book Marketing", "Ghostwriting", "Cover Design", "Audiobook Production"]
		})}></script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"url": "https://spiritmediapublishing.com",
			"name": "Spirit Media Publishing",
			"description": "Christian book publishing and marketing for Kingdom authors",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://spiritmediapublishing.com/bookstore?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		})}></script>
	</Fragment>
	<main id="main-content">

		<!-- ═══ HERO ═══ -->
		<!-- Two-block pattern (Scripture Alive): mobile is text-only so the H1 is the
		     LCP element and NO image downloads on mobile at all. Desktop keeps the
		     side-by-side grid with the book collage. Preload is media-gated to
		     (min-width: 1024px). -->

		<!-- MOBILE HERO — text-only. H1 is LCP. No hero-stagger (no post-LCP flash
		     on an element that IS the LCP). Tight pt-8/pb-10 pushes the LCP text up
		     in the viewport so it paints with less layout work beforehand. -->
		<section class="bg-stone-50 px-6 pt-8 pb-10 overflow-hidden lg:hidden">
			<div class="mx-auto max-w-7xl">
				<h1 class="type-hero text-ink-soft">
					Born from holy conviction.
					<br />
					<span class="text-red">Built for global impact.</span>
				</h1>
				<p class="mt-7 type-body-lg text-stone-700 max-w-xl">
					We refuse small vision. We reveal the Father's heart for His beloved children, for generations, and until the Good News bears fruit in every nation.
				</p>
				<p class="mt-4 type-body-lg text-stone-700 max-w-xl">
					Welcome to Spirit Media! We develop Kingdom Messengers by empowering them from <strong class="text-ink">heart → message → movement.</strong>
				</p>
				<div class="mt-9 flex flex-wrap gap-4">
					<a href="/about" class="btn btn-ghost">We Are Spirit Media</a>
					<a href="/contact" class="btn btn-primary">Request a Call</a>
				</div>
			</div>
		</section>

		<!-- DESKTOP HERO — side-by-side grid, book collage image. Hidden below lg
		     (1024px) so mobile never pays the download cost. srcset targets the
		     actual rendered widths only: 800w (DPR-1 desktop ~600px) and 1200w
		     (DPR-2 desktop). No 480w variant — that was the failed mobile chase.

		     Utility classes are all lg:-prefixed (lg:pt-12, lg:pb-16, lg:grid-cols-2)
		     so critical CSS covers them — without the prefix, grid-cols-2/pt-12/pb-16
		     are in the async Tailwind bundle and the section reflows from 1-col to
		     2-col when the bundle lands (CLS 0.458 regression on prod 2026-04-19). -->
		<section class="bg-stone-50 px-6 lg:pt-12 lg:pb-16 lg:px-8 overflow-hidden hidden lg:block">
			<div class="mx-auto max-w-7xl">
				<div class="grid lg:grid-cols-2 gap-16 items-center">
					<div class="hero-stagger">
						<h1 class="type-hero text-ink-soft">
							Born from holy conviction.
							<br />
							<span class="text-red">Built for global impact.</span>
						</h1>
						<p class="mt-7 type-body-lg text-stone-700 max-w-xl">
							We refuse small vision. We reveal the Father's heart for His beloved children, for generations, and until the Good News bears fruit in every nation.
						</p>
						<p class="mt-4 type-body-lg text-stone-700 max-w-xl">
							Welcome to Spirit Media! We develop Kingdom Messengers by empowering them from <strong class="text-ink">heart → message → movement.</strong>
						</p>
						<div class="mt-9 flex flex-wrap gap-4">
							<a href="/about" class="btn btn-ghost">We Are Spirit Media</a>
							<a href="/contact" class="btn btn-primary">Request a Call</a>
						</div>
					</div>
					<!-- `<source media>` gates the preload scanner by viewport. On mobile
					     no source matches, falling through to the `<img>` — which is
					     loading="lazy" so Chrome's preload scanner skips it entirely.
					     Without these guards, PSI mobile downloads hero-desktop.avif
					     (139KB) because the preload scanner evaluates srcset BEFORE CSS
					     computes display:none on the hidden parent. -->
					<picture>
						<source
							type="image/avif"
							media="(min-width: 1024px)"
							srcset={`${homepageHeroAvif800} 800w, ${homepageHeroAvif1200} 1200w`}
							sizes="600px"
						/>
						<source
							type="image/webp"
							media="(min-width: 1024px)"
							srcset={`${homepageHeroImage800} 800w, ${homepageHeroImage} 1200w`}
							sizes="600px"
						/>
						<img
							src={homepageHeroImage}
							alt={homepageHeroImageAlt}
							width="1200"
							height="776"
							fetchpriority="high"
							loading="lazy"
							decoding="async"
							class="w-full max-h-[600px] object-contain"
						/>
					</picture>
				</div>
			</div>
		</section>

		<!-- ═══ SCRIPTURE SECTION ═══ -->
		<section class="bg-ink-soft px-6 py-12 lg:px-8 relative overflow-hidden">
			<div class="mx-auto max-w-3xl text-center relative z-10">
				<blockquote data-animate="fade-in">
					<div class="font-serif text-red mb-4" style="font-size:4rem;line-height:1;font-style:normal" aria-hidden="true">&ldquo;</div>
					<p class="type-scripture text-stone-100">
						"Publish Our Father's glorious deeds among the nations. Tell everyone about the amazing things He does."
					</p>
					<cite class="mt-6 block text-sm font-semibold tracking-widest text-stone-300 not-italic">
						— Psalm 96:3 (FHB)
					</cite>
				</blockquote>
			</div>
		</section>

		<!-- ═══ AUDIO MESSAGE ═══ -->
		<section class="bg-ink-soft px-6 pb-12 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-stone-300 text-sm font-medium tracking-wide mb-4" data-animate="fade-in">
					We are already praying for you and our Father's message through you.
					<br class="hidden sm:block" />
					Click here to listen &rarr;
				</p>
				<audio controls preload="none" class="mx-auto w-full max-w-md rounded-full" style="accent-color:#c0392b;">
					<source src={homepageAudioUrl} type="audio/mpeg" />
					Your browser does not support the audio element.
				</audio>
			</div>
		</section>

		<!-- ═══ MISSION STATEMENT ═══ -->
		<section class="bg-stone-100 px-6 py-10 lg:py-16 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<span class="eyebrow eyebrow-red" data-animate="fade-in">Our Mission</span>
				<p class="type-scripture text-ink-soft" data-animate="fade-in" data-delay="1">
					Spirit Media is a Christian publishing and marketing family with a mission to reveal our Father's heart to all <span class="text-red">195 nations</span> worldwide.
				</p>
			</div>
		</section>

		<!-- ═══ EXCLUSIVE HOME OF (BRAND CARDS) ═══ -->
		<section class="bg-surface px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-6">
					<span class="eyebrow eyebrow-red" data-animate="fade-in">Exclusive Home of</span>
					<h2 class="type-section-heading text-ink-soft mb-6" data-animate="fade-in" data-delay="1">
						Our Brands &amp; Programs
					</h2>
					<div class="flex flex-wrap justify-center gap-3" data-animate="fade-in" data-delay="2">
						{['Father\'s Heart Bible™', 'Kingdom Messenger Collective', 'Work On Yourself', 'EXPRESS BOOKS™', 'The Believer\'s Library'].map((brand) => (
							<span class="inline-flex items-center gap-1.5 rounded-full bg-surface px-4 py-1.5 text-sm font-semibold text-ink-soft ring-1 ring-stone-300 shadow-sm">
								{brand}
							</span>
						))}
					</div>
				</div>

				<!-- FHB — Featured hero card -->
				<div class="bg-ink-soft rounded-3xl p-8 lg:p-10 mb-6 mt-6 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center" data-animate="fade-in">
					<div class="flex items-center justify-center order-first lg:order-last mt-6 lg:mt-0">
						<img
							src={fhbImage}
							alt="Father's Heart Bible — An Intimate Translation"
							width="288"
							height="288"
							loading="lazy"
							decoding="async"
							class="w-72 object-contain rounded-2xl shadow-2xl"
						/>
					</div>
					<div class="order-last lg:order-first">						<span class="eyebrow" style="color: var(--color-stone-400);">Father's Heart Bible™ (FHB)</span>
						<h3 class="type-card-heading mb-4 leading-snug text-stone-100">
							An intimate translation revealing our Father's heart to a fatherless generation.
						</h3>
						<p class="type-body-lg text-stone-300 mb-6">
							One message for every reader: "Come home. You belong to Me. You are My beloved child." Each gift of $100 places three Father's Heart Bibles into the hands of readers worldwide.
						</p>
						<a href="https://fathersheartbible.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
							Visit FathersHeartBible.com →
						</a>
					</div>
				</div>

				<!-- 4 remaining brand cards -->
				<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
					<!-- KMC -->
					<div class="rounded-2xl border border-stone-200 bg-stone-50 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="1">
						<img src={kmcBrandImage} alt="Kingdom Messenger Collective" width="600" height="300" loading="lazy" decoding="async" class="w-full h-48 object-cover" />
						<div class="p-7">
							<span class="eyebrow">Kingdom Messenger Collective</span>
							<h3 class="type-card-subheading text-ink-soft mb-3">From God-given message to sustainable movement.</h3>
							<p class="type-body-lg text-stone-700 mb-5">Our flagship development program that walks with Kingdom Messengers through a 3+ year partnership.</p>
							<a href="/kingdom-messenger-collective" class="text-sm font-semibold text-red-deep hover:text-red transition-colors">Learn More →</a>
						</div>
					</div>
					<!-- WOY -->
					<div class="rounded-2xl border border-stone-200 bg-stone-50 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="2">
						<img src={woyImage} alt="Work On Yourself" width="600" height="300" loading="lazy" decoding="async" class="w-full h-48 object-cover" />
						<div class="p-7">
							<span class="eyebrow">Work On Yourself</span>
							<h3 class="type-card-subheading text-ink-soft mb-3">A soul care intensive for leaders whose outer success has outpaced their inner life.</h3>
							<p class="type-body-lg text-stone-700 mb-5">A twelve-month protected season where leaders are accompanied rather than optimized.</p>
							<a href="https://workonyourself.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-red-deep hover:text-red transition-colors">Visit WorkOnYourself.com →</a>
						</div>
					</div>
					<!-- Express Books -->
					<div class="rounded-2xl border border-stone-200 bg-stone-50 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="3">
						<img src={expressBooksImage} alt="EXPRESS BOOKS™" width="600" height="400" loading="lazy" decoding="async" class="w-full h-48 object-cover" />
						<div class="p-7">
							<span class="eyebrow">EXPRESS BOOKS™</span>
							<h3 class="type-card-subheading text-ink-soft mb-3">Fast reads. Lasting impact.</h3>
							<p class="type-body-lg text-stone-700 mb-5">Intentionally compact books designed to be read in under an hour. No filler. No fluff. Transformation that lasts a lifetime.</p>
							<a href="/express-books" class="text-sm font-semibold text-red-deep hover:text-red transition-colors">Learn More →</a>
						</div>
					</div>
					<!-- Believer's Library -->
					<div class="rounded-2xl border border-stone-200 bg-stone-50 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="4">
						<img src={believerLibraryImage} alt="The Believer's Library" width="600" height="400" loading="lazy" decoding="async" class="w-full h-48 object-cover object-top" />
						<div class="p-7">
							<span class="eyebrow">The Believer's Library</span>
							<h3 class="type-card-subheading text-ink-soft mb-3">The world's largest cloud-based Christian library.</h3>
							<p class="type-body-lg text-stone-700 mb-5">Our exclusive mobile app delivering PDF downloads to 3.3 billion souls worldwide with limited access to Jesus.</p>
							<a href="https://thebelieverslibrary.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red-deep hover:text-red transition-colors">Visit thebelieverslibrary.com →</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ FREE MANUSCRIPT REVIEW ═══ -->
		<section class="bg-ink-soft px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<!-- Image left -->
					<div class="flex justify-center" data-animate="slide-left">
						<img src={manuscriptReviewImage} alt="Sample Spirit Media Manuscript Review document" width="600" height="900" loading="lazy" decoding="async" class="w-full max-w-xs" />
					</div>
					<!-- Content right -->
					<div data-animate="slide-right">
						<div class="mb-10">
							<span class="eyebrow" style="color: var(--color-stone-500);" data-animate="fade-in">Free Offer</span>
							<h2 class="type-section-heading text-stone-100 mb-4">
								Free Manuscript Review
							</h2>
							<p class="type-body-lg text-stone-400">
								Share your manuscript with us and our team of seasoned editors will provide a <strong class="text-stone-200">FREE customized 20-point review ($250 value).</strong>
							</p>
						</div>
						<div class="flex flex-wrap gap-2 mb-8">
							{[
								'Manuscript Overview', 'Biblical Accuracy', 'Target Audience Analysis', 'Genre & Market Fit',
								'Content Organization', 'Thematic Depth', 'Emotional Impact', 'Writing Style & Voice',
								'Grammar & Mechanics', 'Clarity & Readability', 'Research & Credibility', 'Reader Engagement & Pacing',
								'Unique Selling Points', 'Final Editing Assessment', 'Market Potential', 'Strengths',
								'Areas for Improvement', 'Top Amazon Categories', 'Optimized KDP Keywords', 'Summary & Recommendations',
							].map((item) => (
								<span class="bg-ink-muted/40 text-stone-400 text-xs font-medium px-3 py-1.5 rounded-full ring-1 ring-stone-600/30">
									{item}
								</span>
							))}
						</div>
						<p class="text-stone-500 italic mb-8">
							This will affirm God's good work in and through you.
						</p>
						<MailtoLink email="publisher@spiritmedia.us" class="btn btn-primary">
							Email your Manuscript →
						</MailtoLink>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ SERVICES OVERVIEW ═══ -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<div data-animate="slide-left">
						<span class="eyebrow eyebrow-red">Services</span>
						<h2 class="type-section-heading text-ink-soft mb-4">
							Providing Solutions<br />
							You Need Right Now
						</h2>
						<p class="type-body-lg text-stone-700 mb-6">
							At Spirit Media, our passion is to amplify your message and increase your impact. Our comprehensive publishing and marketing solutions are here to serve you.
						</p>
						<a href="/publishing" class="btn btn-primary">
							Learn More →
						</a>
						<img src={childrensBooksImage} alt="Children's book covers published by Spirit Media" width="980" height="201" loading="lazy" decoding="async" class="w-full mt-8" />
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-animate="slide-right">
						{
							[
								{ title: 'Write My Book', body: 'Meet with your writer one hour per week. Book complete in as few as 90 days.', href: '/publishing' },
								{ title: 'Publish My Book', body: 'Paperback, hardback, digital, and audiobook — global distribution worldwide.', href: '/publishing' },
								{ title: "Publish My Children's Book", body: 'Fully illustrated children\'s books connecting your story with young readers.', href: '/publishing' },
								{ title: 'Build My Website', body: 'Website design, SEO, and digital strategy to grow your online presence.', href: '/marketing' },
								{ title: 'Increase My Sales', body: 'Audit your listings, increase reviews, market to bookstores and increase your sales.', href: '/marketing' },
								{ title: 'Produce My Podcast Show', body: 'Podcast production, YouTube optimization, and video content strategy.', href: '/marketing' },
							].map(({ title, body, href }) => (
								<a href={href} class="group flex gap-3 rounded-xl border border-stone-200 bg-surface p-5 transition-shadow hover:shadow-md">
									<div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-red-wash text-red mt-0.5">
										<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" /></svg>
									</div>
									<div>
										<h3 class="type-card-subheading text-ink-soft group-hover:text-red transition-colors">{title}</h3>
										<p class="mt-1 type-caption text-stone-600">{body}</p>
									</div>
								</a>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ AI WEBSITES SPOTLIGHT ═══ -->
		<section class="relative overflow-hidden bg-ink-soft px-6 py-14 lg:py-20 lg:px-8">
			<div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at top right, rgba(192, 57, 43, 0.4), transparent 60%);"></div>
			<div class="relative mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-center">
					<div class="lg:col-span-3" data-animate="slide-left">
						<span class="eyebrow eyebrow-red">New in 2026</span>
						<h2 class="type-section-heading text-stone-100 mt-2">
							AI-Powered Websites Built on the <span class="text-red-soft">Fastest Stack</span> in 2026
						</h2>
						<p class="mt-5 type-body-lg text-stone-300 max-w-2xl">
							Sub-2-second load times. 95+ Google scores. AI-ready infrastructure. Spirit Media builds websites on the stack Google rewards — and visitors actually use.
						</p>
						<p class="mt-4 font-serif italic text-red-soft text-lg">
							When your message deserves a mountaintop instead of a cave.
						</p>
						<div class="mt-7 flex flex-wrap gap-4">
							<a href="/ai-websites" class="inline-flex items-center rounded-md bg-red px-6 py-3 text-sm font-bold uppercase tracking-[0.08em] text-white transition-all hover:bg-red-deep">
								See Our Websites →
							</a>
							<a href="/contact" class="inline-flex items-center rounded-md border-2 border-stone-300 px-6 py-3 text-sm font-bold uppercase tracking-[0.08em] text-stone-100 transition-all hover:bg-stone-100 hover:text-ink-soft">
								Free 48-Hour Audit
							</a>
						</div>
					</div>
					<div class="lg:col-span-2" data-animate="slide-right">
						<div class="grid grid-cols-2 gap-3">
							{[
								`${R2_BASE}/ai-sample-1.webp`,
								`${R2_BASE}/ai-sample-2.webp`,
								`${R2_BASE}/ai-sample-3.webp`,
								`${R2_BASE}/ai-sample-4.webp`,
							].map((src, i) => (
								<div class="aspect-[4/3] rounded-xl overflow-hidden border border-stone-700 bg-ink">
									<img src={src} alt={`Spirit Media website sample ${i + 1}`} width="400" height="300" class="w-full h-full object-cover" loading="lazy" decoding="async" />
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ TESTIMONIALS ═══ -->
		<section class="bg-stone-100 px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-12">
					<span class="eyebrow eyebrow-red" data-animate="fade-in">Testimonials</span>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-in" data-delay="1">
						Spirit Media Celebrates
					</h2>
					<p class="type-body mt-2 text-stone-700" data-animate="fade-in" data-delay="2">Real authors. Real results. Real transformation.</p>
				</div>
								<div class="grid grid-cols-1 gap-8 md:grid-cols-3">
					{testimonials.map((t, i) => (
						<figure class="rounded-2xl bg-surface p-8 shadow-sm ring-1 ring-stone-200 flex flex-col" data-animate="fade-in" data-delay={String(i + 1)}>
							<blockquote class="type-body-lg text-stone-700 flex-1">
								<p><span class="font-serif text-red mr-1 align-bottom" style="font-size:4rem;line-height:1;font-style:normal" aria-hidden="true">&ldquo;</span>{t.quote}</p>
							</blockquote>
							<figcaption class="mt-6 flex items-center gap-3 pt-6 border-t border-stone-100">
								<img src={t.authorPhoto} alt={t.authorName} width="64" height="64" loading="lazy" decoding="async" class="h-16 w-16 shrink-0 rounded-full object-cover object-top" />
								<div>
									<p class="type-body-sm font-semibold text-ink-soft">
										{t.authorUrl ? (
											<a href={t.authorUrl} target="_blank" rel="noopener noreferrer" class="hover:text-red transition-colors">{t.authorName}</a>
										) : t.authorName}
									</p>
									<p class="type-caption text-stone-700">{t.authorLocation}</p>
								</div>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- ═══ PARTNERING IN YOUR SUCCESS ═══ -->
		<section class="bg-surface px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="text-center mb-12">
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-in">
						Partnering in <em>Your Success</em>
					</h2>
					<p class="mt-2 text-stone-700" data-animate="fade-in" data-delay="1">Choose the path that's right for you.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<div class="rounded-2xl bg-surface border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="1">
						<img src={writeBookImage} alt="Write my book" width="600" height="300" loading="lazy" decoding="async" class="w-full h-48 object-cover object-top" />
						<div class="p-8">
							<h3 class="type-card-heading text-ink-soft mb-3"><span class="font-serif text-red mr-2 align-bottom" style="font-size:4rem;line-height:1;font-style:normal" aria-hidden="true">1</span>Help Me Write My Book</h3>
							<p class="type-body-lg text-stone-700 mb-6">Tell us your vision! We will write your book in your voice using our proven Angel Writing process.</p>
							<a href="/publishing" class="btn btn-primary">Start Writing →</a>
						</div>
					</div>
					<div class="rounded-2xl bg-surface border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="2">
						<img src={publishBookImage} alt="Publish my book" width="600" height="300" loading="lazy" decoding="async" class="w-full h-48 object-cover" />
						<div class="p-8">
							<h3 class="type-card-heading text-ink-soft mb-3"><span class="font-serif text-red mr-2 align-bottom" style="font-size:4rem;line-height:1;font-style:normal" aria-hidden="true">2</span>Publish My Book</h3>
							<p class="type-body-lg text-stone-700 mb-6">Ready to publish? Let us partner with you to bring your book to life and take your message to the nations.</p>
							<a href="/publishing" class="btn btn-primary">Start Publishing →</a>
						</div>
					</div>
					<div class="rounded-2xl bg-surface border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-in" data-delay="3">
						<img src={marketMessageImage} alt="Market my message" width="600" height="300" loading="lazy" decoding="async" class="w-full h-48 object-cover" />
						<div class="p-8">
							<h3 class="type-card-heading text-ink-soft mb-3"><span class="font-serif text-red mr-2 align-bottom" style="font-size:4rem;line-height:1;font-style:normal" aria-hidden="true">3</span>Market My Message</h3>
							<p class="type-body-lg text-stone-700 mb-6">Need to reach your audience? Let us help you get the word out with our systematic marketing strategies.</p>
							<a href="/marketing" class="btn btn-primary">Start Marketing →</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ FINAL CTA ═══ -->
		<section class="bg-ink-soft px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="type-section-heading text-stone-100 mb-4" data-animate="fade-in">
					Ready to publish your message to the nations?
				</h2>
				<p class="type-body-lg text-stone-400 mb-8" data-animate="fade-in" data-delay="1">
					Let's talk about your vision. Our team will walk you through every option and help you find the right path forward — no pressure, no obligation.
				</p>
				<a href="/contact" class="btn btn-primary" data-animate="fade-in" data-delay="2">
					Request a Free Consultation
				</a>
			</div>
		</section>

	</main>
</Layout>
