---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Marketing Services — Spirit Media Publishing"
	description="Kingdom-focused marketing strategy to amplify your book and message. Social media, email, PR, Amazon optimization, and more."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Marketing Services</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Marketing That Multiplies Kingdom Impact
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed mb-8">
					Publishing your book is step one. Getting it into the right hands requires a
					Kingdom-focused marketing strategy. We help you build momentum, grow your audience,
					and create lasting impact.
				</p>
				<a href="/contact" class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
					Request a Strategy Call
				</a>
			</div>
		</section>

		<!-- THE CHALLENGE -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">Most Authors Publish. Few Are Heard.</h2>
				<p class="text-lg text-gray-700 leading-relaxed">
					The biggest challenge facing Kingdom authors today isn't writing the book — it's being
					discovered. With millions of books published every year, visibility is the battleground.
					Spirit Media's marketing team exists to help your message cut through the noise and reach
					the people God intended.
				</p>
			</div>
		</section>

		<!-- OUR MARKETING STRATEGY -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">A Three-Layer Marketing Approach</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">

					<div class="bg-white rounded-2xl p-8">
						<div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-sm mb-6">1</div>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Build Your Platform</h3>
						<p class="text-gray-600 text-sm leading-relaxed mb-4">Your platform is the foundation of every marketing effort.</p>
						<ul class="space-y-2 text-sm text-gray-700">
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Author website</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Social media presence</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Email list building</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Brand identity</li>
						</ul>
					</div>

					<div class="bg-white rounded-2xl p-8">
						<div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-sm mb-6">2</div>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Amplify Your Message</h3>
						<p class="text-gray-600 text-sm leading-relaxed mb-4">Get your book in front of readers who are ready to receive it.</p>
						<ul class="space-y-2 text-sm text-gray-700">
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Amazon optimization</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Podcast guest placements</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Speaking opportunities</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Media &amp; PR pitching</li>
						</ul>
					</div>

					<div class="bg-white rounded-2xl p-8">
						<div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-sm mb-6">3</div>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">Sustain Momentum</h3>
						<p class="text-gray-600 text-sm leading-relaxed mb-4">Marketing is not a one-time event. We create ongoing momentum.</p>
						<ul class="space-y-2 text-sm text-gray-700">
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Email marketing campaigns</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Content strategy</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Paid advertising</li>
							<li class="flex items-center gap-2"><span class="text-red-600">•</span> Affiliate &amp; partner outreach</li>
						</ul>
					</div>

				</div>
			</div>
		</section>

		<!-- FULL SERVICES LIST -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">Our Marketing Services</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto">
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Social Media Management
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Email Marketing Setup &amp; Campaigns
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Amazon Author Page Optimization
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Book Launch Strategy
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Content Creation (blogs, reels, graphics)
						</li>
					</ul>
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Podcast Booking &amp; Placement
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Speaking Opportunity Development
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							PR &amp; Media Outreach
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Paid Advertising Management
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<span class="w-2 h-2 rounded-full bg-red-600 flex-shrink-0"></span>
							Influencer &amp; Partner Outreach
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- FOR PUBLISHERS -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">Marketing + Publishing = Maximum Impact</h2>
				<p class="text-lg text-gray-700 leading-relaxed mb-8">
					When you publish and market with Spirit Media, you get a fully integrated approach.
					Your book's cover, your author brand, your social media, and your distribution strategy
					are all aligned — designed to carry your message further.
				</p>
				<a href="/publishing" class="inline-block border-2 border-red-600 text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
					View Publishing Services
				</a>
			</div>
		</section>

		<!-- CTA BANNER -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Let's Build Your Marketing Strategy</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Book a free strategy call with our team and discover how we can amplify your message.
				</p>
				<a href="/contact" class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors">
					Request a Free Strategy Call
				</a>
			</div>
		</section>

	</main>
</Layout>
