---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Marketing Services — Spirit Media"
	description="Systematic marketing strategies that multiply your exposure, engagement, and Kingdom impact."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Marketing</p>
						<h1 class="type-hero text-ink-soft">
							Marketing with
							<br />
							<span class="text-red">Spirit Media</span>
						</h1>
						<p class="mt-6 type-body-lg text-stone-700 max-w-xl">
							Your message deserves to be heard. We don't just get you to market — we build
							systematic, long-term strategies that multiply your exposure, engagement, and
							Kingdom impact.
						</p>
						<div class="mt-8">
							<a href="/contact" class="rounded-md bg-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Request a Call →</a>
						</div>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-ink-muted aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- STRATEGY -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red mb-3" data-animate="fade-up">Strategy</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">Our Marketing Strategy</h2>
					<p class="mt-4 text-stone-600 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up" data-delay="2">We build from the ground up. Each layer amplifies the last:</p>
				</div>
				<div class="space-y-4">
					{[
						{ step: '1', title: 'Optimized Amazon listing', desc: "the world's #1 bookseller" },
						{ step: '2', title: 'Website with SEO', desc: 'your 24/7 employee working for you' },
						{ step: '3', title: 'YouTube Channel', desc: "the world's #2 search engine" },
						{ step: '4', title: 'Social media', desc: 'steady, systematic presence' },
						{ step: '5', title: 'Press releases', desc: 'domestic and international reach through PR Newswire' },
						{ step: '6', title: 'SMS marketing', desc: 'direct access, high engagement' },
						{ step: '7', title: 'Email marketing', desc: 'consistent communication with your audience' },
					].map(({ step, title, desc }, i) => (
						<div class="flex items-start gap-4 bg-stone-50 rounded-xl p-5 border border-stone-200" data-animate="fade-up" data-delay={String((i % 4) + 1)}>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red text-white font-bold text-sm">{step}</span>
							<div>
								<h3 class="font-semibold text-ink-soft">{title}</h3>
								<p class="text-sm text-stone-500 mt-0.5">— {desc}</p>
							</div>
						</div>
					))}
				</div>
				<p class="mt-6 text-sm text-stone-500 text-center italic" data-animate="fade-in">Steps 5–7 multiply results only when 1–4 are in place. We build the foundation first.</p>
			</div>
		</section>

		<!-- SERVICES -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-sm font-semibold uppercase tracking-widest text-red mb-3" data-animate="fade-up">Services</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">Marketing Services</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{[
						{ title: 'Book Marketing: Amazon Reviews', body: 'Six-month partnership focused on increasing Amazon reviews. Includes custom instruction sheet, systematic implementation, with a goal of 25 reviews per month.' },
						{ title: 'Book Marketing: Advance Reader Copies', body: 'We send advance copies to your personal contacts and USA bookstores. Per-copy cost covers mailing list, up to $5 toward printing, fulfillment, and postage.' },
						{ title: 'Book Marketing: Paid Digital Ads', body: 'Twelve-month partnership with setup and monthly optimization of paid ads on one platform: Amazon, Google, YouTube, Facebook, Instagram, or TikTok.' },
						{ title: 'Websites with SEO', body: 'We design, launch, and optimize responsive websites (up to 10 pages) with SSL, SEO, lead generation forms, and user access.' },
						{ title: 'Landing Pages', body: 'Single-page sites optimized for conversions — perfect for book launches, events, or lead generation.' },
						{ title: 'CRM Platform', body: 'Setup and monthly optimization of your contact management system with conversations, calendar scheduling, business phone, voicemail, SMS, invoicing, payment processing, sales pipeline, forms, funnels, workflows, and automations.' },
						{ title: 'Community Platform', body: 'Setup and monthly optimization of a branded online community including structure, content strategy, and member development.' },
						{ title: 'Video Production', body: 'Eight hours of professional filming edited into short-form feature videos and reels. We handle story development, scripting, and post-production.' },
						{ title: 'Podcast Production', body: 'Setup of a podcast tour with pitch sheet and scheduling management — or launch your own show with full weekly production across all major platforms.' },
						{ title: 'YouTube Channel Optimization', body: 'Twelve-month partnership in strategy, publishing, and channel optimization for one YouTube channel.' },
						{ title: 'Social Media Management', body: 'Twelve-month partnership managing up to three platforms. Includes content creation, scheduling up to 20 posts per month, and weekly community engagement.' },
						{ title: 'Email Marketing', body: 'Twelve-month partnership in email design and management — up to 4 emails per month to your contact list.' },
						{ title: 'SMS Marketing', body: 'Twelve-month partnership in SMS marketing — up to 4 messages per month to your contact list.' },
						{ title: 'Public Relations', body: 'Press releases, media kits, promotional videos, flyers, and pitch decks. North America distribution through PR Newswire.' },
						{ title: 'Google Ads for Nonprofits', body: 'Google offers every 501(c)(3) up to $10,000 in ad grants annually. We manage the complexity so you get the results.' },
						{ title: 'Analytics & Reporting', body: 'Monthly tracking of book sales, website traffic, YouTube, podcasts, and social media performance.' },
					].map(({ title, body }, i) => (
						<div class="bg-stone-100 rounded-2xl p-6 border border-stone-200 hover:shadow-md transition-shadow" data-animate="fade-up" data-delay={String((i % 3) + 1)}>
							<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
							</div>
							<h3 class="type-card-subheading mb-3">{title}</h3>
							<p class="type-body-sm text-stone-700">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FREE GUIDE -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="bg-stone-200 rounded-2xl aspect-[8.6/11] flex items-center justify-center" data-animate="slide-left">
						<p class="text-stone-400 text-sm">Book Cover Image</p>
					</div>
					<div data-animate="slide-right">
						<p class="text-sm font-semibold uppercase tracking-widest text-red mb-3">Free for Every Author</p>
						<h2 class="type-section-heading text-ink-soft mb-4">The Ultimate Book Marketing Guide</h2>
						<p class="text-stone-600 leading-relaxed mb-6">Our CEO Kevin White poured everything he knows about book marketing into The Ultimate Book Marketing Guide — a collection of proven tactics to increase book sales. Every Spirit Media author receives a free copy.</p>
						<a href="https://spiritmedia.us/free-ultimate-book-marketing-guide/" target="_blank" rel="noopener noreferrer" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Get Your Free Copy →</a>
					</div>
				</div>
			</div>
		</section>

		<!-- FINAL CTA -->
		<section class="bg-red px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Ready to amplify your message?</h2>
				<p class="text-stone-200 type-body-lg mb-8" data-animate="fade-up" data-delay="1">Let's build a marketing strategy that multiplies your exposure, engagement, and Kingdom impact.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Free Consultation</a>
			</div>
		</section>

	</main>
</Layout>
