---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Father's Heart Bible — Spirit Media"
  description="The Father's Heart Bible — a transformational Bible experience that reveals the Father's heart on every page."
>
  <main id="main-content">

    <!-- HERO -->
    <section class="bg-red-600 text-white py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-red-200 font-semibold uppercase tracking-widest text-sm mb-4">A Spirit Media Project</p>
        <h1 class="text-5xl font-bold font-serif mb-6">Father's Heart Bible</h1>
        <p class="text-xl text-red-100 leading-relaxed mb-10 max-w-3xl mx-auto">
          A one-of-a-kind Bible experience designed to reveal the Father's heart on every page — connecting believers to the love, character, and voice of God.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://fathersheartbible.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-white text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors"
          >
            Visit FathersHeartBible.com
          </a>
          <a
            href="#about"
            class="inline-block border-2 border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors"
          >
            Learn More
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT THE FHB -->
    <section id="about" class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-6">What Is the Father's Heart Bible?</h2>
        <p class="text-gray-700 leading-relaxed mb-6">
          The Father's Heart Bible is a groundbreaking biblical resource that goes beyond commentary — it's a transformational encounter with the heart of God. Each page is crafted to help readers experience Scripture not just as information, but as a personal conversation with their Heavenly Father.
        </p>
        <p class="text-gray-700 leading-relaxed">
          Unlike traditional study Bibles, the Father's Heart Bible weaves together Scripture, revelation, and the Father's voice to create an immersive, soul-transforming journey through God's Word.
        </p>
      </div>
    </section>

    <!-- KEY FEATURES -->
    <section class="bg-gray-50 py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-12 text-center">What Makes It Unique</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-lg p-8 shadow-sm">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Father's Heart Notes</h3>
            <p class="text-gray-700 leading-relaxed">Marginal notes and insights revealing God's fatherly perspective on each passage.</p>
          </div>
          <div class="bg-white rounded-lg p-8 shadow-sm">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Reflection Questions</h3>
            <p class="text-gray-700 leading-relaxed">Deep, personal reflection prompts to help you encounter God's love.</p>
          </div>
          <div class="bg-white rounded-lg p-8 shadow-sm">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Kingdom Declarations</h3>
            <p class="text-gray-700 leading-relaxed">Faith declarations aligned with Scripture to speak God's truth over your life.</p>
          </div>
          <div class="bg-white rounded-lg p-8 shadow-sm">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Journey Maps</h3>
            <p class="text-gray-700 leading-relaxed">Thematic reading plans that guide you through the Bible's greatest themes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FOR WHOM -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-8">Who Is the Father's Heart Bible For?</h2>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <span class="text-red-600 font-bold mt-1">&#8226;</span>
            <span class="text-gray-700 leading-relaxed">New believers discovering their identity in Christ</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-600 font-bold mt-1">&#8226;</span>
            <span class="text-gray-700 leading-relaxed">Mature believers seeking a deeper encounter with the Father</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-600 font-bold mt-1">&#8226;</span>
            <span class="text-gray-700 leading-relaxed">Leaders, pastors, and ministry teams</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-600 font-bold mt-1">&#8226;</span>
            <span class="text-gray-700 leading-relaxed">Anyone recovering from a distorted image of God</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-600 font-bold mt-1">&#8226;</span>
            <span class="text-gray-700 leading-relaxed">Prayer and intercession groups</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- GET INVOLVED -->
    <section class="bg-navy-950 text-white py-20 px-4 text-center" style="background-color: #0a0f2e;">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif mb-6">Be Part of the Movement</h2>
        <p class="text-gray-300 leading-relaxed mb-10 text-lg">
          The Father's Heart Bible is a global project — and it needs global partners. Visit the official site to learn how you can get involved, support the project, or order your copy.
        </p>
        <a
          href="https://fathersheartbible.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors"
        >
          Visit FathersHeartBible.com &#8594;
        </a>
      </div>
    </section>

  </main>
</Layout>
