---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Schedule a Free Publishing & Marketing Consultation — Spirit Media Publishing"
	description="Ready to publish your book or grow your platform? Schedule a free consultation with Spirit Media Publishing and discover how we can help you reach the nations."
	ogImage="/og-home.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="contact Spirit Media Publishing, free publishing consultation, schedule a call Spirit Media, Christian book publishing consultation, publish my book, Spirit Media contact" />
		<meta name="robots" content="index, follow" />
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Contact Us</p>
						<h1 class="type-hero text-ink-soft">Ready to Schedule a<br /><span class="text-red">FREE Consultation Call?</span></h1>
						<p class="mt-6 text-2xl font-bold text-ink-soft"><a href="tel:+18888003744" class="hover:text-red transition-colors">1-888-800-3744</a></p>
						<p class="mt-4 text-stone-600 leading-relaxed max-w-xl">Otherwise, request a call back. Please use this form to inquire about our publishing and marketing services only. No response will be given for employment or sales inquiries. Thank you!</p>
					</div>
					<div class="hidden lg:flex items-center justify-center" aria-hidden="true" data-animate="zoom-in">
						<img src="/book-collage4.png" alt="Books published by Spirit Media" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- FORM -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto" data-animate="fade-up">
				<iframe
					src="https://mail.spiritmediaone.com/widget/form/SRpyaMchAsDAtYsMfaTg"
					style="width:100%; height:700px; border:none; border-radius:3px;"
					id="inline-SRpyaMchAsDAtYsMfaTg"
					data-layout="{'id':'INLINE'}"
					data-trigger-type="alwaysShow"
					data-trigger-value=""
					data-activation-type="alwaysActivated"
					data-activation-value=""
					data-deactivation-type="neverDeactivate"
					data-deactivation-value=""
					data-form-name="Request A Call"
					data-height="692"
					data-layout-iframe-id="inline-SRpyaMchAsDAtYsMfaTg"
					data-form-id="SRpyaMchAsDAtYsMfaTg"
					title="Request A Call"
				></iframe>
				<script is:inline src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
			</div>
		</section>

		<!-- CONTACT INFO -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="text-center" data-animate="fade-up" data-delay="1">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
						</div>
						<h3 class="font-semibold text-ink-soft mb-1">Address</h3>
						<p class="type-body-sm text-stone-600">205 S Academy St #3251<br />Cary, NC 27519</p>
					</div>
					<div class="text-center" data-animate="fade-up" data-delay="2">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
						</div>
						<h3 class="font-semibold text-ink-soft mb-1">Phone</h3>
						<p class="type-body-sm text-stone-600"><a href="tel:+18888003744" class="hover:text-red transition-colors">1-888-800-3744</a></p>
					</div>
					<div class="text-center" data-animate="fade-up" data-delay="3">
						<div class="flex h-14 w-14 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-4">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
						</div>
						<h3 class="font-semibold text-ink-soft mb-1">Email</h3>
						<p class="type-body-sm text-stone-600"><button onclick="this.outerHTML='<a href=\'mailto:hello@spiritmediapublishing.com\' class=\'hover:text-red transition-colors\'>hello@spiritmediapublishing.com</a>'" class="hover:text-red transition-colors underline underline-offset-2 cursor-pointer bg-transparent border-0 p-0 text-inherit font-inherit" aria-label="Reveal email address">Email Us</button></p>
					</div>
				</div>
			</div>
		</section>

	</main>
</Layout>
