---
import AuthorSurvey from '../components/AuthorSurvey.astro';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

let sitePhone = '1-888-800-3744';
let contactHeroImage: string | undefined;
let contactHeroImageAlt = 'Books published by Spirit Media';

try {
	const s = await sanityClient.fetch(
		'*[_type == "siteSettings"][0]{ phone, contactPageHeroImage, contactPageHeroImageAlt }',
	);
	if (s?.phone) sitePhone = s.phone;
	if (s?.contactPageHeroImage) {
		contactHeroImage = urlFor(s.contactPageHeroImage).width(1058).fit('max').auto('format').url();
	}
	if (s?.contactPageHeroImageAlt) contactHeroImageAlt = s.contactPageHeroImageAlt;
} catch (e) {}

// Fallback if not in Sanity
if (!contactHeroImage) {
	contactHeroImage =
		'https://cdn.sanity.io/images/pmowd8uo/production/7833f28378750a49205269eb39a6c2c19f31b92d-1058x394.png?w=1058&fit=max&fm=webp&q=80';
}
---

<Layout
	title="Free Publishing & Marketing Consultation — Spirit Media"
	description="Ready to publish your book or grow your platform? Schedule a free consultation with Spirit Media Publishing and discover how we can help you reach the nations."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/f67376ca3cbad336ac9ed54977f72d3f9917397b-1200x630.jpg?w=1200&h=630&fit=crop&fm=jpg&q=85"
>
	<Fragment slot="head">
		<meta name="keywords" content="contact Spirit Media Publishing, free publishing consultation, schedule a call Spirit Media, Christian book publishing consultation, publish my book, Spirit Media contact" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ContactPage",
			"name": "Schedule a Free Consultation — Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com/contact",
			"description": "Request a free publishing and marketing consultation with Spirit Media Publishing.",
			"provider": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com", "telephone": "", "email": "info@spiritmediapublishing.com" }
		})}></script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Contact Us</p>
						<h1 class="type-hero text-ink-soft">Getting to<br /><span class="text-red">Know You</span></h1>
						<p class="mt-6 text-xl font-semibold text-ink-soft max-w-xl">Before we talk about your manuscript, we'd love to understand your heart for it.</p>
						<p class="mt-4 text-stone-600 leading-relaxed max-w-xl">We've learned that the books that go on to reach the nations come from authors who are deeply aligned with us on <em>why</em> — not just <em>what</em>. This isn't a test to pass; it's how we make sure a partnership would truly serve you. Publishing and marketing a book to reach the world takes real investment on both sides, and the last thing we want is to take you down a road that isn't right for you. So tell us honestly — there are no wrong answers, only clear ones.</p>
					</div>
					<div class="hidden lg:flex items-center justify-center" aria-hidden="true" data-animate="zoom-in">
						<img src={contactHeroImage} alt={contactHeroImageAlt} class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- FORM -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto" data-animate="fade-up">
				<AuthorSurvey phone={sitePhone} />
			</div>
		</section>

	</main>
</Layout>
