---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Request a Call — Spirit Media"
  description="Schedule a free consultation to discuss publishing and marketing services with our team."
>
  <main id="main-content">

    <!-- ===================== HERO ===================== -->
    <section class="bg-red-600 text-white py-24 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
          Ready to Schedule a FREE Consultation Call?
        </h1>
        <p class="text-xl text-red-100 mb-6">Schedule a FREE Consultation Call</p>
        <a
          href="tel:+18888003744"
          class="inline-block text-3xl sm:text-4xl font-bold text-white hover:text-red-200 transition-colors mb-6"
        >
          1-888-800-3744
        </a>
        <p class="text-lg text-red-100">Otherwise, request a call back.</p>
      </div>
    </section>

    <!-- ===================== FORM SECTION ===================== -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-sm text-gray-600 bg-gray-50 border border-gray-200 rounded-lg px-5 py-4 mb-8 leading-relaxed">
          Please use this form to inquire about our publishing and marketing services only.
          No response will be given for employment or sales inquiries. Thank you!
        </p>

        <iframe
          src="https://mail.spiritmediaone.com/widget/form/SRpyaMchAsDAtYsMfaTg"
          style="width:100%; height:700px; border:none; border-radius:3px;"
          id="inline-SRpyaMchAsDAtYsMfaTg"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Request A Call"
          data-height="692"
          data-layout-iframe-id="inline-SRpyaMchAsDAtYsMfaTg"
          data-form-id="SRpyaMchAsDAtYsMfaTg"
          title="Request A Call"
        ></iframe>
        <script src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
      </div>
    </section>
    <!-- ===================== CONTACT INFO STRIP ===================== -->
    <section class="bg-gray-50 py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <!-- Address -->
          <div class="bg-white rounded-xl p-8 shadow-sm text-center">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-2">Address</h3>
            <p class="text-gray-800 leading-relaxed">
              204 Academy St # 3251<br />
              Cary, NC 27519
            </p>
          </div>

          <!-- Phone -->
          <div class="bg-white rounded-xl p-8 shadow-sm text-center">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-2">Phone</h3>
            <a
              href="tel:+18888003744"
              class="text-gray-800 hover:text-red-600 transition-colors font-medium"
            >
              1-888-800-3744
            </a>
          </div>

          <!-- Email -->
          <div class="bg-white rounded-xl p-8 shadow-sm text-center">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-2">Email</h3>
            <a
              href="mailto:hello@spiritmedia.us"
              class="text-gray-800 hover:text-red-600 transition-colors font-medium"
            >
              hello@spiritmedia.us
            </a>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
