---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

let sitePhone = '1-888-800-3744';
try {
	const s = await sanityClient.fetch('*[_type == "siteSettings"][0]{ phone }');
	if (s?.phone) sitePhone = s.phone;
} catch (e) {}
---

<Layout
	title="Free Publishing & Marketing Consultation — Spirit Media"
	description="Ready to publish your book or grow your platform? Schedule a free consultation with Spirit Media Publishing and discover how we can help you reach the nations."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/f67376ca3cbad336ac9ed54977f72d3f9917397b-1200x630.jpg?w=1200&h=630&fit=crop&auto=format"
>
	<Fragment slot="head">
		<meta name="keywords" content="contact Spirit Media Publishing, free publishing consultation, schedule a call Spirit Media, Christian book publishing consultation, publish my book, Spirit Media contact" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ContactPage",
			"name": "Schedule a Free Consultation — Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com/contact",
			"description": "Request a free publishing and marketing consultation with Spirit Media Publishing.",
			"provider": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com", "telephone": "", "email": "info@spiritmediapublishing.com" }
		})}></script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Contact Us</p>
						<h1 class="type-hero text-ink-soft">Ready to Schedule a<br /><span class="text-red">FREE Consultation Call?</span></h1>
						<p class="mt-6 text-2xl font-bold text-ink-soft"><a href={"tel:+1" + sitePhone.replace(/[^0-9]/g, "")} class="hover:text-red transition-colors">{sitePhone}</a></p>
						<p class="mt-4 text-stone-600 leading-relaxed max-w-xl">Otherwise, request a call back. Please use this form to inquire about our publishing and marketing services only. No response will be given for employment or sales inquiries. Thank you!</p>
					</div>
					<div class="hidden lg:flex items-center justify-center" aria-hidden="true" data-animate="zoom-in">
						<img src="https://cdn.sanity.io/images/pmowd8uo/production/7833f28378750a49205269eb39a6c2c19f31b92d-1058x394.png?w=1058&fit=max&auto=format" alt="Books published by Spirit Media" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- FORM -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto" data-animate="fade-up">
				<iframe
					src="https://mail.spiritmediaone.com/widget/form/SRpyaMchAsDAtYsMfaTg"
					style="width:100%; height:700px; border:none; border-radius:3px;"
					id="inline-SRpyaMchAsDAtYsMfaTg"
					data-layout="{'id':'INLINE'}"
					data-trigger-type="alwaysShow"
					data-trigger-value=""
					data-activation-type="alwaysActivated"
					data-activation-value=""
					data-deactivation-type="neverDeactivate"
					data-deactivation-value=""
					data-form-name="Request A Call"
					data-height="692"
					data-layout-iframe-id="inline-SRpyaMchAsDAtYsMfaTg"
					data-form-id="SRpyaMchAsDAtYsMfaTg"
					title="Request A Call"
				></iframe>
				<script is:inline src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
			</div>
		</section>

	</main>
</Layout>
