---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Publishing Services — Spirit Media Publishing"
	description="From eBook to global distribution — Spirit Media Publishing helps Kingdom Messengers publish, print, and distribute their God-given message."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Publishing Services</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Get Your Book Published and Into the Hands of Nations
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed mb-8">
					From a simple eBook to full print distribution and translation into multiple languages —
					we make it easy, affordable, and Kingdom-focused.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/contact" class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
						Get Started for $99
					</a>
					<a href="#packages" class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors">
						Explore Packages
					</a>
				</div>
			</div>
		</section>

		<!-- WHY START WITH AN EBOOK -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="max-w-3xl mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Why Start with an eBook?</h2>
					<p class="text-lg text-gray-700 leading-relaxed">
						An eBook is the fastest, most affordable way to get your God-given message into the world.
						Starting at just $99, you can publish your book on Amazon, Barnes &amp; Noble, Apple Books,
						and hundreds of other retailers worldwide.
					</p>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-gray-50 rounded-xl p-6">
						<div class="text-3xl mb-3">⚡</div>
						<h3 class="font-semibold text-gray-900 mb-2">Speed to Market</h3>
						<p class="text-sm text-gray-600 leading-relaxed">From manuscript to published in as little as 2 weeks</p>
					</div>
					<div class="bg-gray-50 rounded-xl p-6">
						<div class="text-3xl mb-3">🌍</div>
						<h3 class="font-semibold text-gray-900 mb-2">Global Distribution</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Reach readers in 195+ countries through major retail platforms</p>
					</div>
					<div class="bg-gray-50 rounded-xl p-6">
						<div class="text-3xl mb-3">💡</div>
						<h3 class="font-semibold text-gray-900 mb-2">Low Investment</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Start for as little as $99 — no upfront printing costs</p>
					</div>
					<div class="bg-gray-50 rounded-xl p-6">
						<div class="text-3xl mb-3">✅</div>
						<h3 class="font-semibold text-gray-900 mb-2">Proof of Concept</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Test your message before investing in print</p>
					</div>
				</div>
			</div>
		</section>

		<!-- OUR PUBLISHING PACKAGES -->
		<section id="packages" class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Our Publishing Packages</h2>
					<p class="text-gray-600 leading-relaxed">
						Every package includes professional editing review, cover design guidance, and distribution setup.
					</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">

					<!-- eBook Starter -->
					<div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col">
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-2">eBook Starter</h3>
						<p class="text-3xl font-bold text-red-600 mb-6">$99</p>
						<ul class="space-y-3 text-sm text-gray-700 mb-8 flex-1">
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> eBook formatting</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Amazon KDP setup</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Distribution to 40+ retailers</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> ISBN assignment</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Author page setup</li>
						</ul>
						<a href="/contact" class="block text-center bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
							Get Started
						</a>
					</div>

					<!-- Complete Book Package -->
					<div class="bg-white rounded-2xl border-2 border-red-600 p-8 flex flex-col relative">
						<div class="absolute -top-4 left-1/2 -translate-x-1/2">
							<span class="bg-red-600 text-white text-xs font-semibold px-4 py-1 rounded-full">Most Popular</span>
						</div>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-2">Complete Book Package</h3>
						<p class="text-lg font-semibold text-gray-600 mb-6">Contact for Pricing</p>
						<ul class="space-y-3 text-sm text-gray-700 mb-8 flex-1">
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Everything in eBook Starter</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Print-on-demand setup</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Audiobook production</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Full interior layout</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Advanced distribution</li>
						</ul>
						<a href="/contact" class="block text-center bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
							Request a Quote
						</a>
					</div>

					<!-- Translation Package -->
					<div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col">
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-2">Translation Package</h3>
						<p class="text-lg font-semibold text-gray-600 mb-6">Contact for Pricing</p>
						<ul class="space-y-3 text-sm text-gray-700 mb-8 flex-1">
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Everything in Complete Package</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Translation into 1–3 languages</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Cultural adaptation review</li>
							<li class="flex items-start gap-2"><span class="text-red-600 font-bold mt-0.5">✓</span> Multi-language distribution</li>
						</ul>
						<a href="/contact" class="block text-center bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
							Request a Quote
						</a>
					</div>

				</div>
			</div>
		</section>

		<!-- THE PUBLISHING JOURNEY -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">Your Publishing Journey</h2>
				<ol class="space-y-8">
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">1</div>
						<div>
							<h3 class="font-semibold text-gray-900 mb-1">Submit Your Manuscript</h3>
							<p class="text-gray-600 leading-relaxed">Share your draft (even if rough). We work with first-time authors.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">2</div>
						<div>
							<h3 class="font-semibold text-gray-900 mb-1">Editing &amp; Review</h3>
							<p class="text-gray-600 leading-relaxed">Our team reviews for clarity, flow, and impact.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">3</div>
						<div>
							<h3 class="font-semibold text-gray-900 mb-1">Cover &amp; Interior Design</h3>
							<p class="text-gray-600 leading-relaxed">Professional design that reflects your message and brand.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">4</div>
						<div>
							<h3 class="font-semibold text-gray-900 mb-1">Distribution Setup</h3>
							<p class="text-gray-600 leading-relaxed">We set you up on Amazon, Barnes &amp; Noble, Apple Books, and 40+ more.</p>
						</div>
					</li>
					<li class="flex gap-6">
						<div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">5</div>
						<div>
							<h3 class="font-semibold text-gray-900 mb-1">Launch &amp; Marketing</h3>
							<p class="text-gray-600 leading-relaxed">We help you announce your book to the world.</p>
						</div>
					</li>
				</ol>
			</div>
		</section>

		<!-- BEYOND THE BOOK -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">Beyond the Book</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-white rounded-xl p-8">
						<div class="text-3xl mb-4">🤝</div>
						<h3 class="font-semibold text-gray-900 mb-3 text-lg">Crowdfunding Support</h3>
						<p class="text-gray-600 leading-relaxed text-sm">
							Need funding to publish your next project? We help Kingdom authors raise support
							from their community before the book even prints.
						</p>
					</div>
					<div class="bg-white rounded-xl p-8">
						<div class="text-3xl mb-4">🎙️</div>
						<h3 class="font-semibold text-gray-900 mb-3 text-lg">Audiobook Production</h3>
						<p class="text-gray-600 leading-relaxed text-sm">
							Meet your audience where they are. Audiobooks are the fastest-growing segment
							in publishing.
						</p>
					</div>
					<div class="bg-white rounded-xl p-8">
						<div class="text-3xl mb-4">⚡</div>
						<h3 class="font-semibold text-gray-900 mb-3 text-lg">Express Books</h3>
						<p class="text-gray-600 leading-relaxed text-sm mb-4">
							Need a book published in 30 days? Ask about our Express Books format —
							perfect for conference speakers and ministry leaders.
						</p>
						<a href="/express-books" class="text-red-600 font-semibold text-sm hover:underline">Learn More →</a>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA BANNER -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Your Message Deserves to Be Published</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Let's talk about how Spirit Media Publishing can help you reach the nations.
				</p>
				<a href="/contact" class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors">
					Request a Free Consultation
				</a>
			</div>
		</section>

	</main>
</Layout>
