---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Publishing Services — Spirit Media"
	description="We write, edit, publish, and market your book in paperback, hardback, digital, and audiobook — everywhere books are sold worldwide."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">
					Publishing Services
				</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Publishing with Spirit Media
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed mb-3">
					Your message deserves to reach the nations. We write, edit, publish, and market your
					book — in paperback, hardback, digital, and audiobook — everywhere books are sold
					worldwide.
				</p>
				<p class="text-red-200 font-semibold mb-8">
					Published in 5 months. Accelerated paperbacks in 14 days.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="https://spiritmedia.us/request-a-call/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors"
					>
						Request a Call
					</a>
					<a
						href="#packages"
						class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
					>
						View Packages
					</a>
				</div>
			</div>
		</section>

		<!-- OUR SERVICES -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Our Services</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Write Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							80% of adults want to write a book. Only 2% do. Our Angel Writing service bridges
							the gap. Meet with your writer one hour per week via Zoom. They write 3–4 hours
							weekly in your voice. Your book is outlined within the first month and the manuscript
							is complete in as few as 90 days. <strong>Your story. Your words. Our hands.</strong>
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Edit Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Our editors polish your manuscript to the Chicago Manual of Style —
							professional, clear, and error-free.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Publish Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							We publish in paperback, hardback, digital, and audiobook with global distribution
							through Amazon, IngramSpark, libraries, and eBook stores worldwide. All publishing
							includes a <strong>50/50 royalty split</strong> unless otherwise selected.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Republish Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Need to re-release, update, or redesign an existing title? We handle the full process.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">
							Publish Your Children's Book
						</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Fully illustrated children's books connecting your story with young readers everywhere.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">White Label Publishing</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Want to publish under your own label? We make it happen.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Translate Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							We translate into the top 20 spoken languages — reaching over 75% of the human race.
						</p>
					</div>

					<div class="bg-gray-50 rounded-xl p-6">
						<h3 class="font-serif text-lg font-bold text-gray-900 mb-2">Market Your Book</h3>
						<p class="text-gray-600 text-sm leading-relaxed">
							Every book we publish receives our full base marketing. Because publishing without
							marketing is just printing.
						</p>
					</div>

				</div>
			</div>
		</section>

		<!-- PUBLISHING PACKAGES -->
		<section id="packages" class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Publishing Packages</h2>
				</div>
				<div class="overflow-x-auto">
					<table class="w-full bg-white rounded-2xl shadow-sm overflow-hidden">
						<thead>
							<tr class="bg-red-600 text-white">
								<th class="text-left px-6 py-4 font-semibold text-sm">Package</th>
								<th class="text-left px-6 py-4 font-semibold text-sm">What's Included</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-gray-100">
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 font-semibold text-gray-900 text-sm whitespace-nowrap">
									eBook — Express Books™
								</td>
								<td class="px-6 py-4 text-gray-600 text-sm">
									eBook + PDF (up to 20K words), professional editing, global distribution
								</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 font-semibold text-gray-900 text-sm whitespace-nowrap">
									eBook — Full Size
								</td>
								<td class="px-6 py-4 text-gray-600 text-sm">
									eBook + PDF (up to 50K words), professional editing, global distribution
								</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 font-semibold text-gray-900 text-sm whitespace-nowrap">
									Print — Express Books™ / Children's
								</td>
								<td class="px-6 py-4 text-gray-600 text-sm">
									Paperback + eBook + PDF (up to 20K words), professional editing, global
									distribution
								</td>
							</tr>
							<tr class="hover:bg-gray-50 transition-colors">
								<td class="px-6 py-4 font-semibold text-gray-900 text-sm whitespace-nowrap">
									Print — Full Size
								</td>
								<td class="px-6 py-4 text-gray-600 text-sm">
									Paperback + eBook + PDF (up to 50K words), professional editing, global
									distribution
								</td>
							</tr>
							<tr class="bg-red-50">
								<td class="px-6 py-4 font-semibold text-red-700 text-sm" colspan="2">
									Add-Ons (available after paperback production): Hardback · Audiobook · Foreign
									Translation · Foreign Language Publishing
								</td>
							</tr>
						</tbody>
					</table>
				</div>
				<div class="text-center mt-8">
					<a
						href="https://spiritmedia.us/request-a-call/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
					>
						Request a Call to Discuss Packages
					</a>
				</div>
			</div>
		</section>

		<!-- EVERY BOOK GETS BASE MARKETING -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div>
						<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">
							Every Book Gets Our Base Marketing
						</h2>
						<p class="text-gray-600 leading-relaxed mb-6">
							We don't just publish — we promote. Every title receives:
						</p>
						<ul class="space-y-3">
							{
								[
									'Listing in Spirit Media\'s online catalog',
									'Featured in our book fair',
									'Featured on our podcast',
									'Included in our email and social media marketing',
									'Exposure to Christian bookstores',
									'Partnership in securing Amazon reviews',
									'Coming Soon: PDF download in The Believer\'s Library — our global digital media center',
								].map((item) => (
									<li class="flex items-start gap-3 text-gray-700 text-sm">
										<span class="text-red-600 font-bold mt-0.5 flex-shrink-0">✓</span>
										{item}
									</li>
								))
							}
						</ul>
					</div>
					<div class="bg-gray-50 rounded-2xl p-8 text-center">
						<div class="text-5xl mb-4">📕</div>
						<h3 class="font-serif text-xl font-bold text-gray-900 mb-3">
							Free Copy for Every Author
						</h3>
						<p class="text-gray-600 text-sm leading-relaxed mb-6">
							Our CEO Kevin White poured everything he knows about book marketing into
							<em>The Ultimate Book Marketing Guide</em> — a collection of proven tactics to
							increase book sales. Every Spirit Media author receives a free copy.
						</p>
						<a
							href="https://spiritmedia.us/free-ultimate-book-marketing-guide/"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors text-sm"
						>
							Get the Free Guide →
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- WHY START WITH AN EBOOK -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Why Start with an eBook?</h2>
				<p class="text-gray-600 leading-relaxed mb-8">
					If you can publish print now, do it. Otherwise, consider starting digital:
				</p>
				<ol class="space-y-4">
					{
						[
							'Lower investment — $300–$600 instead of $3,000+',
							'Faster — 3 months instead of 5',
							'Massive audience — 1 billion eBook users worldwide',
							'Fastest growing segment in publishing',
							'Future-ready — AI-narrated eBooks are replacing traditional audiobooks',
							'Flexible — upgrade to print anytime by paying the difference',
							'Smart stewardship — prove the impact at $300 before investing $3,000',
						].map((item, i) => (
							<li class="flex items-start gap-4">
								<span class="flex-shrink-0 w-8 h-8 rounded-full bg-red-600 text-white flex items-center justify-center text-sm font-bold">
									{i + 1}
								</span>
								<span class="text-gray-700 pt-1">{item}</span>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<!-- CROWDFUNDING -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-4xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">
					Need Help Funding Your Book?
				</h2>
				<p class="text-gray-700 leading-relaxed mb-4">
					Spirit Media was born from crowdfunding. Our CEO Kevin White raised $25,000 on
					Kickstarter for his first book — over 100 supporters are listed in the back of
					<em>Audacious Generosity.</em>
				</p>
				<p class="text-gray-700 leading-relaxed mb-6">
					That story launched Spirit Media Charities, an IRS-recognized 501(c)(3) nonprofit.
					Authors use our crowdfunding platform at
					<a href="https://smgives.org" target="_blank" rel="noopener noreferrer" class="text-red-600 hover:underline font-medium">smgives.org</a>
					to invite family and friends to bring their book to life. 100% of donations go toward the
					author's project. All gifts are tax-deductible.
				</p>
				<div class="bg-gray-50 rounded-xl p-6">
					<p class="text-sm font-semibold text-gray-700 mb-3">Fundraising examples:</p>
					<div class="flex flex-wrap gap-3">
						{
							[
								'https://givebutter.com/nicolebranclark',
								'https://givebutter.com/sparklebook',
								'https://givebutter.com/frankjamesbook',
								'https://givebutter.com/beetle',
							].map((url) => (
								<a
									href={url}
									target="_blank"
									rel="noopener noreferrer"
									class="text-red-600 hover:underline text-sm font-medium"
								>
									{url.replace('https://givebutter.com/', 'givebutter.com/')}
								</a>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- TRANSLATION -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">
						Translation: 20 Languages. 75% of Humanity.
					</h2>
					<p class="text-gray-600 leading-relaxed">
						We translate books into the world's most spoken languages:
					</p>
				</div>
				<div class="flex flex-wrap gap-3 justify-center">
					{
						[
							'English (1.5B)',
							'Mandarin (1.1B)',
							'Hindi (600M)',
							'Spanish (550M)',
							'French (280M)',
							'Arabic (274M)',
							'Bengali (272M)',
							'Russian (258M)',
							'Portuguese (257M)',
							'Urdu (231M)',
							'Indonesian (199M)',
							'German (135M)',
							'Japanese (125M)',
							'Nigerian Pidgin (121M)',
							'Marathi (99M)',
							'Telugu (96M)',
							'Turkish (88M)',
							'Tamil (86M)',
							'Yue Chinese (86M)',
							'Vietnamese (85M)',
						].map((lang) => (
							<span class="inline-block bg-white border border-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full shadow-sm">
								{lang}
							</span>
						))
					}
				</div>
			</div>
		</section>

		<!-- BEYOND BOOKS -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">Beyond Books</h2>
				<p class="text-gray-700 leading-relaxed mb-6">
					We believe publishing is anything with a "publish" button. That's why Spirit Media also
					publishes <strong>websites, articles, social media, video, live broadcasts, podcasts, and
					more.</strong> These services can be bundled with any publishing or marketing agreement.
				</p>
				<a
					href="/marketing"
					class="inline-block border-2 border-red-600 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors"
				>
					See Our Full Marketing Services →
				</a>
			</div>
		</section>

		<!-- CTA BANNER -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">
					Your Message Deserves to Reach the Nations
				</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Let's talk about how Spirit Media Publishing can help you publish, market, and multiply
					your message.
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Request a Free Consultation
				</a>
			</div>
		</section>

	</main>
</Layout>
