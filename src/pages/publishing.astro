---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Publishing Services — Spirit Media"
	description="We write, edit, publish, and market your book in paperback, hardback, digital, and audiobook — everywhere books are sold worldwide."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Publishing</p>
						<h1 class="type-hero text-ink-soft">
							Publishing with
							<br />
							<span class="text-red">Spirit Media</span>
						</h1>
						<p class="mt-6 type-body-lg text-stone-700 max-w-xl">Your message deserves to reach the nations. We write, edit, publish, and market your book — in paperback, hardback, digital, and audiobook — everywhere books are sold worldwide.</p>
						<p class="mt-3 type-body font-semibold text-ink-soft">Published in 5 months. Accelerated paperbacks in 14 days.</p>
						<div class="mt-8 flex flex-wrap gap-4">
							<a href="/contact" class="rounded-md bg-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Request a Call →</a>
							<a href="/marketing" class="rounded-md border-2 border-red-600 bg-stone-50 px-6 py-3 text-sm font-semibold text-red transition-colors hover:bg-red-wash">View Marketing Services</a>
						</div>
					</div>
					<div class="hidden lg:flex items-center justify-center" data-animate="zoom-in">
						<img src="/book-collage2.png" alt="Books published by Spirit Media" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- SERVICES -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Our Services</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">Everything You Need to <span class="text-red">Publish</span></h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					{[
						{ title: 'Write Your Book', body: '80% of adults want to write a book. Only 2% do. Our Angel Writing service bridges the gap. Meet with your writer one hour per week via Zoom. They write 3–4 hours weekly in your voice. Book complete in as few as 90 days.' },
						{ title: 'Edit Your Book', body: 'Our editors polish your manuscript to the Chicago Manual of Style — professional, clear, and error-free.' },
						{ title: 'Publish Your Book', body: 'We publish in paperback, hardback, digital, and audiobook with global distribution through Amazon, IngramSpark, libraries, and eBook stores worldwide. All publishing includes a 50/50 royalty split.' },
						{ title: 'Republish Your Book', body: 'Need to re-release, update, or redesign an existing title? We handle the full process.' },
						{ title: "Publish Your Children's Book", body: "Fully illustrated children's books connecting your story with young readers everywhere." },
						{ title: 'White Label Publishing', body: 'Want to publish under your own label? We make it happen.' },
						{ title: 'Translate Your Book', body: 'We translate into the top 20 spoken languages — reaching over 75% of the human race.' },
						{ title: 'Market Your Book', body: 'Every book we publish receives our full base marketing. Because publishing without marketing is just printing.' },
					].map(({ title, body }, i) => (
						<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow" data-animate="fade-up" data-delay={String((i % 4) + 1)}>
							<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
								<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
							</div>
							<h3 class="type-card-subheading mb-3">{title}</h3>
							<p class="type-body-sm text-stone-700">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- PACKAGES -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Packages</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">Publishing Packages</h2>
				</div>
				<div class="overflow-x-auto" data-animate="fade-up" data-delay="2">
					<table class="w-full text-left type-body-sm">
						<thead><tr class="border-b-2 border-red-600"><th class="py-4 pr-4 font-semibold text-ink-soft">Package</th><th class="py-4 px-4 font-semibold text-ink-soft">What's Included</th></tr></thead>
						<tbody class="divide-y divide-stone-200">
							<tr class="bg-stone-50"><td class="py-4 pr-4 font-semibold text-ink-soft">eBook — Express Books™</td><td class="py-4 px-4 text-stone-600">eBook + PDF (up to 20K words), professional editing, global distribution</td></tr>
							<tr class="bg-stone-100"><td class="py-4 pr-4 font-semibold text-ink-soft">eBook — Full Size</td><td class="py-4 px-4 text-stone-600">eBook + PDF (up to 50K words), professional editing, global distribution</td></tr>
							<tr class="bg-stone-50"><td class="py-4 pr-4 font-semibold text-ink-soft">Print — Express Books™ / Children's</td><td class="py-4 px-4 text-stone-600">Paperback + eBook + PDF (up to 20K words), professional editing, global distribution</td></tr>
							<tr class="bg-stone-100"><td class="py-4 pr-4 font-semibold text-ink-soft">Print — Full Size</td><td class="py-4 px-4 text-stone-600">Paperback + eBook + PDF (up to 50K words), professional editing, global distribution</td></tr>
						</tbody>
					</table>
				</div>
				<p class="mt-6 type-body-sm text-stone-500" data-animate="fade-up" data-delay="3"><strong class="text-stone-700">Add-Ons:</strong> Hardback · Audiobook · Foreign Translation · Foreign Language Publishing</p>
			</div>
		</section>

		<!-- BASE MARKETING -->
		<section class="bg-red py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Included</p>
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-6" data-animate="fade-up" data-delay="1">Every Book Gets Our Base Marketing</h2>
				<p class="text-stone-200 type-body-lg mb-8 max-w-2xl mx-auto" data-animate="fade-up" data-delay="2">We don't just publish — we promote. Every title receives:</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto text-left" data-animate="fade-up" data-delay="3">
					{["Listing in Spirit Media's online catalog", 'Featured in our book fair', 'Featured on our podcast', 'Included in our email and social media marketing', 'Exposure to Christian bookstores', 'Partnership in securing Amazon reviews', "Coming Soon: PDF download in The Believer's Library"].map((item) => (
						<div class="flex items-start gap-3">
							<svg class="h-5 w-5 shrink-0 text-white mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
							<span class="text-stone-200 text-sm">{item}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FREE GUIDE -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<img src="/Ultimate Book Marketing Guide - Mock Up.png" alt="The Ultimate Book Marketing Guide by Spirit Media" class="rounded-2xl w-full object-cover" data-animate="slide-left" />
					<div data-animate="slide-right">
						<p class="eyebrow eyebrow-red mb-3">Free for Every Author</p>
						<h2 class="type-section-heading text-ink-soft mb-4">The Ultimate Book Marketing Guide</h2>
						<p class="text-stone-600 leading-relaxed mb-6">Our CEO Kevin White poured everything he knows about book marketing into The Ultimate Book Marketing Guide — a collection of proven tactics to increase book sales. Every Spirit Media author receives a free copy.</p>
						<a href="https://spiritmedia.us/free-ultimate-book-marketing-guide/" target="_blank" rel="noopener noreferrer" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Get Your Free Copy →</a>
					</div>
				</div>
			</div>
		</section>

		<!-- EBOOK -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<div data-animate="slide-left">
						<p class="eyebrow eyebrow-red mb-3">Smart Start</p>
						<h2 class="type-section-heading text-ink-soft mb-4">Why Start with an eBook?</h2>
						<p class="type-body-lg text-stone-700">If you can publish print now, do it. Otherwise, consider starting digital:</p>
					</div>
					<div class="space-y-4" data-animate="slide-right">
						{['Lower investment — $300–$600 instead of $3,000+', 'Faster — 3 months instead of 5', 'Massive audience — 1 billion eBook users worldwide', 'Fastest growing segment in publishing', 'Future-ready — AI-narrated eBooks are replacing traditional audiobooks', 'Flexible — upgrade to print anytime', 'Smart stewardship — prove the impact at $300 before investing $3,000'].map((item, i) => (
							<div class="flex items-start gap-3">
								<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-red text-white text-xs font-bold">{i + 1}</span>
								<p class="text-stone-700 text-sm leading-relaxed pt-1">{item}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- CHILDREN'S BOOKS BANNER -->
		<section class="bg-red-wash py-16 px-6 lg:px-8">
			<div class="max-w-5xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-6" data-animate="fade-up">Children's Books</p>
				<img src="/childrens-books-banner.png" alt="Spirit Media Children's Book Collection" class="w-full" data-animate="fade-in" />
				<p class="type-body-lg text-stone-700 mt-8 max-w-3xl mx-auto" data-animate="fade-up">
					Our children's book publishing package includes professional editing (10,000 words or less) and ALL illustrations — published in paperback, eBook, and PDF with global distribution (Amazon, IngramSpark, libraries, eBook stores).
				</p>
				<p class="mt-4 text-stone-500 tracking-widest uppercase font-semibold" data-animate="fade-up" data-delay="1">
					picture books &nbsp;·&nbsp; early readers &nbsp;·&nbsp; chapter books
				</p>
				<div class="mt-8 flex flex-wrap justify-center gap-4" data-animate="fade-up" data-delay="2">
					<a href="/contact" class="rounded-md bg-red px-6 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Request a Call →</a>
					<a href="/marketing" class="rounded-md border-2 border-red bg-stone-50 px-6 py-3 font-semibold text-red transition-colors hover:bg-red-wash">View Marketing Services</a>
				</div>
			</div>
		</section>

		<!-- CROWDFUNDING -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Funding</p>
				<h2 class="type-section-heading text-ink-soft mb-6" data-animate="fade-up" data-delay="1">Need Help Funding Your Book?</h2>
				<p class="text-stone-600 type-body-lg mb-6" data-animate="fade-up" data-delay="2">Spirit Media was born from crowdfunding. Our CEO Kevin White raised $25,000 on Kickstarter for his first book — over 100 supporters are listed in the back of Audacious Generosity.</p>
				<p class="text-stone-600 leading-relaxed mb-8" data-animate="fade-up" data-delay="3">That story launched Spirit Media Charities, an IRS-recognized 501(c)(3) nonprofit. Authors use our crowdfunding platform at smgives.org to invite family and friends to bring their book to life. 100% of donations go toward the author's project. All gifts are tax-deductible.</p>
				<a href="/contact" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm" data-animate="fade-up" data-delay="4">Learn More About Funding →</a>
			</div>
		</section>

		<!-- TRANSLATION -->
		<section class="bg-ink-soft text-white py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Translation</p>
				<h2 class="font-serif text-3xl font-bold mb-6 text-white" data-animate="fade-up">20 Languages. 75% of Humanity.</h2>
				<p class="text-stone-300 leading-relaxed mb-8" data-animate="fade-up" data-delay="2">We translate books into the world's most spoken languages:</p>
				<div class="flex flex-wrap justify-center gap-3" data-animate="fade-in" data-delay="3">
					{['English (1.5B)', 'Mandarin (1.1B)', 'Hindi (600M)', 'Spanish (550M)', 'French (280M)', 'Arabic (274M)', 'Bengali (272M)', 'Russian (258M)', 'Portuguese (257M)', 'Urdu (231M)', 'Indonesian (199M)', 'German (135M)', 'Japanese (125M)', 'Nigerian Pidgin (121M)', 'Marathi (99M)', 'Telugu (96M)', 'Turkish (88M)', 'Tamil (86M)', 'Yue Chinese (86M)', 'Vietnamese (85M)'].map((lang) => (
						<span class="bg-stone-50/10 text-sm px-3 py-1.5 rounded-full">{lang}</span>
					))}
				</div>
				<img src="/Translations-transparent.png" alt="Spirit Media book translations across languages" class="w-full mt-10 rounded-xl" data-animate="fade-in" data-delay="4" />
			</div>
		</section>

		<!-- BEYOND BOOKS -->
		<section class="bg-stone-50 py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Beyond Books</p>
				<h2 class="type-section-heading text-ink-soft mb-6" data-animate="fade-up" data-delay="1">Publishing Is Anything with a "Publish" Button</h2>
				<p class="text-stone-600 type-body-lg mb-10" data-animate="fade-up" data-delay="2">That's why Spirit Media also helps authors build their full platform — not just their book.</p>
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10" data-animate="fade-in" data-delay="3">
					{[
						{ label: 'Websites', icon: '🌐' },
						{ label: 'Articles', icon: '📝' },
						{ label: 'Social Media', icon: '📱' },
						{ label: 'Video', icon: '🎬' },
						{ label: 'Podcasts', icon: '🎙️' },
						{ label: 'Live Broadcasts', icon: '📡' },
					].map(({ label, icon }) => (
						<div class="bg-stone-100 rounded-xl p-4 flex flex-col items-center gap-2 border border-stone-200">
							<span class="text-2xl">{icon}</span>
							<span class="text-sm font-semibold text-ink-soft">{label}</span>
						</div>
					))}
				</div>
				<a href="/marketing" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm" data-animate="fade-up" data-delay="4">See Our Full Marketing Services →</a>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Ready to publish your message to the nations?</h2>
				<p class="text-stone-200 type-body-lg mb-8" data-animate="fade-up" data-delay="1">Let's talk about your vision. Our team will walk you through every option and help you find the right path forward.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Free Consultation</a>
			</div>
		</section>

	</main>
</Layout>
