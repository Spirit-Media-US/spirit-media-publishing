<script>
	// Intersection observer for data-animate (SMP pattern)
	function initAiWebsiteAnimations() {
		const io = new IntersectionObserver((entries) => {
			entries.forEach((e) => {
				if (e.isIntersecting) {
					e.target.classList.add('is-visible');
					io.unobserve(e.target);
				}
			});
		}, { threshold: 0.1 });
		document.querySelectorAll('[data-animate]').forEach((el) => io.observe(el));

		// hero-stagger
		document.querySelectorAll('.hero-stagger').forEach((el) => el.classList.add('loaded'));
	}
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAiWebsiteAnimations);
	} else {
		initAiWebsiteAnimations();
	}
</script>
