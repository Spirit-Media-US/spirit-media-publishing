---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Identity | Kingdom Messenger Collective — heart → message → movement"
	description="Join Kevin White's flagship 3+ year Christian author coaching & publishing program. Walk from heart to message to movement — publishing, platform, and global impact included."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/ffe76698b677c2a7f0d5722adc843c5776c3ee2b-6000x4000.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Christian author coaching, Christian publishing program, Kingdom Messenger, Spirit Media, Kevin White, Christian book publishing, ministry publishing, Christian leadership coaching, book publishing coaching, faith-based publishing" />
		<meta name="robots" content="index, follow" />
		<meta property="og:site_name" content="Spirit Media Publishing" />
		<meta property="og:locale" content="en_US" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Course",
			"name": "Kingdom Messenger Collective",
			"description": "A 3+ year flagship Christian author coaching and publishing program walking leaders from heart to message to movement.",
			"provider": {
				"@type": "Organization",
				"name": "Spirit Media Publishing",
				"url": "https://spiritmediapublishing.com"
			},
			"instructor": {
				"@type": "Person",
				"name": "Kevin White",
				"jobTitle": "Founder & CEO",
				"worksFor": { "@type": "Organization", "name": "Spirit Media Publishing" }
			},
			"url": "https://spiritmediapublishing.com/kingdom-messenger-collective",
			"image": "https://spiritmediapublishing.com/kingdommessengers.jpg",
			"educationalLevel": "Advanced",
			"teaches": "Christian authorship, book publishing, ministry platform building, global movement leadership"
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-16 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Identity — Kingdom Messenger Collective</p>
						<h1 class="type-hero">From Message to<br /><span class="text-red">Movement</span></h1>
						<p class="mt-6 type-body-lg max-w-xl italic">"The Holy Spirit empowers you to be my messenger, telling people about me everywhere — to those close to you, those different from you, and to the remotest places on earth!"</p>
						<p class="mt-2 text-sm font-semibold text-red">— Acts 1:8 (FHB)</p>
					</div>
					<!-- Mobile hero image -->
					<div class="lg:hidden rounded-2xl overflow-hidden" data-animate="fade-in">
						<img src="https://cdn.sanity.io/images/pmowd8uo/production/ffe76698b677c2a7f0d5722adc843c5776c3ee2b-6000x4000.jpg" alt="Books published by Kingdom Messengers" class="w-full object-cover max-h-64" />
					</div>
					<!-- Desktop hero image -->
					<div class="hidden lg:flex items-center justify-center" data-animate="zoom-in">
						<img src="https://cdn.sanity.io/images/pmowd8uo/production/ffe76698b677c2a7f0d5722adc843c5776c3ee2b-6000x4000.jpg" alt="Books published by Kingdom Messengers" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- HEART → MESSAGE → MOVEMENT -->
		<section class="bg-red px-6 py-12 lg:px-8">
			<div class="mx-auto max-w-7xl text-center" data-animate="fade-up">
				<p class="font-serif text-4xl sm:text-5xl font-bold text-white">heart → message → movement</p>
			</div>
		</section>

		<!-- ARE YOU A KINGDOM MESSENGER + FROM MESSAGE TO MOVEMENT -->
		<section class="bg-stone-100 px-6 lg:px-8">
			<div class="max-w-5xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
					<!-- LEFT: Photo spanning both text blocks -->
					<div class="hidden lg:flex justify-end items-stretch" data-animate="slide-left">
						<img
							src="https://cdn.sanity.io/images/pmowd8uo/production/835f0b7a967793427b04315ab9b926c420368d01-800x2155.jpg"
							alt="Kingdom Messenger"
							class="w-1/2 h-full object-cover rounded-2xl mt-8 ml-auto"
						/>
					</div>
					<!-- RIGHT: Both text sections stacked -->
					<div class="flex flex-col justify-center">
						<div class="py-10 lg:py-16 border-b border-stone-300">
							<h2 class="type-section-heading mb-6" data-animate="fade-up">Are You a Kingdom Messenger?</h2>
							<p class="type-body-lg text-stone-700 leading-relaxed mb-6" data-animate="fade-up" data-delay="1">You carry a message from God that has been refined through years of prayer, crushing, and surrender. You've seen enough fruit to know it has power to transform lives. But you don't just see a message — you see a movement. It starts with identity — knowing who the Father says you are.</p>
							<p class="type-body-lg text-stone-700 leading-relaxed font-semibold" data-animate="fade-up" data-delay="2">The question is: how do you move from message to movement?</p>
						</div>
						<div class="py-16">
							<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">The Program</p>
							<h2 class="type-section-heading mb-6" data-animate="fade-up" data-delay="1">From Message to Movement</h2>
							<p class="type-body-lg text-stone-700 leading-relaxed mb-6" data-animate="fade-up" data-delay="2">When Jesus said "Come, follow me," He wasn't inviting people to hear a talk — He was inviting them into a movement. The Kingdom Messenger Collective is our flagship partnership program, designed to walk with you through a 3+ year journey from restoration to proclamation, and from message to sustainable global movement.</p>
							<p class="type-body-lg text-stone-700 leading-relaxed" data-animate="fade-up" data-delay="3">This isn't coaching. It's a covenant relationship. You bring the message. Spirit Media provides the platform, the strategy, and the team.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- MENTOR -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<div data-animate="slide-left">
						<p class="eyebrow eyebrow-red mb-3">Your Mentor</p>
						<h2 class="type-section-heading mb-6">Kevin White</h2>
						<p class="text-stone-700 leading-relaxed mb-4">Kevin White is an international bestselling author of seven books in five years. His first title, Audacious Generosity, was a bestseller in India before reaching the USA. His second book has over 2 million downloads in Nepal.</p>
						<p class="text-stone-700 leading-relaxed mb-4">Through weekly video podcasts over 7+ years, Kevin has reached audiences in 163 countries. As founder and CEO of Spirit Media, he has helped publish over 300 books for authors across the globe.</p>
						<p class="text-stone-700 leading-relaxed">For over 40 years, God has used Kevin to raise up and commission Kingdom Messengers. Now, he invites you to walk the same path.</p>
					</div>
					<img src="https://cdn.sanity.io/images/pmowd8uo/production/98cdab94c7bdf9c62947c707766a06e9f17f8d8b-3896x5159.jpg" alt="Kevin White" class="w-3/4 h-full object-cover object-top rounded-2xl" data-animate="slide-right" />
				</div>
			</div>
		</section>

		<!-- SOUL CARE -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Soul Care</p>
					<h2 class="type-section-heading" data-animate="fade-up" data-delay="1">Messenger Soul Care</h2>
					<p class="mt-4 text-stone-600 max-w-2xl mx-auto" data-animate="fade-up" data-delay="2">Every Kingdom Messenger receives personalized pastoral accompaniment:</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
					{[
						{ title: 'Weekly Private Calls', body: '30-minute sessions with Kevin White. Father-focused development through prayer, discernment, and counsel for family, business, and ministry.' },
						{ title: 'Monthly Mastermind', body: 'Iron sharpens iron. Gather with fellow Kingdom Messengers for encouragement, accountability, and shared wisdom.' },
						{ title: 'Ongoing Access', body: 'Direct connection to Kevin for advice and encouragement between sessions.' },
						{ title: 'Quarterly Reviews', body: 'Dedicated time to assess goals, celebrate progress, and chart next steps for your movement.' },
					].map(({ title, body }, i) => (
						<div class="bg-stone-100 rounded-2xl p-6 border border-stone-200" data-animate="fade-up" data-delay={String(i + 1)}>
							<h3 class="type-card-subheading mb-3">{title}</h3>
							<p class="type-body-sm">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FORMATION PATHWAY -->
		<section class="bg-ink-soft text-white py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-0">
					<p class="eyebrow eyebrow-red mb-1" data-animate="fade-up">Pathway</p>
					<h2 class="font-serif text-3xl font-bold sm:text-4xl" data-animate="fade-up" data-delay="1">The Formation Pathway</h2>
				</div>
				<img src="https://cdn.sanity.io/images/pmowd8uo/production/415c2c2af0909c84ff5a7cc33ec7618314a47346-1600x613.jpg" alt="Formation Pathway" class="w-3/4 mx-auto rounded-2xl -mt-2 mb-8" data-animate="fade-up" />
				<div class="space-y-4">
					<div class="bg-stone-50/10 rounded-2xl p-8" data-animate="fade-up" data-delay="1">
						<h3 class="font-serif text-xl font-bold text-red-soft mb-2">Phase 1 — Heart</h3>
						<p class="text-sm font-semibold text-white mb-3">Restoring the Father/Child Relationship</p>
						<p class="text-stone-300 leading-relaxed">Intimacy with Father. Identity from Father. Inheritance through Father. We prioritize His work in you — becoming the healthiest adult version of yourself through inner healing, forgiveness, freedom, and transformational prayer ministry.</p>
					</div>
					<div class="bg-stone-50/10 rounded-2xl p-8" data-animate="fade-up" data-delay="2">
						<h3 class="font-serif text-xl font-bold text-red-soft mb-2">Phase 2 — Message</h3>
						<p class="text-sm font-semibold text-white mb-3">Entering the Kingdom</p>
						<p class="text-stone-300 leading-relaxed">Discovering the Kingdom through Father's heart, through brokenness, and through community. Living God's Word with discipline, generosity, and celebration. Stepping into your role as king, priest, and minister.</p>
					</div>
					<div class="bg-stone-50/10 rounded-2xl p-8" data-animate="fade-up" data-delay="3">
						<h3 class="font-serif text-xl font-bold text-red-soft mb-2">Phase 3 — Movement</h3>
						<p class="text-sm font-semibold text-white mb-3">Doing the Stuff</p>
						<p class="text-stone-300 leading-relaxed">Restoration. Healing. Deliverance. Transformation. Taking everything the Father has built in you and releasing it through you — to the nations.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- 3-YEAR JOURNEY -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Journey</p>
					<h2 class="type-section-heading" data-animate="fade-up" data-delay="1">The 3-Year Journey</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					{[
						{ year: 'Year 1', title: 'Foundation', body: 'Build your platform, publish your first or next book, establish your initial community.' },
						{ year: 'Year 2', title: 'Growth', body: 'Multiple books, expanding audience, new revenue streams, deepening influence.' },
						{ year: 'Year 3', title: 'Movement', body: 'Train leaders, expand globally, develop legacy systems.' },
						{ year: 'Beyond', title: 'Multiplication', body: 'Generational impact. Global Kingdom influence.' },
					].map(({ year, title, body }, i) => (
						<div class="bg-stone-100 rounded-2xl p-6 border border-stone-200 text-center" data-animate="fade-up" data-delay={String(i + 1)}>
							<p class="eyebrow eyebrow-red mb-1">{year}</p>
							<h3 class="type-card-heading mb-3">{title}</h3>
							<p class="type-body-sm">{body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- INFRASTRUCTURE -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Infrastructure</p>
				<h2 class="type-section-heading mb-6" data-animate="fade-up" data-delay="1">Movement-Building Services</h2>
				<p class="text-stone-600 type-body-lg" data-animate="fade-up" data-delay="2">Spirit Media provides the full infrastructure for your movement — publishing, video production, digital presence, community platform, podcast, social media, and marketing. All done for you. You focus on your message. We build everything around it.</p>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-5xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<img
						src="https://cdn.sanity.io/images/pmowd8uo/production/c9ae43b11d8e0cd5b128e1c453d9c99beb84fad7-1600x1118.jpg"
						alt="Are You One of the 10?"
						class="w-full rounded-2xl"
						data-animate="slide-left"
					/>
					<div class="text-center lg:text-left">
						<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Are You One of the 10?</h2>
						<p class="text-stone-200 type-body-lg mb-6" data-animate="fade-up" data-delay="1">This opportunity is by invitation only, limited to 10 Kingdom Messengers per mastermind group. You may be a fit if you have:</p>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left max-w-lg mx-auto lg:mx-0 mb-8" data-animate="fade-up" data-delay="2">
							{["A passion for God's presence and glory.", 'A clear calling to global Kingdom influence.', 'A message that demands a movement.', 'Commitment to a multi-year journey.', 'A heart for reaching the nations.'].map((item) => (
								<div class="flex items-start gap-2">
									<svg class="h-5 w-5 shrink-0 text-white mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
									<span class="text-stone-200 text-sm">{item}</span>
								</div>
							))}
						</div>
						<p class="text-white font-semibold mb-4" data-animate="fade-up" data-delay="3">Request a discovery interview:</p>
						<a href="mailto:kevin@spiritmediapublishing.com" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="4">Email Kevin →</a>
					</div>
				</div>
			</div>
		</section>

	</main>
</Layout>
