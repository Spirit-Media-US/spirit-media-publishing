---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

const rawTeamMembers = await sanityClient.fetch(`
  *[_type == "teamMember"] | order(displayOrder asc) {
    name, role, "photo": photo.asset->url, objectPosition
  }
`);

const FALLBACK_TEAM = [
  { name: 'Kevin & Shelly White', role: 'CEO / Creative', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/b0440d24ed4a71d23fbed7621d490e58b5d39652-2316x3088?w=800&h=1070&fit=crop&auto=format.jpg', objectPosition: 'center 55%' },
  { name: 'Ana Marie Barrieses', role: 'HR', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/a1eb409c457f61ee03b09c447147556d59540818-720x902?w=600&h=800&fit=crop&auto=format.jpg', objectPosition: 'center 35%' },
  { name: 'David Foster', role: 'Publishing', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/4889ecdf40fc64deecd550332305b49d193f6f82-800x800?w=600&h=600&fit=crop&auto=format.jpg', objectPosition: 'center 20%' },
  { name: 'Walinda Phiri', role: 'Marketing', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/9dd5a114ff5c256f09e44751d1249df828cd1ede-1360x1360?w=1024&h=1024&fit=crop&auto=format.jpg', objectPosition: 'center center' },
  { name: 'Justin Keishing', role: 'Events', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/204e1ebdf3b4fe6138b59aee134f96b799685d44-1152x1500?w=800&h=1050&fit=crop&auto=format.jpg', objectPosition: 'center 5%' },
  { name: 'Jay Esteban', role: 'Production', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/138bfab38bff77e68a027e0cae62e6457d0ac456-582x762?w=600&h=800&fit=crop&auto=format.jpg', objectPosition: 'center 25%' },
  { name: 'Glory Suresh', role: 'Production Team', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/50ac53519f508930d956494db16d1a569979e049-273x361?w=400&h=450&fit=crop&auto=format.jpg', objectPosition: 'center center' },
  { name: 'Suresh Bob', role: 'Production Team', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/b1983a4b9a6bfb508e0cf023f0073a982c28f230-268x305?w=400&h=450&fit=crop&auto=format.jpg', objectPosition: '75% 20%' },
  { name: 'Vinit James', role: 'Production Team', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/f5642a39f86a01b4bbf5abce84f016628d540014-768x816.png?w=400&h=450&fit=crop&auto=format.jpg', objectPosition: 'center 20%' },
  { name: 'Revo Tribaco', role: 'Production Team', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/faf8fa50dcef52f75addd865c8216dfb0c2ff867-3353x3352?w=1024&h=1024&fit=crop&auto=format.jpg', objectPosition: 'center 20%' },
  { name: 'Kali White', role: 'Production Team', photo: 'https://cdn.sanity.io/images/pmowd8uo/production/0a502cb3d0b1a131a2f7f3c96b08c886b32835ba-957x957?w=800&h=800&fit=crop&auto=format.jpg', objectPosition: 'center 25%' },
];
const teamMembers = rawTeamMembers.length > 0 ? rawTeamMembers : FALLBACK_TEAM;
---

<Layout
	title="About Spirit Media Publishing — Christian Publishing & Marketing Company"
	description="Spirit Media Publishing is a global Christian publishing and marketing company empowering Kingdom Messengers to share their message in all 195 nations. Meet our team."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/02e9961fbe45d2e8dfc63a772f73719af79693f0-1200x630?w=1200&h=630&fit=crop&auto=format.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Spirit Media Publishing, about Spirit Media, Christian publishing company, Kevin White publisher, Kingdom Messenger publishing, Christian book publisher, faith-based publishing company, global Christian publisher" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "AboutPage",
			"name": "About Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com/about",
			"description": "Spirit Media Publishing is a global Christian publishing and marketing company empowering Kingdom Messengers to share their message in all 195 nations.",
			"publisher": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" }
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 pt-12 pb-10 lg:pt-14 lg:pb-14 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<div class="hero-stagger">
						<p class="text-base font-semibold uppercase tracking-widest text-red mb-4">About Us</p>
						<h1 class="type-hero text-ink-soft">
							Why We<br />
							<span class="text-red">Exist</span>
						</h1>
						<div class="mt-8 w-12 h-1 bg-red rounded-full"></div>
						<p class="mt-8 type-body-lg text-stone-700">
							Spirit Media exists because the Good News was never meant to stop at borders. Too often,
							vision in publishing has been small, limited to markets instead of nations. But our
							Heavenly Father is worthy of His story bearing fruit in all 195 nations of the earth. We
							exist to remove the barriers — the complexity, the cost, the confusion — and to equip
							Kingdom Messengers with the publishing and marketing solutions they need to multiply
							Kingdom impact and generational inheritance.
						</p>
						<p class="mt-5 type-body-lg text-stone-700">
							What began as holy frustration became a global mandate. We are here to build sustainable
							Kingdom movements, amplify our Father's heart, and see His whisper reach every tribe,
							tongue, and nation.
						</p>
						<div class="mt-8 flex gap-4 flex-wrap">
							<a href="/contact" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Partner with Us →</a>
							<a href="/publishing" class="inline-block border border-stone-400 text-ink-soft font-semibold px-6 py-3 rounded-md hover:bg-stone-100 transition-colors text-sm">Our Services →</a>
						</div>
					</div>
					<div class="flex items-start justify-center order-first lg:order-last lg:sticky lg:top-28" data-animate="zoom-in">
						<img src="https://cdn.sanity.io/images/pmowd8uo/production/d2c5e4ac450f5a25436b580c1474c320b71ce1b0-1100x1000?w=1000&h=910&fit=crop&auto=format.png" alt="A collage of books published by Spirit Media authors across multiple nations" class="w-full rounded-2xl" />
					</div>
				</div>
			</div>
		</section>

		<!-- IMPACT STATS -->
		<section class="bg-red px-6 py-12 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
					{[
						{ number: '300+', label: 'Books Published' },
						{ number: '195', label: 'Nations Mission' },
						{ number: '163', label: 'Countries Reached' },
						{ number: '40+', label: 'Years of Leadership' },
					].map(({ number, label }, i) => (
						<div data-animate="fade-up" data-delay={String(i + 1)}>
							<p class="font-serif text-4xl sm:text-5xl font-bold text-white">{number}</p>
							<p class="mt-1 text-sm font-semibold text-stone-300 uppercase tracking-widest">{label}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- KEVIN AND SHELLY WHITE -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-5xl mx-auto">
				<div class="rounded-3xl overflow-hidden border border-stone-200 shadow-sm">
					<div class="grid grid-cols-1 lg:grid-cols-2">
						<!-- Left: bio -->
						<div class="p-10 lg:p-12 flex flex-col justify-center" data-animate="slide-left">
							<p class="text-base font-semibold uppercase tracking-widest text-red mb-3">Leadership</p>
							<h2 class="type-section-heading text-ink-soft mb-6">Kevin &amp; Shelly White</h2>
							<p class="type-body-lg text-stone-700 mb-4">
								Kevin White is an author, speaker, and marketplace pastor with decades of experience
								planting churches, leading nonprofits, starting companies, and developing leaders
								worldwide. Together with his wife, Shelly, he co-founded and leads Spirit Media,
								Father's Heart Bible™, and Work On Yourself.
							</p>
							<p class="type-body-lg text-stone-700 mb-8">
								As partners in both marriage and mission for nearly forty years, they are committed to
								empowering Kingdom Messengers. They live in North Carolina with their family.
							</p>
							<div class="flex gap-3 flex-wrap">
								<a href="/contact" class="inline-block bg-red text-white text-sm font-semibold px-5 py-2.5 rounded-md hover:bg-red-deep transition-colors">Partner with Us →</a>
							</div>
						</div>
						<!-- Right: photo (stacks first on mobile) -->
						<div class="overflow-hidden min-h-80 lg:min-h-0 order-first lg:order-last" data-animate="slide-right">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/3dc19194b19b5c804633ad324a893237ab692da5-1583x2048?w=800&h=1024&fit=crop&auto=format.png" alt="Kevin and Shelly White" class="w-full h-full object-cover" style="object-position: center 30%;" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FREE BOOK -->
		<section class="bg-stone-300 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-5xl mx-auto">
				<div class="rounded-3xl shadow-lg overflow-hidden" style="border: 1px solid rgba(255,255,255,0.1)">
					<div class="grid grid-cols-1 lg:grid-cols-2 lg:items-stretch">
						<!-- Left: book mockup photo — natural 2:3 ratio drives the card height -->
						<div data-animate="slide-left">
							<img src="https://cdn.sanity.io/images/pmowd8uo/production/917a1dde3704a12b0f29c784022d6abdcd97a981-1024x1536?w=800&h=1200&fit=crop&auto=format.png" alt="Father's Heart → Beloved Identity by Kevin White" class="w-full block" />
						</div>
						<!-- Right: free book offer -->
						<div class="p-10 lg:p-12 flex flex-col justify-center bg-stone-700" data-animate="slide-right">
							<p class="text-base font-semibold uppercase tracking-widest text-red mb-3">FREE BOOK from Spirit Media</p>
							<h3 class="font-serif text-3xl font-bold text-white mb-6">
								Father's Heart<br /><span class="text-red-soft">→ Beloved Identity</span>
							</h3>
							<p class="text-stone-300 leading-relaxed mb-8">
								Eight billion people are asking the same question: <em>Who am I?</em> Only one voice
								holds the answer. In this powerful compact devotional, your Heavenly Father speaks
								directly to you — revealing His heart, dismantling the orphan spirit, and establishing
								your true identity as His beloved child. Come home. You belong to Him.
							</p>
							<div>
								<button
									onclick="document.getElementById('fhb-modal').classList.remove('hidden')"
									class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm cursor-pointer"
								>
									Get Your Free Book →
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- MISSION AND VISION -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12">
					<p class="text-base font-semibold uppercase tracking-widest text-red mb-3" data-animate="fade-up">Identity</p>
					<h2 class="type-section-heading text-ink-soft" data-animate="fade-up" data-delay="1">This is Who We Are</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto mb-20">
					<div class="bg-stone-50 rounded-2xl p-8 border border-stone-200 shadow-sm" data-animate="fade-up" data-delay="1">
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red text-white mb-5">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /></svg>
						</div>
						<p class="text-base font-semibold uppercase tracking-widest text-red mb-2">Our Mission</p>
						<p class="type-body-lg text-stone-700">
							We walk with Kingdom Messengers from restoration to proclamation. Empowering them
							from <span class="text-red font-semibold">heart → message → movement.</span>
						</p>
					</div>
					<div class="bg-stone-50 rounded-2xl p-8 border border-stone-200 shadow-sm" data-animate="fade-up" data-delay="2">
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red text-white mb-5">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9 9 0 0 1 3 12c0-1.47.353-2.856.978-4.082" /></svg>
						</div>
						<p class="text-base font-semibold uppercase tracking-widest text-red mb-2">Our Vision</p>
						<p class="type-body-lg text-stone-700">
							For our Father's heart to be poured out on His beloved sons and daughters in all
							<span class="text-red font-semibold">195 nations.</span>
						</p>
					</div>
				</div>

				<!-- VALUES -->
				<div class="text-center max-w-2xl mx-auto mb-12">
					<p class="text-base font-semibold uppercase tracking-widest text-red mb-3" data-animate="fade-up">Our Values</p>
					<h3 class="type-card-heading text-ink-soft" data-animate="fade-up" data-delay="1">
						This is the culture that carries that mission.
					</h3>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">

					<!-- Father's Heart -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="1">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Father's Heart</h4>
						<p class="text-base font-semibold text-red mb-3">Everything flows from who God is as Father.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							We seek to reveal the Father Heart of God in every relationship and decision.
							We refuse orphan thinking. We build from intimacy, identity, and inheritance, not
							insecurity. We lead with love, truth, clarity, and courage. Every author, every
							partner, every team member is seen, valued, and called higher.
							<strong class="block mt-2 text-stone-700">We build people — not just platforms.</strong>
						</p>
					</div>

					<!-- Faith -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="2">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Faith</h4>
						<p class="text-base font-semibold text-red mb-3">We move where vision requires dependence on God.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							We pursue bold vision, trusting our perfect and loving Heavenly Father for outcomes
							beyond our capacity. If it can be done without Him, it isn't big enough. We embrace
							bold goals, global reach, and supernatural outcomes. We expect fruit beyond strategy,
							impact beyond borders, and provision beyond logic.
							<strong class="block mt-2 text-stone-700">We build with faith — not fear.</strong>
						</p>
					</div>

					<!-- Family -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="3">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Family</h4>
						<p class="text-base font-semibold text-red mb-3">We operate from covenants, not contracts.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							We build covenant relationships and treat every author, partner, and team member
							like family. Honor and trust matters here. We celebrate together. We carry one
							another. We speak truth in love and protect unity fiercely.
							<strong class="block mt-2 text-stone-700">Culture is not what we say — it's how we treat each other when it costs something.</strong>
						</p>
					</div>

					<!-- Excellence -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="4">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.040.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Excellence</h4>
						<p class="text-base font-semibold text-red mb-3">Our Father deserves our best as we seek His best.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							We reject mediocrity. We refine, sharpen, improve, and elevate. From manuscript to
							marketplace, we steward every detail with intentionality.
							<strong class="block mt-2 text-stone-700">Excellence is worship in action.</strong>
						</p>
					</div>

					<!-- Multiplication -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="5">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Multiplication</h4>
						<p class="text-base font-semibold text-red mb-3">We think nations, not numbers.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							We are not building for one launch or one market. We empower heart → message → movement
							that multiply intimacy with the Father, beloved identity, and kingdom inheritance
							across generations.
							<strong class="block mt-2 text-stone-700">The mandate is 195 nations — and we build accordingly.</strong>
						</p>
					</div>

					<!-- Stewardship -->
					<div class="bg-stone-50 rounded-2xl p-6 border border-stone-200 shadow-sm hover:shadow-md transition-shadow flex flex-col" data-animate="fade-up" data-delay="6">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-wash text-red mb-4">
							<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
						</div>
						<h4 class="type-card-heading mb-1">Stewardship</h4>
						<p class="text-base font-semibold text-red mb-3">Nothing entrusted to us is small.</p>
						<p class="type-body-lg text-stone-700 leading-relaxed">
							Messages carry eternity. Resources carry responsibility. Relationships carry legacy.
							We handle them with integrity, wisdom, and long-term Kingdom vision.
						</p>
					</div>

				</div>
			</div>
		</section>

		<!-- MID-PAGE CTA -->
		<section class="bg-stone-100 py-10 lg:py-16 px-6 lg:px-8 border-t border-stone-200">
			<div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
				<div>
					<p class="type-card-heading text-ink-soft">Ready to get your message out?</p>
					<p class="type-body-lg text-stone-600 mt-1">We'd love to walk with you from heart to movement.</p>
				</div>
				<div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto shrink-0">
					<a href="/publishing" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm whitespace-nowrap">Publishing Services →</a>
					<a href="/marketing" class="inline-block border border-stone-400 text-ink-soft font-semibold px-6 py-3 rounded-md hover:bg-stone-200 transition-colors text-sm whitespace-nowrap">Marketing Services →</a>
				</div>
			</div>
		</section>

		<!-- OUR TEAM -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<p class="text-base font-semibold uppercase tracking-widest text-red mb-3" data-animate="fade-up">Our Team</p>
					<h2 class="type-section-heading mb-4" data-animate="fade-up" data-delay="1">
						A Global Team for a Global Mission
					</h2>
					<p class="type-body-lg text-stone-700 leading-relaxed" data-animate="fade-up" data-delay="2">
						Our team spans the USA, India, the Philippines, and beyond — because reaching 195
						nations requires the best talent from more than one.
					</p>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
					{
						teamMembers.map(({ name, role, photo, objectPosition }, i) => (
							<div
								class="rounded-2xl border border-stone-200 bg-stone-100 overflow-hidden flex flex-row h-24 transition-shadow hover:shadow-md"
								data-animate="fade-up"
								data-delay={String((i % 4) + 1)}
							>
								<div class="w-1/2 shrink-0 overflow-hidden">
									<img src={photo} alt={name} class="w-full h-full object-cover" style={`object-position: ${objectPosition}; filter: sepia(15%) brightness(1.05) contrast(1.02);`} />
								</div>
								<div class="w-1/2 p-3 flex flex-col justify-center">
									<p class="font-semibold text-sm text-ink-soft leading-snug">{name}</p>
									<p class="text-xs mt-1 font-medium text-red">{role}</p>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- CLOSING STATEMENT -->
		<section class="bg-stone-300 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<p class="type-section-heading text-ink-soft leading-relaxed" data-animate="fade-up">
					We are not simply a publishing family.
				</p>
				<p class="type-section-heading text-ink-soft leading-relaxed mt-3" data-animate="fade-up" data-delay="1">
					We are part of a global movement.
				</p>
				<p class="font-serif text-2xl sm:text-3xl font-bold text-red leading-relaxed mt-3" data-animate="fade-up" data-delay="2">
					And we will not stop until the Father's Heart bears sons and daughters in every nation.
				</p>
			</div>
		</section>

		<!-- WHY PARTNER -->
		<section class="bg-red py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold text-ink-soft mb-6" data-animate="fade-up">Why Partner with Spirit Media?</h2>
				<p class="text-red-100 type-body-lg mb-8" data-animate="fade-up" data-delay="1">
					Our Father's Heart is for relationships not just results. He offers significance not
					just success. Let Spirit Media be your long-term publishing partner to prioritize our
					Father's heart → message → movement IN you while leaving His Work THROUGH you in
					His hands.
				</p>
				<blockquote class="bg-white/10 rounded-xl p-8 mb-10" data-animate="fade-in" data-delay="2">
					<p class="font-serif text-xl italic text-white leading-relaxed">
						"Seek our Father's Kingdom above all else, and live righteously, and he will give you
						everything you need."
					</p>
					<cite class="block mt-4 text-sm font-semibold text-red-100 not-italic">— Matthew 6:33 (FHB)</cite>
				</blockquote>
				<a
					href="/contact"
					class="inline-block bg-white text-red font-bold px-8 py-4 rounded-md hover:bg-red-100 transition-colors shadow-sm"
					data-animate="fade-up"
					data-delay="3"
				>
					Partner with Us →
				</a>
			</div>
		</section>

	</main>

	<!-- FREE BOOK MODAL -->
	<div
		id="fhb-modal"
		class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
		onclick="if(event.target===this)this.classList.add('hidden')"
	>
		<!-- Backdrop -->
		<div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
		<!-- Panel -->
		<div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg z-10 overflow-hidden">
			<!-- Header -->
			<div class="bg-stone-700 px-6 py-5 flex items-start justify-between">
				<div>
					<p class="text-xs font-semibold uppercase tracking-widest text-red-soft mb-1">FREE BOOK from Spirit Media</p>
					<h3 class="font-serif text-xl font-bold text-white">Father's Heart → Beloved Identity</h3>
				</div>
				<button
					onclick="document.getElementById('fhb-modal').classList.add('hidden')"
					class="text-stone-400 hover:text-white transition-colors ml-4 mt-0.5 text-xl leading-none cursor-pointer bg-transparent border-0"
					aria-label="Close"
				>✕</button>
			</div>
			<!-- Form -->
			<div class="p-6">
				<iframe
					src="https://mail.spiritmediaone.com/widget/survey/UYe8vyLv7DZ5BuMRhEfv"
					style="border:none;width:100%;min-height:320px;"
					scrolling="no"
					id="UYe8vyLv7DZ5BuMRhEfv"
					title="Get Your Free Copy of Father's Heart → Beloved Identity"
				></iframe>
				<script is:inline src="https://mail.spiritmediaone.com/js/form_embed.js"></script>
			</div>
		</div>
	</div>
</Layout>
