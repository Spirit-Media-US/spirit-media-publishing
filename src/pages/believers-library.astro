---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Believer's Library — Spirit Media"
	description="Believer's Library — the faith-based digital reading app by Spirit Media. Coming soon."
>
	<main id="main-content">

		<!-- HERO — COMING SOON -->
		<section class="bg-navy-950 text-white py-32 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<span class="inline-block bg-red-600 text-white text-sm font-semibold px-4 py-1 rounded-full mb-6">
					Coming Soon
				</span>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Believer's Library
				</h1>
				<p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed mb-8">
					A curated digital reading app designed for believers — putting Kingdom-building books,
					devotionals, and study resources at your fingertips.
				</p>
				<a href="/contact" class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors mb-4">
					Get Notified at Launch
				</a>
				<p class="text-sm text-gray-400">We'll let you know the moment it's available.</p>
			</div>
		</section>

		<!-- WHAT IS BELIEVER'S LIBRARY -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">What Is Believer's Library?</h2>
				<p class="text-lg text-gray-700 leading-relaxed mb-6">
					Believer's Library is Spirit Media's upcoming faith-based digital reading platform —
					a place where Kingdom authors can publish and distribute their works directly to a
					community of faith-filled readers.
				</p>
				<p class="text-lg text-gray-700 leading-relaxed">
					Think of it as a curated Christian alternative to mainstream reading apps — built with
					the mission of the Kingdom at the center.
				</p>
			</div>
		</section>

		<!-- FEATURES PREVIEW -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-7xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-12 text-center">What to Expect</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">📚</div>
						<h3 class="font-semibold text-gray-900 mb-2">Curated Kingdom Content</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Only faith-aligned books, devotionals, and study materials — hand-selected by our editorial team</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">✍️</div>
						<h3 class="font-semibold text-gray-900 mb-2">Author Publishing Hub</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Kingdom authors can publish directly to the Believer's Library audience</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">💬</div>
						<h3 class="font-semibold text-gray-900 mb-2">Community Reading</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Share highlights, notes, and reflections with a community of readers</p>
					</div>
					<div class="bg-white rounded-xl p-6">
						<div class="text-3xl mb-3">📱</div>
						<h3 class="font-semibold text-gray-900 mb-2">Offline Reading</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Download books and read anywhere, anytime — even without an internet connection</p>
					</div>
				</div>
			</div>
		</section>

		<!-- FOR AUTHORS -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-6">For Kingdom Authors</h2>
				<p class="text-lg text-gray-700 leading-relaxed mb-8">
					Believer's Library will give Spirit Media authors a dedicated platform to reach a
					faith-focused readership — a curated space where your book stands alongside other
					Kingdom voices, not buried in the noise of mainstream marketplaces.
				</p>
				<a href="/publishing" class="inline-block border-2 border-red-600 text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
					Publish with Spirit Media
				</a>
			</div>
		</section>

		<!-- NOTIFY ME -->
		<section class="bg-red-600 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Be First to Know</h2>
				<p class="text-red-100 text-lg leading-relaxed mb-8">
					Join our waitlist and be among the first to access Believer's Library when it launches.
				</p>
				<a href="/contact" class="inline-block bg-white text-red-600 font-semibold px-8 py-3 rounded-md hover:bg-red-50 transition-colors">
					Join the Waitlist
				</a>
			</div>
		</section>

	</main>
</Layout>
