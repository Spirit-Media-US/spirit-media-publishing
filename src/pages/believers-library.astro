---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="The Believer's Library — World's Largest Cloud-Based Christian Book App"
	description="Download The Believer's Library app and access millions of Christian books as PDFs in your own language — free or low-cost, available anywhere in the world on any phone."
	ogImage="/og-believers.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Believer's Library app, Christian book app, free Christian books, Christian digital library, Christian books PDF, global missions app, 10/40 Window, Christian books every language, Spirit Media Publishing, mobile Christian library" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "The Believer's Library",
			"applicationCategory": "EducationApplication",
			"operatingSystem": "iOS, Android",
			"description": "Access millions of Christian books as PDFs in your own language — free or low-cost, available anywhere in the world on any phone.",
			"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
			"publisher": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" },
			"url": "https://spiritmediapublishing.com/believers-library"
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">The Believer's Library</p>
						<h1 class="type-hero">The world's largest<br /><span class="text-red">cloud-based Christian library</span></h1>
						<p class="mt-6 text-2xl font-bold text-stone-600">In your pocket.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-ink-muted aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- SCRIPTURE -->
		<section class="bg-ink-soft px-6 py-10 lg:py-16 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<blockquote data-animate="fade-in">
					<p class="font-serif text-xl sm:text-2xl font-medium italic leading-relaxed text-white">"Publish Our Father's glorious deeds among the nations. Tell everyone about the amazing things He does."</p>
					<cite class="mt-4 block text-sm font-semibold tracking-widest text-red-soft not-italic">— Psalm 96:3 (FHB)</cite>
				</blockquote>
			</div>
		</section>

		<!-- THE GAP -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">The Gap</p>
				<h2 class="type-section-heading mb-6" data-animate="fade-up" data-delay="1">The Gap Isn't Content. It's Access.</h2>
				<div class="space-y-4 text-lg text-stone-700 leading-relaxed">
					<p data-animate="fade-up" data-delay="2">Today, 3.3 billion people have limited or no access to the Gospel.</p>
					<p data-animate="fade-up" data-delay="3">Amazon — the world's largest bookseller — reaches only 1% of the global population.</p>
					<p data-animate="fade-up" data-delay="4">Less than 1 billion people have access to a library.</p>
					<p data-animate="fade-up" data-delay="5">But <strong class="text-ink-soft">8.6 billion</strong> mobile phone subscriptions are active worldwide.</p>
				</div>
			</div>
		</section>

		<!-- THE SOLUTION -->
		<section class="bg-stone-50 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">The Solution</p>
				<h2 class="type-section-heading mb-6" data-animate="fade-up" data-delay="1">The Believer's Library</h2>
				<p class="type-body-lg text-stone-700 leading-relaxed mb-6" data-animate="fade-up" data-delay="2">A mobile app delivering millions of Christian books as downloadable PDFs to anyone with a phone — in their own language, from anywhere on earth.</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-animate="fade-up" data-delay="3">
					{['Intelligent search by language, location, topic, and tradition', 'AI-generated audio reading, book summaries, and study guides', 'Affordable subscription pricing for global accessibility', 'Books from every nation, tribe, and language'].map((item) => (
						<div class="flex items-start gap-3">
							<svg class="h-5 w-5 shrink-0 text-red mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
							<span class="type-body-sm text-stone-700">{item}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- VISION -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<p class="eyebrow eyebrow-red mb-3" data-animate="fade-up">Vision</p>
				<h2 class="type-section-heading mb-6" data-animate="fade-up" data-delay="1">The Vision</h2>
				<p class="type-body-lg text-stone-700 leading-relaxed mb-6" data-animate="fade-up" data-delay="2">From Genesis to Revelation, God has used the written word to bring life. The Gutenberg press made the Bible the most printed book in history. The Believer's Library is the next chapter — empowering every believer to publish their testimony and every person on earth to access Christian books.</p>
				<p class="type-card-heading italic" data-animate="fade-up" data-delay="3">Our call to authors worldwide is simple:<br /><span class="text-red">Give us your book and we'll get it to the nations.</span></p>
			</div>
		</section>

		<!-- COMING SOON -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Coming Soon</h2>
				<p class="text-stone-200 type-body-lg mb-6" data-animate="fade-up" data-delay="1">A working prototype has been built. Launch is planned for late 2026. Every Spirit Media publishing agreement already includes permission to distribute through The Believer's Library. When it goes live, every book we've ever published will be accessible to the world.</p>
				<p class="text-stone-300 text-sm" data-animate="fade-in" data-delay="2">Published by Spirit Media.</p>
			</div>
		</section>

	</main>
</Layout>
