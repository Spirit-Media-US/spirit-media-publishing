---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Bookstore — Spirit Media Publishing"
	description="Browse over 300 Kingdom-building titles published through Spirit Media. New titles added every week."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Bookstore</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Spirit Media's Bookstore
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed">
					To date we have published over 300 titles. New titles are added every week.
				</p>
			</div>
		</section>

		<!-- INTRO -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<p class="text-lg text-gray-700 leading-relaxed mb-8">
					Let Spirit Media publish your book. Whose out next New York Times Bestseller, National
					Bestseller, or International Bestseller? We are here for you.
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Publish Your Book →
				</a>
			</div>
		</section>

		<!-- BROWSE AMAZON -->
		<section class="bg-gray-50 py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">Browse Our Titles</h2>
				<p class="text-gray-600 leading-relaxed mb-8">
					Our full catalog is available on Amazon. Search for Spirit Media Publishing to discover
					our complete collection of Kingdom-building books.
				</p>
				<a
					href="https://www.amazon.com/s?k=spirit+media+publishing"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Browse on Amazon →
				</a>
			</div>
		</section>

		<!-- PUBLISH YOUR BOOK CTA -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Ready to Be Published?</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Join over 300 authors who have trusted Spirit Media Publishing to carry their message
					to the nations.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="/publishing"
						class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
					>
						View Publishing Services
					</a>
					<a
						href="https://spiritmedia.us/request-a-call/"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-md hover:bg-white/10 transition-colors"
					>
						Request a Call
					</a>
				</div>
			</div>
		</section>

	</main>
</Layout>
