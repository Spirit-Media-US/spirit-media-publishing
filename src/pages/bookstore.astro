---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

// Fetch all books from Sanity at build time
const rawBooks = await sanityClient.fetch(`
  *[_type == "book"] | order(publishDate desc) {
    title,
    "display_title": coalesce(displayTitle, title),
    author,
    "img": coalesce(coverImageUrl, coverImage.asset->url + "?w=400&auto=format"),
    "amazon": amazon,
    "date": publishDate,
    formats {
      "paperback": paperback,
      "hardback": hardback,
      "ebook": ebook,
      "audio": audio
    }
  }
`);

// Serialize for client-side JS injection
const BOOKS_JSON = JSON.stringify(rawBooks);
---

<Layout
	title="Christian Bookstore — Browse 300+ Spirit Media Published Titles"
	description="Shop the Spirit Media Christian bookstore — over 300 titles by Kingdom Messengers covering faith, leadership, healing, and discipleship. New books added weekly."
	ogImage="https://cdn.sanity.io/images/pmowd8uo/production/e1274263f40d901cf33297ab4c8110e8ad9d9ca7-1200x630.jpg?w=1200&h=630&fit=crop&auto=format"
>
	<Fragment slot="head">
		<meta name="keywords" content="Christian bookstore, buy Christian books, Kingdom Messenger books, Spirit Media books, Christian authors, faith books, Christian leadership books, discipleship books, healing books, Christian publishing" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ItemList",
			"name": "Spirit Media Christian Bookstore",
			"description": "300+ Christian books by Kingdom Messengers published by Spirit Media Publishing",
			"url": "https://spiritmediapublishing.com/bookstore",
			"numberOfItems": 300,
			"itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Father's Heart - Beloved Identity", "author": "Kevin White", "url": "https://www.amazon.com/dp/B0GQ3L2LQT" },
				{ "@type": "ListItem", "position": 2, "name": "Humble Influence", "author": "Jim Matuga", "url": "https://www.amazon.com/Humble-Influence-Strength-True-Followership/dp/B0F9WJFTSJ" },
				{ "@type": "ListItem", "position": 3, "name": "Only God Works", "author": "Kevin White", "url": "https://www.amazon.com/dp/195830476X" },
				{ "@type": "ListItem", "position": 4, "name": "Audacious Generosity", "author": "Kevin White", "url": "https://www.amazon.com/Audacious-Generosity-Experience-Receive-Possible/dp/1544516142" },
				{ "@type": "ListItem", "position": 5, "name": "The End-Times Warrior", "author": "Patricia Daniel", "url": "https://www.amazon.com/End-Times-Warrior-40-Day-Devotional/dp/B0FD9RN45N" },
				{ "@type": "ListItem", "position": 6, "name": "Daughters of the King", "author": "Freddie Prado", "url": "https://www.amazon.com/Daughters-King-Devotional-Dads/dp/B0FBLFC6N5" },
				{ "@type": "ListItem", "position": 7, "name": "Ascension", "author": "Bryan Elliott", "url": "https://www.amazon.com/Ascension-Living-Beyond-Bryan-Elliott/dp/B0FVFS457S" },
				{ "@type": "ListItem", "position": 8, "name": "A Journey Through Grief", "author": "Annie Brown", "url": "https://www.amazon.com/Journey-Through-Grief-Annie-Brown/dp/B0FC2SCNMT/" },
				{ "@type": "ListItem", "position": 9, "name": "What's Your Word", "author": "Kevin White", "url": "https://www.amazon.com/dp/1958304123" },
				{ "@type": "ListItem", "position": 10, "name": "Spirit Media's Ultimate Book Marketing Guide", "author": "Kevin White", "url": "https://www.amazon.com/dp/1958304514" }
			]
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-10 lg:py-12 lg:px-8">
			<div class="mx-auto max-w-7xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
				<div>
					<p class="eyebrow eyebrow-red mb-2">Bookstore</p>
					<h1 class="font-serif text-3xl font-bold text-ink-soft">Spirit Media’s <span class="text-red">Bookstore</span></h1>
					<p class="mt-1 text-sm text-stone-500">Over 300 titles by Kingdom Messengers. New books added every week.</p>
				</div>
				<a href="/contact" class="shrink-0 rounded-md bg-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Publish Your Book →</a>
			</div>
		</section>


		<!-- BOOKSTORE GRID -->
		<section class="bg-stone-100 py-10 lg:py-16 px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="flex flex-col sm:flex-row gap-4 mb-6">
					<input id="book-search" type="text" placeholder="Search by title or author…"
						class="flex-1 rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-sm text-ink-soft placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-red" />
					<select id="author-filter" class="rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-sm text-ink-soft focus:outline-none focus:ring-2 focus:ring-red">
						<option value="">All Authors</option>
						{[...new Set(rawBooks.map((b: any) => b.author).filter(Boolean))].sort().map((author: string) => (
							<option value={author}>{author}</option>
						))}
					</select>
					<select id="sort-order" class="rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-sm text-ink-soft focus:outline-none focus:ring-2 focus:ring-red">
						<option value="newest">Newest First</option>
						<option value="oldest">Oldest First</option>
						<option value="title">Title A–Z</option>
						<option value="author">Author A–Z</option>
					</select>
				</div>
				<p id="book-count" class="text-sm text-stone-500 mb-6"></p>
				<div id="book-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5"></div>
				<p id="no-results" class="hidden text-center text-stone-500 py-12 lg:py-20">No books found matching your search.</p>
			</div>
		</section>


		<!-- STATS STRIP -->
		<section class="bg-stone-300 px-6 py-5">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
					<div class="flex flex-col items-center text-center py-2">
						<span id="stat-titles" class="font-serif text-3xl font-bold text-ink-soft">0</span>
						<span class="text-xs font-semibold uppercase tracking-widest text-stone-600 mt-1">Published Titles</span>
					</div>
					<div class="flex flex-col items-center text-center py-2">
						<span id="stat-authors" class="font-serif text-3xl font-bold text-ink-soft">0</span>
						<span class="text-xs font-semibold uppercase tracking-widest text-stone-600 mt-1">Kingdom Messengers</span>
					</div>
					<div class="flex flex-col items-center text-center py-2">
						<span id="stat-formats" class="font-serif text-3xl font-bold text-ink-soft">0</span>
						<span class="text-xs font-semibold uppercase tracking-widest text-stone-600 mt-1">Format Editions</span>
					</div>
					<div class="flex flex-col items-center text-center py-2">
						<span id="stat-years" class="font-serif text-3xl font-bold text-red">3</span>
						<span class="text-xs font-semibold uppercase tracking-widest text-stone-600 mt-1">Years of Publishing</span>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-12 lg:py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4">Ready to publish your book?</h2>
				<p class="text-stone-200 type-body-lg mb-8">Join over 300 Kingdom Messengers who have trusted Spirit Media to publish and market their message.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors">Request a Free Consultation</a>
			</div>
		</section>

	</main>

	<script define:vars={{ BOOKS_JSON }}>
		const BOOKS = JSON.parse(BOOKS_JSON);
		BOOKS.forEach(b => { if (!b.formats) b.formats = {}; });

		// --- STATS COUNTERS (derived live from BOOKS data) ---
		(function() {
			const totalTitles = BOOKS.length;
			const uniqueAuthors = new Set(BOOKS.map(b => b.author)).size;
			const totalFormats = BOOKS.reduce((sum, b) => sum + Object.values(b.formats || {}).filter(v => v).length, 0);

			function animateCount(id, target, duration = 1400) {
				const el = document.getElementById(id);
				if (!el) return;
				const start = performance.now();
				function step(now) {
					const progress = Math.min((now - start) / duration, 1);
					const ease = 1 - Math.pow(1 - progress, 3);
					el.textContent = Math.round(ease * target);
					if (progress < 1) requestAnimationFrame(step);
					else el.textContent = target;
				}
				requestAnimationFrame(step);
			}

			const obs = new IntersectionObserver((entries) => {
				if (entries[0].isIntersecting) {
					animateCount('stat-titles', totalTitles);
					animateCount('stat-authors', uniqueAuthors, 1200);
					animateCount('stat-formats', totalFormats, 1600);
					obs.disconnect();
				}
			}, { threshold: 0.3 });

			const strip = document.getElementById('stat-titles')?.closest('section');
			if (strip) obs.observe(strip);
		})();

		const FORMAT_LABELS = {
			paperback: 'Paperback',
			hardback:  'Hardback',
			ebook:     'eBook',
			audiobook: 'Audiobook',
			audio:     'Audiobook',
			pdf:       'PDF',
		};
		const FORMAT_STYLES = {
			paperback: 'background:#fde8e8;color:#c0392b;border:1px solid #f5c6c6;',
			hardback:  'background:#e8edf5;color:#2c3e6b;border:1px solid #c5cfe8;',
			ebook:     'background:#e6f4f1;color:#1a7a65;border:1px solid #b8dfd8;',
			audiobook: 'background:#fef3e2;color:#92640a;border:1px solid #f5d99e;',
			audio:     'background:#fef3e2;color:#92640a;border:1px solid #f5d99e;',
			pdf:       'background:#f0eeeb;color:#5a5248;border:1px solid #d8d2cb;',
		};

		function renderFormats(b) {
			const fmts = b.formats || {};
			let keys = Object.keys(fmts).filter(k => FORMAT_LABELS[k] && fmts[k]);
			// If no formats defined, fall back to amazon link — detect type by ASIN
			if (!keys.length) {
				const asinMatch = b.amazon.match(/\/dp\/([A-Z0-9]+)/);
				const asin = asinMatch ? asinMatch[1] : '';
				const isEbook = asin.startsWith('B');
				const fmtKey = isEbook ? 'ebook' : 'paperback';
				const fmtLabel = isEbook ? 'eBook' : 'Paperback';
				return `<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;">
					<a href="${b.amazon}" target="_blank" rel="noopener noreferrer"
						style="display:inline-block;font-size:0.6rem;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;padding:3px 7px;border-radius:4px;text-decoration:none;${FORMAT_STYLES[fmtKey]}"
						onclick="event.stopPropagation()">${fmtLabel}</a>
				</div>`;
			}
			const badges = keys.map(k =>
				`<a href="${fmts[k]}" target="_blank" rel="noopener noreferrer"
					style="display:inline-block;font-size:0.6rem;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;padding:3px 7px;border-radius:4px;text-decoration:none;${FORMAT_STYLES[k]}"
					onclick="event.stopPropagation()">
					${FORMAT_LABELS[k]}
				</a>`
			).join('');
			return `<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;">${badges}</div>`;
		}

		function render(filtered) {
			const grid = document.getElementById('book-grid');
			const count = document.getElementById('book-count');
			const none = document.getElementById('no-results');
			grid.innerHTML = filtered.map(b => {
				const dateLabel = b.date ? new Date(b.date + 'T12:00:00').toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) : '';
				const displayTitle = b.display_title || b.title;
				const hasFormats = b.formats && Object.keys(b.formats).length > 0;
				return `<div class="group flex flex-col bg-white overflow-hidden border border-stone-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
					<a href="${b.amazon}" target="_blank" rel="noopener noreferrer" class="block">
						<div class="aspect-[2/3] overflow-hidden bg-stone-100">
							<img src="${b.img}" alt="${displayTitle}" loading="lazy"
								class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300" />
						</div>
					</a>
					<div class="p-3 flex flex-col gap-1">
						<a href="${b.amazon}" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-ink-soft leading-tight line-clamp-2 hover:text-red transition-colors">${displayTitle}</a>
						<p class="text-xs text-stone-500">${b.author}</p>
						${dateLabel ? `<p class="text-xs text-stone-400">${dateLabel}</p>` : ''}
						${renderFormats(b)}
					</div>
				</div>`;
			}).join('');
			count.textContent = `Showing ${filtered.length} of ${BOOKS.length} titles`;
			none.classList.toggle('hidden', filtered.length > 0);
		}

		function filter() {
			const q = document.getElementById('book-search').value.toLowerCase();
			const a = document.getElementById('author-filter').value.toLowerCase();
			const sort = document.getElementById('sort-order').value;
			let filtered = BOOKS.filter(b => {
				const displayTitle = (b.display_title || b.title).toLowerCase();
				const matchQ = !q || displayTitle.includes(q) || b.author.toLowerCase().includes(q);
				const matchA = !a || b.author.toLowerCase() === a;
				return matchQ && matchA;
			});
			filtered.sort((x, y) => {
				if (sort === 'newest') return (y.date || '').localeCompare(x.date || '');
				if (sort === 'oldest') return (x.date || '').localeCompare(y.date || '');
				if (sort === 'title')  return (x.display_title || x.title).localeCompare(y.display_title || y.title);
				if (sort === 'author') return x.author.localeCompare(y.author);
				return 0;
			});
			render(filtered);
		}

		document.getElementById('book-search').addEventListener('input', filter);
		document.getElementById('author-filter').addEventListener('change', filter);
		document.getElementById('sort-order').addEventListener('change', filter);
		filter();
	</script>
</Layout>
