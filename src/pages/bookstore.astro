		function render(filtered) {
			const grid = document.getElementById('book-grid');
			const count = document.getElementById('book-count');
			const none = document.getElementById('no-results');
			grid.innerHTML = filtered.map(b => {
				const dateLabel = b.date ? new Date(b.date + 'T12:00:00').toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) : '';
				const displayTitle = b.display_title || b.title;
				return `<a href="${b.amazon}" target="_blank" rel="noopener noreferrer"
					class="group flex flex-col bg-white overflow-hidden border border-stone-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
					<div class="aspect-[2/3] overflow-hidden bg-stone-100">
						<img src="${b.img}" alt="${displayTitle}" loading="lazy"
							class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300" />
					</div>
					<div class="p-3 flex flex-col gap-1">
						<p class="text-xs font-semibold text-ink-soft leading-tight line-clamp-2">${displayTitle}</p>
						<p class="text-xs text-stone-500">${b.author}</p>
						${dateLabel ? `<p class="text-xs text-stone-400">${dateLabel}</p>` : ''}
					</div>
				</a>`;
			}).join('');
			count.textContent = `Showing ${filtered.length} of ${BOOKS.length} titles`;
			none.classList.toggle('hidden', filtered.length > 0);
		}

		function filter() {
			const q = document.getElementById('book-search').value.toLowerCase();
			const a = document.getElementById('author-filter').value.toLowerCase();
			const sort = document.getElementById('sort-order').value;
			let filtered = BOOKS.filter(b => {
				const displayTitle = (b.display_title || b.title).toLowerCase();
				const matchQ = !q || displayTitle.includes(q) || b.author.toLowerCase().includes(q);
				const matchA = !a || b.author.toLowerCase() === a;
				return matchQ && matchA;
			});
			filtered.sort((x, y) => {
				if (sort === 'newest') return (y.date || '').localeCompare(x.date || '');
				if (sort === 'oldest') return (x.date || '').localeCompare(y.date || '');
				if (sort === 'title')  return (x.display_title || x.title).localeCompare(y.display_title || y.title);
				if (sort === 'author') return x.author.localeCompare(y.author);
				return 0;
			});
			render(filtered);
		}

		document.getElementById('book-search').addEventListener('input', filter);
		document.getElementById('author-filter').addEventListener('change', filter);
		document.getElementById('sort-order').addEventListener('change', filter);
		filter();
	</script>
