---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Spirit Media's Bookstore"
	description="Browse over 300 titles published by Spirit Media. New titles added every week."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Bookstore</p>
						<h1 class="type-hero text-ink-soft">Spirit Media's<br /><span class="text-red">Bookstore</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">To date we have published over 300 titles. New titles are added every week. Let Spirit Media publish your book.</p>
						<p class="mt-3 type-body text-stone-500 max-w-xl">Whose our next New York Times Bestseller, National Bestseller, or International Bestseller? We are here for you.</p>
						<div class="mt-8">
							<a href="/contact" class="rounded-md bg-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-deep">Publish Your Book →</a>
						</div>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-ink-muted aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- BOOKSTORE PLACEHOLDER -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<div class="bg-stone-50 rounded-2xl border border-gray-200 p-12" data-animate="fade-up">
					<div class="flex h-16 w-16 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-6">
						<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
					</div>
					<h2 class="font-serif text-2xl font-bold text-ink-soft mb-4">Book Catalog Coming Soon</h2>
					<p class="text-stone-600 leading-relaxed mb-6">Our full online catalog with 300+ titles is being prepared. In the meantime, browse our books on Amazon.</p>
					<a href="https://www.amazon.com/s?k=Spirit+Media+Publishing" target="_blank" rel="noopener noreferrer" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Browse on Amazon →</a>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-red px-6 py-20 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="font-serif text-3xl font-bold text-white sm:text-4xl mb-4" data-animate="fade-up">Ready to publish your book?</h2>
				<p class="text-stone-200 text-lg leading-relaxed mb-8" data-animate="fade-up" data-delay="1">Let Spirit Media help you get your message to the nations.</p>
				<a href="/contact" class="inline-block bg-stone-50 text-red font-semibold px-8 py-3.5 rounded-md hover:bg-red-wash transition-colors" data-animate="fade-up" data-delay="2">Request a Free Consultation</a>
			</div>
		</section>

	</main>
</Layout>
