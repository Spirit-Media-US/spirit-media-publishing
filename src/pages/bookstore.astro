---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bookstore — Spirit Media Publishing" description="Browse Kingdom-building books published through Spirit Media Publishing. Faith-driven authors, life-changing messages.">
  <main id="main-content">

    <!-- HERO -->
    <section class="bg-red-600 text-white py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Bookstore</p>
        <h1 class="text-4xl md:text-5xl font-bold font-serif mb-6">Kingdom Books for Kingdom Readers</h1>
        <p class="text-lg md:text-xl text-red-100 leading-relaxed max-w-2xl mx-auto">
          Browse the growing library of books published through Spirit Media Publishing — written by Kingdom Messengers for believers ready to go deeper.
        </p>
      </div>
    </section>

    <!-- COMING SOON / FEATURED CONTENT -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-6">Our Catalog Is Growing</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Spirit Media Publishing is committed to bringing only the highest-quality Kingdom-focused books to our readers. Our bookstore catalog features books written and published through our platform — from eBooks to full print volumes.
        </p>
        <p class="text-gray-700 leading-relaxed mb-8">
          New titles are added regularly. Check back often or join our community to be notified of new releases.
        </p>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-8">
          <p class="text-gray-700 leading-relaxed">
            🔔 Want to be first to know about new releases? Join the Spirit Media Network for early access.
          </p>
        </div>
        <a href="/join" class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
          Join the Community
        </a>
      </div>
    </section>

    <!-- CATEGORIES -->
    <section class="bg-gray-50 py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-12 text-center">Browse by Category</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

          <a href="#" class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow block">
            <div class="text-red-600 text-2xl mb-3">✝️</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors">Faith & Spiritual Growth</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Books to deepen your walk with God</p>
          </a>

          <a href="#" class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow block">
            <div class="text-red-600 text-2xl mb-3">👑</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors">Leadership & Ministry</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Resources for leaders building Kingdom movements</p>
          </a>

          <a href="#" class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow block">
            <div class="text-red-600 text-2xl mb-3">🌱</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors">Inner Healing & Identity</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Books to help you discover who you are in Christ</p>
          </a>

          <a href="#" class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow block">
            <div class="text-red-600 text-2xl mb-3">📖</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors">Publishing & Writing</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Resources for authors and communicators</p>
          </a>

        </div>
      </div>
    </section>

    <!-- ARE YOU AN AUTHOR -->
    <section class="bg-navy-950 text-white py-20 px-4 text-center">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold font-serif mb-6">Are You a Kingdom Author?</h2>
        <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-2xl mx-auto">
          Want your book featured in our bookstore? Publish with Spirit Media and reach our growing community of Kingdom readers.
        </p>
        <a href="/publishing" class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
          Publish Your Book
        </a>
      </div>
    </section>

  </main>
</Layout>
