---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog — Spirit Media Publishing" description="Kingdom insights for authors, leaders, and messengers. Publishing tips, marketing strategy, and faith-driven leadership from the Spirit Media team.">
  <main id="main-content">

    <!-- HERO -->
    <section class="bg-red-600 text-white py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">The Spirit Media Blog</p>
        <h1 class="text-4xl md:text-5xl font-bold font-serif mb-6">Insights for Kingdom Messengers</h1>
        <p class="text-lg md:text-xl text-red-100 leading-relaxed max-w-2xl mx-auto">
          Publishing tips, marketing strategy, leadership insights, and faith-filled encouragement — from the Spirit Media team to you.
        </p>
      </div>
    </section>

    <!-- COMING SOON -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-6">Articles Coming Soon</h2>
        <p class="text-gray-700 leading-relaxed mb-10">
          We're building out our content library. Subscribe to our community to be first to access new articles, resources, and insights from Kevin White and the Spirit Media team.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/join" class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
            Join the Community
          </a>
          <a href="/contact" class="inline-block border-2 border-red-600 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </section>

    <!-- TOPICS WE COVER -->
    <section class="bg-gray-50 py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold font-serif text-gray-900 mb-10 text-center">Topics We Cover</h2>
        <div class="flex flex-wrap gap-3 justify-center">
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">How to Write Your First Book</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Self-Publishing vs Traditional</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Building Your Author Platform</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Book Marketing Strategies</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Faith-Driven Leadership</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Publishing on Amazon</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Finding Your Message</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Kingdom Entrepreneurship</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Inner Healing for Leaders</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Audiobook Production</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Book Cover Design Tips</span>
          <span class="inline-block bg-gray-100 text-gray-700 rounded-full px-4 py-2 text-sm font-medium">Email Marketing for Authors</span>
        </div>
      </div>
    </section>

    <!-- STAY CONNECTED -->
    <section class="bg-navy-950 text-white py-20 px-4 text-center">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold font-serif mb-6">Never Miss an Article</h2>
        <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-2xl mx-auto">
          Join the Spirit Media Network for early access to all blog content, plus live sessions, community, and more.
        </p>
        <a href="/join" class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors">
          Join the Network
        </a>
      </div>
    </section>

  </main>
</Layout>
