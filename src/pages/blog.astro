---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Blog — Spirit Media Publishing"
	description="Kingdom insights for authors, leaders, and messengers. Publishing tips, marketing strategy, and faith-driven leadership from the Spirit Media team."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-red-600 text-white py-24 px-4">
			<div class="max-w-4xl mx-auto text-center">
				<p class="text-sm font-semibold uppercase tracking-widest text-red-200 mb-4">Blog</p>
				<h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6">
					Welcome to Spirit Media's Blog
				</h1>
				<p class="text-xl text-red-100 max-w-2xl mx-auto leading-relaxed">
					Kingdom insights for authors, leaders, and messengers — publishing, marketing, and
					faith from the Spirit Media family.
				</p>
			</div>
		</section>

		<!-- COMING SOON -->
		<section class="bg-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<div class="inline-block bg-red-50 text-red-600 text-sm font-semibold px-4 py-1 rounded-full mb-6">
					Coming Soon
				</div>
				<h2 class="font-serif text-3xl font-bold text-gray-900 mb-4">
					Articles Are on the Way
				</h2>
				<p class="text-gray-600 text-lg leading-relaxed mb-8">
					We're working on content to help you write, publish, and market your message. Check
					back soon — or follow us on social media to stay updated.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="https://www.facebook.com/spiritmedia.us"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block bg-red-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-red-700 transition-colors"
					>
						Follow on Facebook
					</a>
					<a
						href="https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block border-2 border-red-600 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-50 transition-colors"
					>
						Watch on YouTube
					</a>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bg-navy-950 text-white py-20 px-4">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="font-serif text-3xl font-bold mb-4">Ready to Publish Your Message?</h2>
				<p class="text-gray-300 text-lg leading-relaxed mb-8">
					Don't wait for the perfect moment. Your message is needed now.
				</p>
				<a
					href="https://spiritmedia.us/request-a-call/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-red-600 text-white font-semibold px-8 py-3 rounded-md hover:bg-red-700 transition-colors"
				>
					Request a Free Consultation
				</a>
			</div>
		</section>

	</main>
</Layout>
