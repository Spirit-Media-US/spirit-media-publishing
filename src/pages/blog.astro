---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Blog — Spirit Media"
	description="Insights, encouragement, and resources for Kingdom Messengers from the Spirit Media team."
>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Blog</p>
						<h1 class="type-hero text-ink-soft">Welcome to<br /><span class="text-red">Spirit Media's Blog</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">Insights, encouragement, and resources for Kingdom Messengers building their message and expanding their reach.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
						<div class="rounded-2xl bg-ink-muted aspect-square"></div>
						<div class="rounded-2xl bg-red aspect-square"></div>
						<div class="rounded-2xl bg-ink-soft aspect-square"></div>
						<div class="rounded-2xl bg-red-deep aspect-square"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- COMING SOON -->
		<section class="bg-stone-100 py-20 px-6 lg:px-8">
			<div class="max-w-3xl mx-auto text-center">
				<div class="bg-stone-50 rounded-2xl border border-gray-200 p-12" data-animate="fade-up">
					<div class="flex h-16 w-16 mx-auto items-center justify-center rounded-full bg-red-wash text-red mb-6">
						<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" /></svg>
					</div>
					<h2 class="font-serif text-2xl font-bold text-ink-soft mb-4">Blog Coming Soon</h2>
					<p class="text-stone-600 leading-relaxed mb-6">We're preparing articles, devotionals, and practical guides for Kingdom Messengers. Subscribe to be notified when we launch.</p>
					<a href="/join" class="inline-block bg-red text-white font-semibold px-6 py-3 rounded-md hover:bg-red-deep transition-colors text-sm">Join Our Network →</a>
				</div>
			</div>
		</section>

	</main>
</Layout>
