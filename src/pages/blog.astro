---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Christian Publishing & Marketing Blog — Spirit Media Publishing"
	description="Insights, tips, and encouragement for Christian authors and Kingdom Messengers. Learn how to write, publish, market your book, and grow your platform."
	ogImage="/og-blog.jpg"
>
	<Fragment slot="head">
		<meta name="keywords" content="Christian publishing blog, Christian author tips, how to publish a Christian book, Kingdom Messenger blog, book marketing tips, Christian writing advice, Spirit Media blog, Christian author resources" />
		<meta name="robots" content="index, follow" />
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Blog",
			"name": "Spirit Media Publishing Blog",
			"url": "https://spiritmediapublishing.com/blog",
			"description": "Insights, tips, and encouragement for Christian authors and Kingdom Messengers.",
			"publisher": { "@type": "Organization", "name": "Spirit Media Publishing", "url": "https://spiritmediapublishing.com" }
		})}</script>
	</Fragment>
	<main id="main-content">

		<!-- HERO -->
		<section class="bg-stone-50 px-6 py-12 lg:py-20 lg:py-28 lg:px-8 overflow-hidden">
			<div class="mx-auto max-w-7xl">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="hero-stagger">
						<p class="eyebrow eyebrow-red mb-4">Blog</p>
						<h1 class="type-hero text-ink-soft">Welcome to<br /><span class="text-red">Spirit Media's Blog</span></h1>
						<p class="mt-6 type-body-lg text-stone-600 max-w-xl">Insights, encouragement, and resources for Kingdom Messengers building their message and expanding their reach.</p>
					</div>
					<div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true" data-animate="zoom-in">
						<!-- Row 1 -->
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/blog-hero.jpg" alt="" class="w-full h-full object-cover" style="filter: grayscale(100%) sepia(80%) brightness(0.85) contrast(0.95);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/workonyourself1.jpg" alt="" class="w-full h-full object-cover" style="filter: grayscale(100%) sepia(40%) brightness(0.9) hue-rotate(180deg) contrast(0.9);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/TBLblog.png" alt="" class="w-full h-full object-cover object-center" style="filter: grayscale(100%) sepia(60%) brightness(0.85) contrast(0.95);" />
						</div>
						<!-- Row 2 -->
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/fhb-city.png" alt="" class="w-full h-full object-cover" style="filter: grayscale(100%) sepia(50%) brightness(0.8) contrast(1.05);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/WOY.png" alt="" class="w-full h-full object-cover object-top" style="filter: grayscale(100%) sepia(70%) brightness(0.85) contrast(0.9);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/workonyourself-hands.jpg" alt="" class="w-full h-full object-cover" style="filter: grayscale(100%) sepia(30%) brightness(0.9) hue-rotate(200deg) contrast(0.95);" />
						</div>
						<!-- Row 3 -->
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/kevinwhitephoto.jpg" alt="" class="w-full h-full object-cover object-top" style="filter: grayscale(100%) sepia(60%) brightness(0.85) contrast(0.95);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/fhb-mockup.png" alt="" class="w-full h-full object-cover" style="filter: grayscale(100%) sepia(50%) brightness(0.9) contrast(0.9);" />
						</div>
						<div class="relative rounded-2xl overflow-hidden aspect-square">
							<img src="/kevin-and-shelly.png" alt="" class="w-full h-full object-cover object-top" style="filter: grayscale(100%) sepia(40%) brightness(0.85) hue-rotate(160deg) contrast(0.95);" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- POSTS -->
		<section class="bg-stone-100 py-12 lg:py-20 px-6 lg:px-8">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

					<!-- Post: Why We Start with Heart -->
					<a href="/blog/why-we-start-with-heart" class="group bg-stone-50 rounded-2xl border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-up">
						<div class="h-48 overflow-hidden">
							<img src="/blog-hero.jpg" alt="Why We Start with Heart" class="w-full h-full object-cover" />
						</div>
						<div class="p-6">
							<h3 class="font-serif text-xl font-bold text-red mb-2">Why We Start with Heart</h3>
							<p class="type-body-sm text-stone-600 mb-4">High-capacity leaders are achieving results while losing their souls. Discover why true leadership development must begin with spiritual soul care.</p>
							<div class="flex items-center justify-between text-sm text-stone-400">
								<span>Kevin White · March 3, 2026</span>
								<span class="text-red font-semibold group-hover:underline">Read →</span>
							</div>
						</div>
					</a>

					<!-- Post: Work On Yourself -->
					<a href="/blog/work-on-yourself" class="group bg-stone-50 rounded-2xl border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-up" data-delay="1">
						<div class="h-48 overflow-hidden">
							<img src="/WOY.png" alt="Work On Yourself" class="w-full h-full object-cover" />
						</div>
						<div class="p-6">
							<h3 class="font-serif text-xl font-bold text-red mb-2">The Most Courageous Thing a Leader Can Do</h3>
							<p class="type-body-sm text-stone-600 mb-4">Many leaders are achieving more than ever while quietly feeling less than ever. Discover why working on yourself is the most strategic thing you can do.</p>
							<div class="flex items-center justify-between text-sm text-stone-400">
								<span>Kevin White · March 3, 2026</span>
								<span class="text-red font-semibold group-hover:underline">Read →</span>
							</div>
						</div>
					</a>

					<!-- Post: Believer's Library -->
					<a href="/blog/believers-library" class="group bg-stone-50 rounded-2xl border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden" data-animate="fade-up" data-delay="2">
						<div class="h-48 overflow-hidden">
							<img src="/TBLblog.png" alt="The Believer's Library" class="w-full h-full object-cover object-top" />
						</div>
						<div class="p-6">
							<h3 class="font-serif text-xl font-bold text-red mb-2">A Global Library for Every Nation, Tribe, and Tongue</h3>
							<p class="type-body-sm text-stone-600 mb-4">3.3 billion people have limited access to Jesus and to print books — but nearly everyone has a phone. The Believer's Library changes everything.</p>
							<div class="flex items-center justify-between text-sm text-stone-400">
								<span>Kevin White · March 3, 2026</span>
								<span class="text-red font-semibold group-hover:underline">Read →</span>
							</div>
						</div>
					</a>

				</div>
			</div>
		</section>

	</main>
</Layout>
