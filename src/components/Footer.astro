---
import { sanityClient, urlFor } from '../lib/sanity.ts';

let sitePhone = '1-888-800-3744';
let siteEmail = 'hello@spiritmediapublishing.com';
let siteFacebook = 'https://www.facebook.com/spiritmedia.us';
let siteInstagram = 'https://www.instagram.com/spiritmedia.us';
let siteYoutube = 'https://www.youtube.com/channel/UCQh2m97udW1osliFysbWsOA';
let siteLinkedin = 'https://www.linkedin.com/company/spiritmediaus';
let siteTwitter = 'https://x.com/SpiritMediaUS';
let logoUrl: string | undefined;

try {
	const s = await sanityClient.fetch(
		'*[_type == "siteSettings"][0]{ phone, email, facebook, instagram, youtube, linkedin, twitter, logo }',
	);
	if (s?.phone) sitePhone = s.phone;
	if (s?.email) siteEmail = s.email;
	if (s?.facebook) siteFacebook = s.facebook;
	if (s?.instagram) siteInstagram = s.instagram;
	if (s?.youtube) siteYoutube = s.youtube;
	if (s?.linkedin) siteLinkedin = s.linkedin;
	if (s?.twitter) siteTwitter = s.twitter;
	if (s?.logo) {
		logoUrl = urlFor(s.logo).width(440).height(88).fit('max').auto('format').url();
	}
} catch (e) {}

// Fallback logo URL if fetch fails
if (!logoUrl) {
	logoUrl =
		'https://cdn.sanity.io/images/pmowd8uo/production/37e09864cdd5c5b0811a221b7f06ce7f15fbcbad-6575x656.png?w=440&h=88&fit=max&auto=format';
}
const year = new Date().getFullYear();

const companyLinks = [
	{ href: '/about', label: 'About Us' },
	{ href: '/identity', label: 'Identity' },
	{ href: '/publishing', label: 'Publishing' },
	{ href: '/marketing', label: 'Marketing' },
	{ href: '/contact', label: 'Contact' },
];

const resourceLinks = [
	{ href: '/bookstore', label: 'Bookstore' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/media-center', label: 'Media Center' },
	{ href: '/portfolio', label: 'Portfolio' },
];

const legalLinks = [
	{ href: '/privacy', label: 'Privacy Policy' },
	{ href: '/terms', label: 'Terms of Service' },
];

const socialLinks = [
	{
		href: siteFacebook,
		label: 'Facebook',
		svg: '<path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"/>',
	},
	{
		href: siteInstagram,
		label: 'Instagram',
		svg: '<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/>',
	},
	{
		href: siteYoutube,
		label: 'YouTube',
		svg: '<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>',
	},
	{
		href: siteLinkedin,
		label: 'LinkedIn',
		svg: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>',
	},
	{
		href: siteTwitter,
		label: 'X (Twitter)',
		svg: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>',
	},
];
---

<footer class="bg-ink text-stone-300">
  <!-- Main footer content -->
  <div class="mx-auto max-w-7xl px-4 py-10 lg:py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center" aria-label="Spirit Media Publishing — home">
          <img
            src={logoUrl}
            alt="Spirit Media Publishing"
            width="220"
            height="44"
            class="h-auto w-auto max-w-[220px]"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <span class="hidden items-center gap-2" aria-hidden="true">
            <span class="flex h-8 w-8 items-center justify-center rounded bg-red font-bold text-white text-sm">S</span>
            <span class="font-serif text-lg font-semibold leading-tight">Spirit Media<br /><span class="text-red-soft">Publishing</span></span>
          </span>
        </a>
        <p class="mt-4 text-sm leading-6 text-stone-400">
          We develop Kingdom Messengers by empowering them from heart → message → movement.
          Revealing our Father's heart to all 195 nations.
        </p>
        <div class="mt-6 flex gap-4">
          {
            socialLinks.map(({ href, label, svg }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="text-stone-500 transition-colors hover:text-red-soft"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={svg} />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Company links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-300">Company</h3>
        <ul class="mt-4 space-y-3">
          {
            companyLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-stone-400 transition-colors hover:text-stone-100">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Resources links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-300">Resources</h3>
        <ul class="mt-4 space-y-3">
          {
            resourceLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-stone-400 transition-colors hover:text-stone-100">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-300">Get in Touch</h3>
        <ul class="mt-4 space-y-3 text-sm text-stone-400">
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-red-soft" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>205 S Academy St #3251<br />Cary, NC 27519</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 shrink-0 text-red-soft" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            <a href={"tel:+1" + sitePhone.replace(/[^0-9]/g, "")} class="transition-colors hover:text-stone-100">{sitePhone}</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 shrink-0 text-red-soft" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <button
              id="footer-email-btn"
              data-e={siteEmail.split('@')[0]}
              data-d={siteEmail.split('@')[1]}
              class="transition-colors hover:text-stone-100 cursor-pointer underline bg-transparent border-0 p-0 text-inherit font-inherit"
            >Email Us</button>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-ink-muted/30">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-stone-400">
          &copy; <span id="footer-year"></span> Spirit Media Publishing. All rights reserved. &bull; Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">Spirit Media</a>
        </p>
        <nav aria-label="Legal navigation" class="flex gap-6">
          {
            legalLinks.map(({ href, label }) => (
              <a href={href} class="text-xs text-stone-400 transition-colors hover:text-stone-400">
                {label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </div>
</footer>

<script>
  // Auto-updating copyright year
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = new Date().getFullYear().toString();

  // Email obfuscation — assembled in JS so address never appears in HTML source
  const btn = document.getElementById('footer-email-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      const email = btn.dataset.e + '@' + btn.dataset.d;
      window.location.href = 'mailto:' + email;
    });
  }
</script>
