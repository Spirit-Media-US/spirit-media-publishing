---
interface Props {
	currentSlug: string;
	currentTags: string[];
}
const { currentSlug, currentTags } = Astro.props;

const ALL_POSTS = [
	{
		slug: '/blog/ai-powered-ministry-infrastructure',
		title: 'The Rise of AI-Powered Ministry Infrastructure',
		excerpt:
			'Why the next generation of global gospel impact requires more than websites — and how AI is transforming how Kingdom messages reach the world.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/2818dba933e7689c0d43dd1dc3cc4b897010f0ed-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center 40%',
		date: 'March 6, 2026',
		tags: ['Technology & AI', 'Kingdom Messenger', 'Global Mission', 'Publishing'],
	},
	{
		slug: '/blog/master-youtube-without-it-mastering-you',
		title: 'How to Master YouTube Without It Mastering You',
		excerpt:
			'A practical guide for authors, creators, and Kingdom communicators who want to build lasting reach — without burning out.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/f8dc81706d72594005c0a0e83d7d8b212344b656-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center 50%',
		date: 'March 5, 2026',
		tags: ['YouTube', 'Marketing', 'Kingdom Messenger'],
	},
	{
		slug: '/blog/revive-youtube-channel',
		title: 'How to Revive a "Dead" YouTube Channel',
		excerpt:
			'Why old channels still have value — and a simple strategy to grow to 10,000 subscribers for authors, ministries, and Kingdom communicators.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/ba5e54bed15560135c9b445988c42bd05ec4cd45-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center 30%',
		date: 'March 5, 2026',
		tags: ['YouTube', 'Marketing', 'Kingdom Messenger'],
	},
	{
		slug: '/blog/end-of-traditional-website-platforms',
		title: 'The End of "Traditional" Website Platforms',
		excerpt:
			'Why AI-empowered development is replacing WordPress, Wix, and drag-and-drop builders — and what it means for your ministry or business.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/0b6dd9ee36733cccc72c35fbf17fb78c33ca0cb3-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center 20%',
		date: 'March 4, 2026',
		tags: ['Technology & AI', 'Publishing', 'Marketing'],
	},
	{
		slug: '/blog/why-we-start-with-heart',
		title: 'Why We Start with Heart',
		excerpt:
			'High-capacity leaders are achieving results while losing their souls. Discover why true leadership development must begin with spiritual soul care.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/4494cc0dc0ce536868da01dfff4a8252df0c4b16-1200x630?w=1200&h=630&fit=crop&auto=format.jpg?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center center',
		date: 'March 3, 2026',
		tags: ['Soul Care', 'Leadership', 'Kingdom Messenger', 'Publishing'],
	},
	{
		slug: '/blog/work-on-yourself',
		title: 'The Most Courageous Thing a Leader Can Do',
		excerpt:
			'Many leaders are achieving more than ever while quietly feeling less than ever. Discover why working on yourself is the most strategic thing you can do.',
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/f70a943f61106e4ae7369ea21d4d4723b3e5a7bb-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center center',
		date: 'March 3, 2026',
		tags: ['Leadership', 'Soul Care', 'Kingdom Messenger'],
	},
	{
		slug: '/blog/believers-library',
		title: 'A Global Library for Every Nation, Tribe, and Tongue',
		excerpt:
			"3.3 billion people have limited access to Jesus and to print books — but nearly everyone has a phone. The Believer's Library changes everything.",
		image: 'https://cdn.sanity.io/images/pmowd8uo/production/7b27b1d46368fb3702e227e995ea220a8b42a618-1536x1024?w=768&h=512&fit=crop&auto=format.png?w=768&h=512&fit=crop&auto=format',
		imagePosition: 'center top',
		date: 'March 3, 2026',
		tags: ['Global Mission', 'Technology & AI', 'Kingdom Messenger', 'Publishing'],
	},
];

// Score each post by number of shared tags, exclude current
const related = ALL_POSTS.filter((p) => p.slug !== currentSlug)
	.map((p) => ({
		...p,
		score: p.tags.filter((t) => currentTags.includes(t)).length,
	}))
	.filter((p) => p.score > 0)
	.sort((a, b) => b.score - a.score)
	.slice(0, 3);
---

{related.length > 0 && (
<section class="bg-stone-100 px-6 py-12 lg:py-16 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-serif text-2xl font-bold text-ink-soft mb-8">Related Posts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map(post => (
        <a href={post.slug} class="group bg-white rounded-2xl border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
          <div class="h-36 overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              style={`object-position: ${post.imagePosition};`}
            />
          </div>
          <div class="p-4">
            <div class="flex flex-wrap gap-1 mb-2">
              {post.tags.filter(t => currentTags.includes(t)).slice(0, 2).map(tag => (
                <span class="text-xs font-semibold text-red bg-red-wash rounded-full px-2 py-0.5">{tag}</span>
              ))}
            </div>
            <h3 class="font-serif text-base font-bold text-ink-soft leading-snug group-hover:text-red transition-colors">{post.title}</h3>
            <p class="text-xs text-stone-500 mt-2">{post.date}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}
