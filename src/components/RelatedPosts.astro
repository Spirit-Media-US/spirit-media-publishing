---
import { sanityClient, urlFor } from '../lib/sanity.ts';

interface Props {
	currentSlug: string;
	currentTags: string[];
}
const { currentSlug, currentTags = [] } = Astro.props;

// Fetch all published blog posts from Sanity (excluding current)
const allPosts = await sanityClient.fetch(
	`*[_type == "blogPost" && slug.current != $slug] {
		"slug": "/blog/" + slug.current,
		title,
		excerpt,
		heroImage,
		publishDate,
		tags
	}`,
	{ slug: currentSlug.replace('/blog/', '') },
);

// Format date helper
const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

// Score each post by number of shared tags, pick top 3
const related = allPosts
	.map((p: any) => ({
		...p,
		score: (p.tags || []).filter((t: string) => currentTags.includes(t)).length,
	}))
	.filter((p: any) => p.score > 0)
	.sort((a: any, b: any) => b.score - a.score)
	.slice(0, 3);
---

{related.length > 0 && (
<section class="bg-stone-100 px-6 py-12 lg:py-16 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-serif text-2xl font-bold text-ink-soft mb-8">Related Posts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map((post: any) => (
        <a href={post.slug} class="group bg-white rounded-2xl border border-stone-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
          <div class="h-36 overflow-hidden">
            {post.heroImage ? (
              <img
                src={urlFor(post.heroImage).width(768).height(512).format('webp').url()}
                alt={post.heroImage?.alt || post.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : (
              <div class="w-full h-full bg-stone-200 flex items-center justify-center">
                <span class="text-stone-400 text-sm">No image</span>
              </div>
            )}
          </div>
          <div class="p-4">
            <div class="flex flex-wrap gap-1 mb-2">
              {(post.tags || []).filter((t: string) => currentTags.includes(t)).slice(0, 2).map((tag: string) => (
                <span class="text-xs font-semibold text-red bg-red-wash rounded-full px-2 py-0.5">{tag}</span>
              ))}
            </div>
            <h3 class="font-serif text-base font-bold text-ink-soft leading-snug group-hover:text-red transition-colors">{post.title}</h3>
            <p class="text-xs text-stone-500 mt-2">{post.publishDate ? formatDate(post.publishDate) : ''}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}
