---
// Site-wide navigation bar with active-link highlighting and Resources dropdown

const pathname = new URL(Astro.request.url).pathname;

const mainLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About Us' },
	{ href: '/publishing', label: 'Publishing' },
	{ href: '/marketing', label: 'Marketing' },
] as const;

const resourcesLinks = [
	{ href: '/bookstore', label: 'Bookstore' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/media-center', label: 'Media Center' },
	{ href: '/portfolio', label: 'Portfolio' },
] as const;

function isActive(href: string): boolean {
	return href === '/' ? pathname === '/' : pathname.startsWith(href);
}

const isResourcesActive = resourcesLinks.some(({ href }) => pathname.startsWith(href));
---

<!-- Skip to main content for keyboard / screen-reader users -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-red-600 focus:shadow"
>
  Skip to main content
</a>

<header class="sticky top-0 z-40 border-b border-stone-200 bg-surface shadow-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 lg:h-24 items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="flex shrink-0 items-center" aria-label="Spirit Media Publishing — home">
        <img
          src="/logo.png"
          alt="Spirit Media Publishing"
          width="220"
          height="22"
          class="h-auto w-auto max-w-[220px] sm:max-w-[260px]"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <!-- Fallback: shown only if logo.png is missing -->
        <span class="hidden items-center gap-2" aria-hidden="true">
          <span class="flex h-8 w-8 items-center justify-center rounded bg-red-600 font-bold text-white text-sm">S</span>
          <span class="font-bold text-lg text-gray-900 leading-tight">Spirit Media<br /><span class="text-red-600 text-sm font-semibold">Publishing</span></span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Main navigation" class="hidden lg:block">
        <ul class="flex items-center gap-1">
          {
            mainLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isActive(href) ? 'page' : undefined}
                  class:list={[
                    'rounded px-3 py-2 text-sm font-medium transition-colors',
                    isActive(href)
                      ? 'bg-red text-white'
                      : 'text-stone-600 hover:bg-stone-50 hover:text-ink',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))
          }

          <!-- Resources dropdown -->
          <li class="relative">
            <button
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              id="resources-menu-btn"
              class:list={[
                'flex items-center gap-1 rounded px-3 py-2 text-sm font-medium transition-colors',
                isResourcesActive
                  ? 'bg-red text-white'
                  : 'text-stone-600 hover:bg-stone-50 hover:text-ink',
              ]}
            >
              Resources
              <svg
                class="h-4 w-4 transition-transform duration-200"
                id="resources-chevron"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>

            <!-- Dropdown panel -->
            <ul
              id="resources-menu"
              role="menu"
              aria-labelledby="resources-menu-btn"
              class="absolute left-0 top-full z-50 mt-1 hidden w-44 rounded-md border border-stone-200 bg-surface py-1 shadow-lg"
            >
              {
                resourcesLinks.map(({ href, label }) => (
                  <li role="none">
                    <a
                      href={href}
                      role="menuitem"
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        pathname.startsWith(href)
                          ? 'bg-red text-white font-medium'
                          : 'text-stone-700 hover:bg-stone-50 hover:text-ink',
                      ]}
                    >
                      {label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </nav>

      <!-- CTA + mobile menu button -->
      <div class="flex items-center gap-3">
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center rounded-md bg-red px-4 py-2 text-sm font-bold uppercase tracking-[0.08em] text-white transition-all hover:bg-red-deep"
        >
          Request a Call
        </a>

        <!-- Hamburger — mobile only -->
        <button
          type="button"
          id="mobile-menu-btn"
          aria-controls="mobile-menu"
          aria-expanded="false"
          class="inline-flex items-center justify-center rounded-md p-2 text-stone-600 hover:bg-stone-100 hover:text-ink lg:hidden"
          aria-label="Open main menu"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-stone-100 bg-surface lg:hidden"
    aria-label="Mobile navigation"
  >
    <nav class="mx-auto max-w-7xl space-y-1 px-4 py-3 sm:px-6">
      {
        mainLinks.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class:list={[
              'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
              isActive(href)
                ? 'bg-red text-white'
                : 'text-stone-700 hover:bg-stone-50 hover:text-ink',
            ]}
          >
            {label}
          </a>
        ))
      }

      <!-- Resources section in mobile -->
      <div class="pt-1">
        <p class="px-3 py-1 text-xs font-semibold uppercase tracking-wider text-stone-400">Resources</p>
        {
          resourcesLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                pathname.startsWith(href)
                  ? 'bg-red text-white'
                  : 'text-stone-700 hover:bg-stone-50 hover:text-ink',
              ]}
            >
              {label}
            </a>
          ))
        }
      </div>

      <div class="border-t border-stone-100 pt-3">
        <a
          href="/contact"
          class="block w-full rounded-md bg-red px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-red-deep transition-colors"
        >
          Request a Call
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  let navbarController: AbortController | null = null;

  function initNavbar() {
    navbarController?.abort();
    navbarController = new AbortController();
    const { signal } = navbarController;

    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileBtn?.addEventListener('click', () => {
      if (!mobileMenu || !mobileBtn || !hamburger || !closeIcon) return;
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      mobileBtn.setAttribute('aria-expanded', String(!isOpen));
      hamburger.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    }, { signal });

    // Resources dropdown toggle
    const resourcesBtn = document.getElementById('resources-menu-btn');
    const resourcesMenu = document.getElementById('resources-menu');
    const chevron = document.getElementById('resources-chevron');

    resourcesBtn?.addEventListener('click', () => {
      if (!resourcesMenu || !resourcesBtn || !chevron) return;
      const isOpen = !resourcesMenu.classList.contains('hidden');
      resourcesMenu.classList.toggle('hidden');
      resourcesBtn.setAttribute('aria-expanded', String(!isOpen));
      (chevron as HTMLElement).style.transform = isOpen ? '' : 'rotate(180deg)';
    }, { signal });

    // Close resources dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!resourcesMenu || !resourcesBtn || !chevron) return;
      if (!resourcesBtn.contains(e.target as Node) && !resourcesMenu.contains(e.target as Node)) {
        resourcesMenu.classList.add('hidden');
        resourcesBtn.setAttribute('aria-expanded', 'false');
        (chevron as HTMLElement).style.transform = '';
      }
    }, { signal });
  }

  document.addEventListener('astro:page-load', initNavbar);
</script>
