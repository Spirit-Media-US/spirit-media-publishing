# Homepage — additional Early Hint for the LCP hero image (R2-hosted, stable URL)
# imagesrcset lets DPR-2 mobile devices preload the correct variant (tablet@800w)
# instead of wasting bytes on the wrong one.
/
  Link: <https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-mobile.avif>; rel=preload; as=image; type="image/avif"; fetchpriority=high; imagesrcset="https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-mobile.avif 480w, https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-tablet.avif 800w, https://assets.spiritmediapublishing.com/spirit-media-publishing/hero-desktop.avif 1200w"; imagesizes="(max-width: 1023px) 358px, 600px"
# Link: headers above CF Pages promotes to 103 Early Hints on cached edge hits
# (20-30% LCP win, CF BFCM data). Hero moved from Sanity CDN to R2 so it shares
# origin with fonts (one TLS handshake) and has a stable URL safe for Early Hints.

# ─── Long cache for hashed/immutable assets ────────────────────────────
# CF Pages default is max-age=14400 (4h) which wastes bandwidth re-downloading
# hashed, content-addressed assets on every revisit. PSI flagged 2.3 MB of
# savings from extending these lifetimes.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon-final.svg
  Cache-Control: public, max-age=31536000

/favicon.ico
  Cache-Control: public, max-age=31536000

/og/*
  Cache-Control: public, max-age=31536000

/images/*
  Cache-Control: public, max-age=31536000
